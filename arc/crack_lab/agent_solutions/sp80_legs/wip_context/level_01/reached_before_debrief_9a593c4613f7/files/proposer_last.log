import sys
sys.path.insert(0, '/Users/sasha/gkm/arc/crack_lab')
import gkm_arena as A
import numpy as np
from collections import deque

env = A.Arena('sp80')
base_level = env.levels_completed

def make_key(e):
    f = np.array(e.frame())
    nines = np.where(f == 9)
    if len(nines[0]) == 0:
        return None
    return (nines[0].min(), nines[0].max(), nines[1].min(), nines[1].max())

# BFS to find ALL shortest winning paths
start_key = make_key(env)
q = deque([(env.clone(), [])])
seen = {start_key: []}
found_paths = []

while q:
    node, path = q.popleft()
    
    if found_paths and len(path) >= len(found_paths[0]):
        continue  # Only look for paths of same length or shorter
    
    for action in [1, 2, 3, 4, 5, 6]:
        child = node.clone()
        child.step(action)
        
        if child.levels_completed > base_level:
            found_paths.append(path + [action])
            continue
        
        key = make_key(child)
        if key is None:
            continue
        
        new_path = path + [action]
        if key not in seen or len(seen[key]) > len(new_path):
            seen[key] = new_path
            q.append((child, new_path))
    
    if found_paths and len(q) == 0:
        break

print(f'Found {len(found_paths)} winning paths:')
for p in found_paths[:20]:
    print(f'  {p}')
"
