    ys, xs = np.where(b != a)
    if len(ys) == 0:
        print(f'{title}: NO CHANGE')
        return
    print(f'{title}: {len(ys)} pixel changes')
    for y, x in zip(ys[:20], xs[:20]):
        print(f'  ({y},{x}): {b[y,x]} -> {a[y,x]}')

