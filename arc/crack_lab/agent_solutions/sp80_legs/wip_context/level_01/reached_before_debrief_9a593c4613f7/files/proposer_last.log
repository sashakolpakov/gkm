import sys
sys.path.insert(0, '/Users/sasha/gkm/arc/crack_lab')
import gkm_arena as A
import numpy as np
from collections import deque

env = A.Arena('sp80')
base_level = env.levels_completed

# BFS for win condition
def make_key(e):
    f = np.array(e.frame())
    nines = np.where(f == 9)
    if len(nines[0]) == 0:
        return None
    return (nines[0].min(), nines[0].max(), nines[1].min(), nines[1].max())

start_key = make_key(env)
q = deque([(env.clone(), [])])
seen = {start_key}
found = None

print(f'BFS starting, key={start_key}')

while q and len(seen) < 5000:
    node, path = q.popleft()
    
    for action in [1, 2, 3, 4, 5, 6]:
        child = node.clone()
        child.step(action)
        
        if child.levels_completed > base_level:
            found = path + [action]
            print(f'WIN FOUND! Path: {found}')
            break
        
        key = make_key(child)
        if key is None or key in seen:
            continue
        seen.add(key)
        q.append((child, path + [action]))
    
    if found:
        break

if not found:
    print(f'No win found, explored {len(seen)} states')
    # Show all states found
    print('States found:', sorted(seen)[:10])
