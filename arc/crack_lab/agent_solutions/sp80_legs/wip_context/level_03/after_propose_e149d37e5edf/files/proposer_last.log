import sys, time
sys.path.insert(0, '/Users/sasha/gkm/arc/crack_lab'); sys.path.insert(0,'.')
import gkm_arena as A
import perception as P
def mk2():
    env=A.Arena('sp80')
    for a in [4,4,4,5]: env.step(a)
    return env
grabs={'A':(13,17),'B':(33,25),'C':(29,37)}
def cur_left(env):
    return [bl for bl in P.connected_components(env.frame(),colors=[9],min_area=4)][0].bbox[1]
def place(env,name,left):
    x,y=grabs[name]; env.step(6,x,y); cl=cur_left(env); d=(left-cl)//4
    act=4 if d>0 else 3
    for _ in range(abs(d)): env.step(act)
    return env.terminal()
def test(la,lb,lc):
    env=mk2()
    if place(env,'A',la) or place(env,'B',lb) or place(env,'C',lc): return 'timeout'
    env.step(5)
    if env.terminal(): return 'timeout5'
    return 'win' if env.levels_completed>1 else 'no'
t=time.time()
wins=[]; to=0
for la in range(0,49,4):
    for lb in range(0,49,4):
        for lc in range(0,45,4):
            r=test(la,lb,lc)
            if r=='win': wins.append((la,lb,lc))
            elif r.startswith('timeout'): to+=1
print("wins",len(wins),"timeouts",to,"time",round(time.time()-t,1))
for w in wins: print(w)
