import sys
sys.path.insert(0, '/Users/sasha/gkm/arc/crack_lab'); sys.path.insert(0,'.')
import gkm_arena as A
import perception as P

def mk2():
    env=A.Arena('sp80')
    for a in [4,4,4,5]: env.step(a)
    return env

# grabs by center of each block at level2 start
# A(12w) cols8-19 row16-19; B(12w) cols28-39 row24-27; C(20w) cols20-39 row36-39
grabs={'A':(13,17),'B':(33,25),'C':(29,37)}
widths={'A':12,'B':12,'C':20}

def place(env, name, left):
    x,y=grabs[name]
    env.step(6,x,y)
    for _ in range(16): env.step(3)   # go left to col0
    for _ in range(left//4): env.step(4)

# but after moving one block, grab points for others still valid? grab is by current cell.
# The block moved; its grab center changed. Safer: grab by original position only works before moving that block.
# We place blocks one at a time; each block only grabbed once at its ORIGINAL center. OK since we grab before moving it.

import itertools
positions=list(range(0,49,8))  # 0..48 step8
wins=[]
count=0
for la in positions:
    for lb in positions:
        for lc in range(0,45,8): # C width20 max left 44
            env=mk2()
            place(env,'A',la); place(env,'B',lb); place(env,'C',lc)
            env.step(5)
            if env.levels_completed>1:
                wins.append((la,lb,lc))
            count+=1
print("tested",count,"wins",len(wins))
for w in wins[:60]: print(w)
