import sys, random, time
sys.path.insert(0, '/Users/sasha/gkm/arc/crack_lab'); sys.path.insert(0,'.')
import gkm_arena as A
import perception as P
def mk3():
    env=A.Arena('sp80')
    for a in [4,4,4,5, [6,14,18],4,4,4, [6,34,26],4,4, [6,30,38],4,4,5]:
        env.step(*a) if isinstance(a,list) else env.step(a)
    return env
grabs={'A':(15,21),'B':(49,29),'C':(19,33),'N':(47,41)}
maxl={'A':48,'B':44,'C':40,'N':40}
def cur_left(env):
    return [bl for bl in P.connected_components(env.frame(),colors=[9],min_area=4)][0].bbox[1]
def place(env,name,left):
    x,y=grabs[name]; env.step(6,x,y)
    if env.terminal(): return True
    cl=cur_left(env); d=(left-cl)//4
    act=4 if d>0 else 3
    for _ in range(abs(d)):
        env.step(act)
        if env.terminal(): return True
    return False
def test(cfg):
    env=mk3()
    for name in ['A','B','C','N']:
        if place(env,name,cfg[name]): return 'to'
    env.step(5)
    if env.terminal(): return 'to'
    return 'win' if env.levels_completed>2 else 'no'
random.seed(1)
t=time.time(); tries=0; found=None
while tries<600 and time.time()-t<180:
    cfg={n: random.randrange(0,maxl[n]+1,4) for n in grabs}
    r=test(cfg); tries+=1
    if r=='win':
        found=cfg; break
print("tries",tries,"found",found,"time",round(time.time()-t,1))
