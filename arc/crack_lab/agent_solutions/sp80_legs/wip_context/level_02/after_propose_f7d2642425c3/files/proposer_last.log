import sys
sys.path.insert(0, '/Users/sasha/gkm/arc/crack_lab')
from gkm_arena import Arena
import numpy as np
from perception import *

# Get to level 2
env = Arena('sp80')
for act in [4, 4, 4, 5]:
    env.step(act)
print(f"Level: {env.levels_completed}")

# Try BFS to win
from collections import deque

base_level = env.levels_completed

# Key: position of 9-block, 8-blocks, 6-block (if they move)
def key_fn(e):
    f = np.array(e.frame())
    r9, c9 = np.where(f == 9)
    r8, c8 = np.where(f == 8)
    return (
        (int(r9.min()) if len(r9) else -1, int(c9.min()) if len(c9) else -1),
        (int(r8.min()) if len(r8) else -1, int(c8.min()) if len(c8) else -1),
    )

start_key = key_fn(env)
q = deque([(env.clone(), [])])
seen = {start_key}
found = None

while q and len(seen) <= 10000:
    node, path = q.popleft()
    if len(path) >= 50:
        continue
    for action in [1, 2, 3, 4, 5, 6]:
        child = node.clone()
        child.step(action)
        if child.levels_completed > base_level:
            found = path + [action]
            break
        k = key_fn(child)
        if k not in seen:
            seen.add(k)
            q.append((child, path + [action]))
    if found:
        break

if found:
    print(f"Found winning path: {found}")
    print(f"Length: {len(found)}")
else:
    print(f"No path found in {len(seen)} states")
