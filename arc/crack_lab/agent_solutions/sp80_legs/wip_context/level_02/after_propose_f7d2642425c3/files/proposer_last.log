from gkm_arena import Arena
import numpy as np
from collections import deque

# Get to level 2
env = Arena('sp80')
for act in [4, 4, 4, 5]:
    env.step(act)
print(f"Level: {env.levels_completed}")

base_level = env.levels_completed

# Use the FULL frame hash for BFS (definitive - no false negatives)
def key_fn(e):
    f = np.array(e.frame())
    # Only track non-background, non-timer pixels
    mask = (f != 12) & (f != 14)  # remove background and timer
    return (f[mask]).tobytes() + f[63].tobytes()  # Include timer row for completeness

start_key = key_fn(env)
q = deque([(env.clone(), [])])
seen = {start_key}
found = None

print("Running full-hash BFS (max 5000 states, max 30 depth)...")
while q and len(seen) <= 5000:
    node, path = q.popleft()
    if len(path) >= 30:
        continue
    for action in [1, 2, 3, 4, 5, 6]:
        child = node.clone()
        child.step(action)
        if child.levels_completed > base_level:
            found = path + [action]
            break
        k = key_fn(child)
        if k not in seen:
            seen.add(k)
            q.append((child, path + [action]))
    if found:
        break

if found:
    print(f"Found: {found}")
else:
    print(f"No path in {len(seen)} states (depth ≤30)")
    
    # Try with larger depth
    seen2 = set()
    q2 = deque([(env.clone(), [])])
    def key2(e):
        f = np.array(e.frame())
        r9, c9 = np.where(f == 9)
        r8, c8 = np.where(f == 8)
        pos9 = (int(r9.min())//4, int(c9.min())//4) if len(r9) > 0 else (-1,-1)
        blobs8 = tuple(sorted(set(zip((r8//4).tolist(), (c8//4).tolist()))))
        return (pos9, blobs8[:4])  # First 4 8-block cells
    
    seen2.add(key2(env))
    found2 = None
    while q2 and len(seen2) <= 200000:
        node, path = q2.popleft()
        if len(path) >= 100:
            continue
        for action in [1, 2, 3, 4, 5, 6]:
            child = node.clone()
            child.step(action)
            if child.levels_completed > base_level:
                found2 = path + [action]
                break
            k = key2(child)
            if k not in seen2:
                seen2.add(k)
                q2.append((child, path + [action]))
        if found2:
            break
    
    if found2:
        print(f"Found with larger BFS: {found2}")
    else:
        print(f"No path in {len(seen2)} states (depth ≤100)")
