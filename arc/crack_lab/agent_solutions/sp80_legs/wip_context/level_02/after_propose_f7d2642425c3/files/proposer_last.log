import sys
sys.path.insert(0, '/Users/sasha/gkm/arc/crack_lab')
from gkm_arena import Arena
import numpy as np
from collections import deque

# Get to level 2 
env = Arena('sp80')
for act in [4, 4, 4, 5]:
    env.step(act)
print(f"Level: {env.levels_completed}")

# Wider BFS using full frame hash
base_level = env.levels_completed

def key_fn(e):
    f = np.array(e.frame())
    # Track key elements only
    r9, c9 = np.where(f == 9)
    r8, c8 = np.where(f == 8)
    r6, c6 = np.where(f == 6)
    r4, c4 = np.where(f == 4)
    
    def bbox(r, c):
        if len(r) == 0: return (-1, -1)
        return (int(r.min()), int(c.min()))
    
    return (bbox(r9, c9), tuple(sorted(set(zip(r8.tolist(), c8.tolist())))[:2]), bbox(r6, c6), bbox(r4, c4))

# This might be too slow due to 8-block tracking
# Let me try a simpler approach first

def key_simple(e):
    f = np.array(e.frame())
    r9, c9 = np.where(f == 9)
    r8, c8 = np.where(f == 8)
    if len(r9) == 0:
        pos9 = (-1, -1)
    else:
        pos9 = (int(r9.min()), int(c9.min()))
    # Track all 8-block positions compactly
    if len(r8) == 0:
        pos8 = ()
    else:
        # Find bounding boxes of each separate 8-block
        blobs8 = []
        seen8 = set()
        for r, c in zip(r8.tolist(), c8.tolist()):
            if (r, c) not in seen8:
                seen8.add((r, c))
                blobs8.append((r, c))
        blobs8 = tuple(sorted(set((int(r)//4, int(c)//4) for r, c in blobs8)))
        pos8 = blobs8
    return (pos9, pos8)

start_key = key_simple(env)
q = deque([(env.clone(), [])])
seen = {start_key}
found = None

print("Starting BFS...")
while q and len(seen) <= 50000:
    node, path = q.popleft()
    if len(path) >= 60:
        continue
    for action in [1, 2, 3, 4, 5, 6]:
        child = node.clone()
        child.step(action)
        if child.levels_completed > base_level:
            found = path + [action]
            break
        k = key_simple(child)
        if k not in seen:
            seen.add(k)
            q.append((child, path + [action]))
    if found:
        break

if found:
    print(f"Found winning path: {found}")
    print(f"Length: {len(found)}")
else:
    print(f"No path found in {len(seen)} states explored")
