from gkm_arena import Arena
import numpy as np

# Get to level 2
env = Arena('sp80')
for act in [4, 4, 4, 5]:
    env.step(act)

def show_state(c):
    f = np.array(c.frame())
    r9, c9 = np.where(f == 9)
    
    # Find 8-block positions separately (look at row clusters)
    r8, c8_8 = np.where(f == 8)
    block8s = []
    if len(r8) > 0:
        # Group by row range (4-pixel blocks)
        by_cell_row = {}
        for r, c in zip(r8.tolist(), c8_8.tolist()):
            cell_r = r // 4
            if cell_r not in by_cell_row:
                by_cell_row[cell_r] = []
            by_cell_row[cell_r].append(c)
        for cell_r, cs in sorted(by_cell_row.items()):
            block8s.append((cell_r*4, cell_r*4+3, min(cs), max(cs)))
    
    r6, c6 = np.where(f == 6)
    r4, c4 = np.where(f == 4)
    
    out = {}
    if len(r9) > 0:
        out['9'] = (r9.min(), r9.max(), c9.min(), c9.max())
    out['8s'] = block8s
    if len(r6) > 0:
        out['6'] = (r6.min(), r6.max(), c6.min(), c6.max())
    if len(r4) > 0:
        out['4'] = (r4.min(), r4.max(), c4.min(), c4.max())
    return out

print("Initial state:")
print(show_state(env))

# Move UP several times
c = env.clone()
for i in range(10):
    c.step(1)
    print(f"After {i+1} UPs:")
    print(show_state(c))
