import sys
sys.path.insert(0, '/Users/sasha/gkm/arc/crack_lab')
from gkm_arena as A
import numpy as np
from collections import deque

env = A.Arena('sp80')
for act in [4, 4, 4, 5]:
    env.step(act)
base = env.levels_completed

# BFS that tracks 9-block position + USE history
def get_pos(e):
    f = np.array(e.frame())
    r9, c9 = np.where(f == 9)
    return (int(r9.min())//4, int(c9.min())//4) if len(r9)>0 else (-1,-1)

# State: (9-block cell pos, tuple of USE-positions used)
start_pos = get_pos(env)
start_state = (start_pos, ())  # no USEs yet

q = deque([(env.clone(), [], start_state)])
seen = {start_state}
found = None

print("BFS with USE tracking...")
while q and len(seen) <= 100000:
    node, path, state = q.popleft()
    pos, use_hist = state
    
    if len(use_hist) >= 4:  # limit to 4 USEs max (5th would be terminal)
        continue
    if len(path) >= 40:
        continue
    
    for action in [1, 2, 3, 4, 5, 6]:
        child = node.clone()
        child.step(action)
        
        if child.levels_completed > base:
            found = path + [action]
            print(f"FOUND: {found}")
            break
        if child.terminal():
            continue
        
        new_pos = get_pos(child)
        if action == 5:  # USE
            new_use_hist = use_hist + (pos,)  # record position at which USE was pressed
        else:
            new_use_hist = use_hist
        
        new_state = (new_pos, new_use_hist)
        if new_state not in seen:
            seen.add(new_state)
            q.append((child, path + [action], new_state))
    
    if found:
        break

if not found:
    print(f"No path found. {len(seen)} states explored.")
