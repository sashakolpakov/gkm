$ python - <<'EOF'
import sys
sys.path.insert(0, '/Users/sasha/gkm/arc/crack_lab')
from gkm_arena import Arena
import numpy as np

env = Arena('sp80')
for act in [4, 4, 4, 5]:
    env.step(act)
base = env.levels_completed

# Try all sequences of length 1-6 that contain action 5 or 6
# Use BFS with full frame hash
from collections import deque

def key(e):
    f = np.array(e.frame())
    # compact key: positions of each non-background color
    r9, c9 = np.where(f == 9)
    row63 = f[63]  # timer row
    pos9 = (int(r9.min())//4, int(c9.min())//4) if len(r9)>0 else (-1,-1)
    timer = int(np.argmax(row63 != 14)) if (row63 == 14).any() else 64
    return (pos9, timer)

q = deque([(env.clone(), [])])
seen = {key(env)}
found = None

print("BFS (correct state space)...")
while q and len(seen) <= 50000:
    node, path = q.popleft()
    if len(path) >= 60:
        continue
    for action in [1, 2, 3, 4, 5, 6]:
        child = node.clone()
        child.step(action)
        if child.levels_completed > base:
            found = path + [action]
            print(f"FOUND: {found}")
            break
        if child.terminal():
            continue  # don't explore terminal states
        k = key(child)
        if k not in seen:
            seen.add(k)
            q.append((child, path + [action]))
    if found:
        break

if not found:
    print(f"No path found. {len(seen)} states explored.")
    # What positions were reachable?
    positions = set(k[0] for k in seen)
    timers = set(k[1] for k in seen)
    print(f"Reachable positions (row, col in cells): {sorted(positions)}")
    print(f"Timer values explored: {sorted(timers)}")
