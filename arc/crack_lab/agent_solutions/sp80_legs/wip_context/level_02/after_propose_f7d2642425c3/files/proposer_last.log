    for r, c in zip(r8.tolist(), c8.tolist()):
        cr, cc = r // 4, c // 4
        if cr not in blobs8:
            blobs8[cr] = set()
        blobs8[cr].add(cc)
    
    pos8 = tuple(sorted((cr, min(ccs), max(ccs)) for cr, ccs in blobs8.items()))
    return (pos9, pos8)

start_key = key_fn(env)
