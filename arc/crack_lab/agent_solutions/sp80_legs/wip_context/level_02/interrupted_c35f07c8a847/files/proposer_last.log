import gkm_arena as A
import numpy as np
from collections import deque
def get_to_level2():
    holder = {}
    def prog(env):
        for a in [4,4,4,5]: env.step(a)
        holder['env'] = env.clone()
    A.run_program('sp80', prog)
    return holder['env']
def p9(e):
    f=np.array(e.frame());r,c=np.where(f==9)
    return None if len(r)==0 else(int(r.min()),int(r.max()),int(c.min()),int(c.max()))
def scan_win(e):
    # enumerate reachable 9 positions via moves, test USE for level up
    seen={p9(e):e.clone()}; q=deque([e.clone()])
    while q:
        n=q.popleft()
        for a in(1,2,3,4):
            ch=n.clone();ch.step(a);p=p9(ch)
            if p not in seen:seen[p]=ch;q.append(ch)
    for p,ee in seen.items():
        ch=ee.clone();ch.step(5)
        if ch.levels_completed>1: return ('WIN at',p)
    return None
def move_to(e,tr,tc):
    # move 9 (bbox) so rmin=tr,cmin=tc using greedy steps
    for _ in range(40):
        b=p9(e)
        if b is None: break
        rmin,rmax,cmin,cmax=b
        if rmin==tr and cmin==tc: break
        if cmin<tc: e.step(4)
        elif cmin>tc: e.step(3)
        elif rmin<tr: e.step(2)
        elif rmin>tr: e.step(1)
    return p9(e)
