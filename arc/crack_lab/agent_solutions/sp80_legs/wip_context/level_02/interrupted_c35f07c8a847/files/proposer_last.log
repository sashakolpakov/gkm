$ cd /Users/sasha/gkm/arc/crack_lab/runs/scratch/gkm_legs_ws_sp80 && cat > /tmp/sound.py << 'EOF'
import sys, os, time
sys.path.insert(0, '/Users/sasha/gkm/arc/crack_lab')
sys.path.insert(0, os.getcwd())
import gkm_arena as A
import numpy as np
from collections import deque
def get_to_level2():
    holder = {}
    def prog(env):
        for a in [4,4,4,5]: env.step(a)
        holder['env'] = env.clone()
    A.run_program('sp80', prog)
    return holder['env']
def pos9(e):
    f=np.array(e.frame());r,c=np.where(f==9)
    return None if len(r)==0 else (int(r.min()),int(c.min()))
def fkey(e):
    f=np.array(e.frame()).copy(); f[63,:]=0; return f.tobytes()
def reachable(e):
    # dict pos->(env,path) reachable by moves only
    start=pos9(e)
    res={start:(e.clone(),[])}
    q=deque([start])
    while q:
        p=q.popleft(); node,pa=res[p]
        for a in(1,2,3,4):
            c=node.clone(); c.step(a)
            if c.terminal(): continue
            np_=pos9(c)
            if np_ is None or np_ in res: continue
            res[np_]=(c,pa+[a]); q.append(np_)
    return res
t=time.time(); solution=None
def search(e, prefix, uses_left):
    global solution
    if solution or time.time()-t>500: return
    R=reachable(e)
    # check win by position or by single USE
    for p,(node,pa) in R.items():
        if node.levels_completed>1:
            solution=prefix+pa; return
        c=node.clone(); c.step(5)
        if c.levels_completed>1:
            solution=prefix+pa+[5]; return
    if uses_left<=0: return
    # branch on effective USEs from distinct trigger positions, dedup children by frame
    seen=set()
    for p,(node,pa) in R.items():
        c=node.clone(); before=fkey(c); c.step(5)
        if c.terminal(): continue
        if fkey(c)==before: continue  # no-op USE, skip
        k=fkey(c)
        if k in seen: continue
        seen.add(k)
        search(c, prefix+pa+[5], uses_left-1)
        if solution: return
