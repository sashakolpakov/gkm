import sys, os
sys.path.insert(0, '/Users/sasha/gkm/arc/crack_lab')
sys.path.insert(0, os.getcwd())
import gkm_arena as A
import numpy as np
from collections import deque
def get_to_level2():
    holder = {}
    def prog(env):
        for a in [4,4,4,5]: env.step(a)
        holder['env'] = env.clone()
    A.run_program('sp80', prog)
    return holder['env']
def blocks(e,color):
    f=np.array(e.frame())
    seen=np.zeros(f.shape,bool); out=[]
    for r in range(64):
        for c in range(64):
            if f[r,c]==color and not seen[r,c]:
                q=[(r,c)]; seen[r,c]=True; pts=[]
                while q:
                    x,y=q.pop(); pts.append((x,y))
                    for dx,dy in((1,0),(-1,0),(0,1),(0,-1)):
                        nx,ny=x+dx,y+dy
                        if 0<=nx<64 and 0<=ny<64 and f[nx,ny]==color and not seen[nx,ny]:
                            seen[nx,ny]=True; q.append((nx,ny))
                rs=[p[0]for p in pts];cs=[p[1]for p in pts]
                out.append((min(rs),max(rs),min(cs),max(cs)))
    return sorted(out)
env=get_to_level2()
def pos(e):
    f=np.array(e.frame());r,c=np.where(f==9);return(int(r.min()),int(c.min()))
seen={pos(env):env.clone()}; q=deque([env.clone()])
while q:
    n=q.popleft()
    for a in(1,2,3,4):
        ch=n.clone();ch.step(a);p=pos(ch)
        if p not in seen:seen[p]=ch;q.append(ch)
# classify USE effects
for p in sorted(seen):
    e=seen[p]
    b9=blocks(e,9); b8=blocks(e,8)
    ch=e.clone();ch.step(5)
    a9=blocks(ch,9); a8=blocks(ch,8)
    if b9!=a9 or b8!=a8:
        print("9pos",p,"| before 8:",b8,"9:",b9)
        print("     -> after 8:",a8,"9:",a9)
