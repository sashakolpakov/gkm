import sys, os, time
sys.path.insert(0, '/Users/sasha/gkm/arc/crack_lab')
sys.path.insert(0, os.getcwd())
import gkm_arena as A
import numpy as np
def get_to_level2():
    holder = {}
    def prog(env):
        for a in [4,4,4,5]: env.step(a)
        holder['env'] = env.clone()
    A.run_program('sp80', prog)
    return holder['env']
STEPS=[0]
def clone_step(e,a):
    e.step(a); STEPS[0]+=1
def p9(e):
    f=np.array(e.frame());r,c=np.where(f==9)
    return None if len(r)==0 else (int(r.min()),int(c.min()),int(c.max()))
def moveto(e,tr,tc,log):
    for _ in range(40):
        b=p9(e)
        if b is None or e.terminal(): return False
        r0,c0,c1=b
        if r0>tr: clone_step(e,1); log.append(1)
        elif r0<tr: clone_step(e,2); log.append(2)
        elif c0<tc: clone_step(e,4); log.append(4)
        elif c0>tc: clone_step(e,3); log.append(3)
        else: return True
    return False
def fkey(e):
    f=np.array(e.frame()).copy(); f[63,:]=0; return f.tobytes()
ALLCOLS=list(range(0,53,4))
LEFTCOLS=[0,4,8,12,16,20,24]
sol=[None]
def search(e, prefix, uses_left):
    if sol[0] or STEPS[0]>200000: return
    # WIN check: move active to each top-row column, USE
    for col in ALLCOLS:
        c=e.clone(); lg=list(prefix)
        if not moveto(c,16,col,lg): continue
        if c.levels_completed>1: sol[0]=lg; return
        c.step(5); STEPS[0]+=1; lg.append(5)
        if c.levels_completed>1: sol[0]=lg; return
    if uses_left<=0: return
    seen=set()
    for col in LEFTCOLS:
        c=e.clone(); lg=list(prefix)
        if not moveto(c,16,col,lg): continue
        before=fkey(c); c.step(5); STEPS[0]+=1; lg.append(5)
        if c.terminal(): continue
        if fkey(c)==before: continue
        if c.levels_completed>1: sol[0]=lg; return
        k=fkey(c)
        if k in seen: continue
        seen.add(k)
        search(c, lg, uses_left-1)
        if sol[0]: return
env=get_to_level2()
t=time.time()
search(env.clone(), [], 3)
print("SOL",sol[0],"steps",STEPS[0],"time",round(time.time()-t,1))
import json; open("/tmp/lean_result.json","w").write(json.dumps(sol[0]))
