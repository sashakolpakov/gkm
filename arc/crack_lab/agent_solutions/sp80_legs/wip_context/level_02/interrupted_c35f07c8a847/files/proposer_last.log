import sys, os, time
sys.path.insert(0, '/Users/sasha/gkm/arc/crack_lab')
sys.path.insert(0, os.getcwd())
import gkm_arena as A
import numpy as np
from collections import deque

def get_to_level2():
    holder = {}
    def prog(env):
        for a in [4,4,4,5]:
            env.step(a)
        holder['env'] = env.clone()
    A.run_program('sp80', prog)
    return holder['env']

env = get_to_level2()
base = env.levels_completed

def key_fn(e):
    f = np.array(e.frame())
    # positions of 8 and 9 pixels
    k8 = tuple(sorted(map(tuple, np.argwhere(f==8).tolist())))
    k9 = tuple(sorted(map(tuple, np.argwhere(f==9).tolist())))
    return (k8,k9)

start = key_fn(env)
q = deque([(env.clone(), [])])
seen = {start}
found=None
states=0
t=time.time()
while q and states<8000:
    node, path = q.popleft()
    states+=1
    if len(path)>=30: continue
    for a in (1,2,3,4,5):
        child = node.clone()
        child.step(a)
        if child.levels_completed>base:
            found=path+[a]; break
        k=key_fn(child)
        if k in seen: continue
        seen.add(k); q.append((child, path+[a]))
    if found: break
print("found", found, "states", states, "seen", len(seen), "time", round(time.time()-t,1))
