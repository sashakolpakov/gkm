import sys, os, time
sys.path.insert(0, '/Users/sasha/gkm/arc/crack_lab')
sys.path.insert(0, os.getcwd())
import gkm_arena as A
import numpy as np
def get_to_level2():
    holder = {}
    def prog(env):
        for a in [4,4,4,5]: env.step(a)
        holder['env'] = env.clone()
    A.run_program('sp80', prog)
    return holder['env']
def p9(e):
    f=np.array(e.frame());r,c=np.where(f==9)
    return None if len(r)==0 else (int(r.min()),int(r.max()),int(c.min()),int(c.max()))
def move_to(e,trow,tcol,acts):
    # returns True if reached (approx), appends actions; e mutated
    for _ in range(40):
        if e.terminal(): return False
        b=p9(e)
        if b is None: return False
        rmin,rmax,cmin,cmax=b
        if rmin>trow: e.step(1); acts.append(1)
        elif cmin<tcol: e.step(4); acts.append(4)
        elif cmin>tcol: e.step(3); acts.append(3)
        else: return True
    return False
env=get_to_level2()
cols=list(range(0,53,4))  # possible cmin for 12-wide
t=time.time(); win=None
# DFS over up to 4 USE drops, each drop at (16, col)
def dfs(e, acts, uses):
    global win
    if win or time.time()-t>300: return
    if e.terminal(): return
    if e.levels_completed>1: win=acts[:]; return
    if uses>=4: return
    b=p9(e)
    if b is None: return
    for col in cols:
        c=e.clone(); a2=acts[:]
        if not move_to(c,16,col,a2): continue
        if c.terminal(): continue
        if c.levels_completed>1: win=a2; return
        c.step(5); a2.append(5)
        if c.levels_completed>1: win=a2; return
        if c.terminal(): continue
        dfs(c,a2,uses+1)
        if win: return
dfs(env.clone(),[],0)
print("WIN",win,"time",round(time.time()-t,1))
import json; open("/tmp/macro_result.json","w").write(json.dumps(win))
