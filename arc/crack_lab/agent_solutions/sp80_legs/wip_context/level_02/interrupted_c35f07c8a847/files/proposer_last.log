        r,c=b
        if c<tc: e.step(4)
        elif c>tc: e.step(3)
        elif r<tr: e.step(2)
        elif r>tr: e.step(1)
        else: break
        steps+=1
    if e.terminal(): print("terminal during move"); break
    e.step(5); uses+=1; steps+=1
    after=key(e)
    print("USE",uses,"steps",steps,"effective",before!=after,"term",e.terminal(),"lvl",e.levels_completed)
