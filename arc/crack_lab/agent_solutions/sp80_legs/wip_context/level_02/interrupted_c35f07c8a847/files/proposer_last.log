import sys, os, time
sys.path.insert(0, '/Users/sasha/gkm/arc/crack_lab')
sys.path.insert(0, os.getcwd())
import gkm_arena as A
import numpy as np
from collections import deque
def get_to_level2():
    holder = {}
    def prog(env):
        for a in [4,4,4,5]: env.step(a)
        holder['env'] = env.clone()
    A.run_program('sp80', prog)
    return holder['env']
def key(e):
    f=np.array(e.frame())
    k8=np.argwhere(f==8); k9=np.argwhere(f==9)
    return (k8.tobytes(),k9.tobytes())
env=get_to_level2()
start=env.clone()
q=deque([(start,[],0)])
seen={key(start)}
t=time.time(); best=None; states=0
while q:
    node,path,uses=q.popleft()
    states+=1
    if states%5000==0: print("states",states,"depth",len(path),"time",round(time.time()-t),"q",len(q))
    if len(path)>=26: continue
    for a in (1,2,3,4,5):
        if a==5 and uses>=3: continue
        child=node.clone()
        child.step(a)
        if child.terminal():
            if child.levels_completed>1:
                best=path+[a]; print("WIN",best); q.clear(); break
            continue
        if child.levels_completed>1:
            best=path+[a]; print("WIN",best); q.clear(); break
        k=key(child)
        if k in seen: continue
        seen.add(k)
        q.append((child,path+[a],uses+(1 if a==5 else 0)))
    if best: break
    if time.time()-t>240: print("timeout"); break
print("done best",best,"states",states,"seen",len(seen))
