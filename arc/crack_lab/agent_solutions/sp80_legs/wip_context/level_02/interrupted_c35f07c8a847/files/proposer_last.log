import sys, os
sys.path.insert(0, '/Users/sasha/gkm/arc/crack_lab')
sys.path.insert(0, os.getcwd())
import gkm_arena as A
import numpy as np
from collections import deque

def get_to_level2():
    holder = {}
    def prog(env):
        for a in [4,4,4,5]:
            env.step(a)
        holder['env'] = env.clone()
    A.run_program('sp80', prog)
    return holder['env']

env = get_to_level2()
base = env.levels_completed

def key_fn(e):
    f = np.array(e.frame())
    rows, cols = np.where(f == 9)
    if len(rows)==0: return None
    return (int(rows.min()), int(cols.min()))

start = key_fn(env)
q = deque([(env.clone(), [])])
seen = {start}
found=None
states=0
while q and states<=3000:
    node, path = q.popleft()
    states+=1
    if len(path)>=25: continue
    for a in (1,2,3,4,5):
        child = node.clone()
        child.step(a)
        if child.levels_completed>base:
            found=path+[a]; break
        k=key_fn(child)
        if k is None or k in seen: continue
        seen.add(k); q.append((child, path+[a]))
    if found: break
print("found", found, "states", states, "seen", len(seen))
EOF
