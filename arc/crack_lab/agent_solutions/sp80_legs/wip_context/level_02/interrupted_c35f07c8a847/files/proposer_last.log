import sys, os, time
sys.path.insert(0, '/Users/sasha/gkm/arc/crack_lab')
sys.path.insert(0, os.getcwd())
import gkm_arena as A
import numpy as np
from collections import deque
def get_to_level2():
    holder = {}
    def prog(env):
        for a in [4,4,4,5]: env.step(a)
        holder['env'] = env.clone()
    A.run_program('sp80', prog)
    return holder['env']
def comps9(e):
    f=np.array(e.frame());r,c=np.where(f==9)
    if len(r)==0: return None
    return (int(r.min()),int(c.min()),int(c.max()-c.min()+1))
def masked(e):
    f=np.array(e.frame()).copy(); f[63,:]=0; return f
env=get_to_level2()
# 3 blocks: widths, initial positions (rmin,cmin)
# big20 active@(36,20); A(12)@(16,8); B(12)@(24,28)
W=[20,12,12]
start_pos=[(36,20),(16,8),(24,28)]
start=(env.clone(),0,tuple(start_pos))
def key(s):
    _,ai,pos=s
    return (ai,pos)
q=deque([(start,[])]); seen={key(start)}
sol=None; steps=0; t=time.time(); unmatched=0
while q and steps<230000 and sol is None:
    (e,ai,pos),path=q.popleft()
    for act in (1,2,3,4,5):
        c=e.clone(); before=masked(c); c.step(act); steps+=1
        if c.levels_completed>1: sol=path+[act]; break
        if c.terminal(): continue
        info=comps9(c)
        if info is None: continue
        r,cmin,w=info
        pos=list(pos)
        if act in (1,2,3,4):
            npos=list(pos); npos[ai]=(r,cmin); nai=ai
        else:
            if np.array_equal(masked(c),before): continue  # no-op
            # effective USE: active stamped at pos[ai] (unchanged since we moved it already).
            # new active = block whose stored (r,cmin,width) matches info
            nai=None
            for j in range(3):
                if j==ai: continue
                if pos[j]==(r,cmin) and W[j]==w: nai=j; break
            if nai is None:
                # fallback: match by width only among non-active
                cand=[j for j in range(3) if j!=ai and W[j]==w]
                if len(cand)==1: nai=cand[0]; 
                else: unmatched+=1; continue
            npos=list(pos); npos[nai]=(r,cmin)
        ns=(c,nai,tuple(npos)); k=key(ns)
        if k in seen: continue
        seen.add(k); q.append((ns,path+[act]))
    if sol: break
print("SOL",sol,"steps",steps,"states",len(seen),"unmatched",unmatched,"time",round(time.time()-t,1))
import json; open("/tmp/logic3_result.json","w").write(json.dumps(sol))
