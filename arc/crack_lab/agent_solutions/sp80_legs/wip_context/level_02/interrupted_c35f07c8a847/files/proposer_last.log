def get_to_level2():
    holder = {}
    def prog(env):
        for a in [4,4,4,5]: env.step(a)
        holder['env'] = env.clone()
    A.run_program('sp80', prog)
    return holder['env']
def comps(e,color):
    f=np.array(e.frame());seen=np.zeros(f.shape,bool);out=[]
    for r in range(64):
        for c in range(64):
            if f[r,c]==color and not seen[r,c]:
                st=[(r,c)];seen[r,c]=True;pts=[]
                while st:
                    x,y=st.pop();pts.append((x,y))
                    for dx,dy in((1,0),(-1,0),(0,1),(0,-1)):
                        nx,ny=x+dx,y+dy
                        if 0<=nx<64 and 0<=ny<64 and f[nx,ny]==color and not seen[nx,ny]:
                            seen[nx,ny]=True;st.append((nx,ny))
                rs=[p[0]for p in pts];cs=[p[1]for p in pts]
                out.append((min(rs),max(rs),min(cs),max(cs)))
    return sorted(out)
def nblocks(e): return len(comps(e,8))+len(comps(e,9))
def p9(e):
    f=np.array(e.frame());r,c=np.where(f==9)
    return None if len(r)==0 else (int(r.min()),int(c.min()),int(c.max()))
env=get_to_level2()
e=env.clone()
# Strategy: keep active at DOWN region (rows44-47), never overlapping, cycle many USEs.
# But USE needs trigger zone (upper). Let me just move active straight UP to row16 then USE, and vary column so drops spread.
# Simpler: just USE from wherever after moving up a bit, count deaths & nblocks
import itertools
uses=0
log=[]
# move active to row 16 (up) at current column, then USE, repeat
while not e.terminal() and uses<10:
    # move up to row16
    for _ in range(10):
        b=p9(e)
        if b is None: break
        if b[0]>16: e.step(1)
        else: break
        if e.terminal(): break
    if e.terminal(): log.append(("died moving up",uses)); break
    nb=nblocks(e)
    e.step(5); uses+=1
    if e.terminal(): log.append(("USE",uses,"->DEATH","nb_before",nb)); break
    log.append(("USE",uses,"nb_after",nblocks(e),"9",p9(e)))
for l in log: print(l)
