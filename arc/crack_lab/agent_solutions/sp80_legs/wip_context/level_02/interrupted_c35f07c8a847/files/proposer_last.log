import sys, os, time
sys.path.insert(0, '/Users/sasha/gkm/arc/crack_lab')
sys.path.insert(0, os.getcwd())
import gkm_arena as A
import numpy as np
from collections import deque
def get_to_level2():
    holder = {}
    def prog(env):
        for a in [4,4,4,5]: env.step(a)
        holder['env'] = env.clone()
    A.run_program('sp80', prog)
    return holder['env']
def active(e):
    f=np.array(e.frame());r,c=np.where(f==9)
    if len(r)==0: return None
    return (int(r.min()),int(c.min()),int(c.max()-c.min()+1))  # rmin,cmin,width
def masked(e):
    f=np.array(e.frame()).copy(); f[63,:]=0; return f.tobytes()
env=get_to_level2()
# start: active=big(20), big at (36,20), small(B,12) at (24,28)
a0=active(env)
print("start active",a0)
# BFS with logical key
# state carried: (env, active_is_big, big_pos(r,c), small_pos(r,c))
start=(env.clone(), True, (36,20), (24,28))
def key(s):
    _,ab,bp,sp=s
    return (ab,bp,sp)
q=deque([(start,[])]); seen={key(start)}
sol=None; steps=0; t=time.time(); bad=0
while q and steps<230000 and sol is None:
    (e,ab,bp,sp),path=q.popleft()
    for act in (1,2,3,4,5):
        c=e.clone(); before=masked(c); c.step(act); steps+=1
        if c.levels_completed>1:
            sol=path+[act]; break
        if c.terminal(): continue
        after=masked(c); ainfo=active(c)
        if ainfo is None: continue
        r,cmin,w=ainfo
        if act in (1,2,3,4):
            # moved active block
            if ab: nbp=(r,cmin); nsp=sp; nab=True
            else: nsp=(r,cmin); nbp=bp; nab=False
        else: # USE
            if np.array_equal(np.frombuffer(before,dtype=np.uint8),np.frombuffer(after,dtype=np.uint8)):
                continue  # no-op USE, skip (waste)
            # effective USE: stamped active, toggled. new active is the other block.
            nab=not ab
            # active block that got stamped stays where it was (its pos unchanged in our record)
            # new active pos = ainfo; verify width matches other block
            if nab: # now big active
                nbp=(r,cmin); nsp=sp
                if w!=20: bad+=1
            else:
                nsp=(r,cmin); nbp=bp
                if w!=12: bad+=1
        ns=(c,nab,nbp,nsp)
        k=key(ns)
        if k in seen: continue
        seen.add(k); q.append((ns,path+[act]))
    if sol: break
print("SOL",sol,"steps",steps,"states",len(seen),"bad",bad,"time",round(time.time()-t,1))
import json; open("/tmp/logic_result.json","w").write(json.dumps(sol))
