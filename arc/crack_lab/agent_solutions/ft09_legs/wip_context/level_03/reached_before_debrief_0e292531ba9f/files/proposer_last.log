import sys; sys.path.insert(0,'/Users/sasha/gkm/arc/crack_lab'); sys.path.insert(0,'.')
import gkm_arena as A
import numpy as np, json, random
ck = json.load(open('checkpoint.json'))
env = A.Arena('ft09')
for act in ck['final_path']:
    env.step(act)
rowc={0:6,1:14,2:22,3:30,4:38,5:46,6:54}; colc={0:14,1:22,2:30,3:38,4:46}
Fblocks=[(0,1),(0,2),(0,3),(1,1),(1,3),(2,0),(2,1),(2,2),(2,3),(2,4),
(3,0),(3,2),(3,4),(4,0),(4,1),(4,2),(4,3),(4,4),(5,1),(5,3),(6,1),(6,2),(6,3)]
def fill(f): return int(np.sum(f[63]!=12))
def click(cl,i):
    b=Fblocks[i]; cl.step(6,colc[b[1]],rowc[b[0]])
def build(sel):
    c=env.clone()
    for i in sorted(sel): click(c,i)
    return c
def hillclimb(start):
    sel=set(start)
    cur=build(sel); curfill=fill(cur.frame())
    if cur.levels_completed>2: return sel,curfill,True
    for it in range(60):
        best=None
        for i in range(23):
            c=cur.clone(); click(c,i)
            fv=fill(c.frame()); win=c.levels_completed>2
            if win: return (sel^{i}), fv, True
            if best is None or fv>best[1]:
                best=(i,fv,c)
        if best[1]>curfill:
            i,fv,c=best
            if i in sel: sel.discard(i)
            else: sel.add(i)
            cur=c; curfill=fv
        else:
            break
    return sel,curfill,False
random.seed(0)
bestoverall=(None,-1)
for trial in range(6):
    if trial==0: start=set()
    elif trial==1: start=set(range(23))
    else: start=set(random.sample(range(23),random.randint(5,18)))
    sel,fv,win=hillclimb(start)
    print(f"trial{trial} start{len(start)} -> fill={fv} win={win} sel={sorted(sel)}")
    if win:
        print("WIN sel blocks:",[Fblocks[i] for i in sorted(sel)]); break
    if fv>bestoverall[1]: bestoverall=(sel,fv)
print("best fill",bestoverall[1],"set",sorted(bestoverall[0]) if bestoverall[0] else None)
