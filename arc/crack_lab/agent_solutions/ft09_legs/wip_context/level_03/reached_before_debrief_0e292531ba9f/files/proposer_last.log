import sys; sys.path.insert(0,'/Users/sasha/gkm/arc/crack_lab'); sys.path.insert(0,'.')
import gkm_arena as A
import numpy as np, json, itertools
ck = json.load(open('checkpoint.json'))
def base():
    env = A.Arena('ft09')
    for act in ck['final_path']:
        env.step(act)
    return env
# map grid (r,c)->click (x,y). row centers, col centers
rowc={0:6,1:14,2:22,3:30,4:38,5:46,6:54}
colc={0:14,1:22,2:30,3:38,4:46}
Fblocks=[(0,1),(0,2),(0,3),(1,1),(1,3),(2,0),(2,1),(2,2),(2,3),(2,4),
(3,0),(3,2),(3,4),(4,0),(4,1),(4,2),(4,3),(4,4),(5,1),(5,3),(6,1),(6,2),(6,3)]
def orbit(rc):
    r,c=rc
    return frozenset([(r,c),(6-r,c),(r,4-c),(6-r,4-c)])
orbits=[]
seen=set()
for b in Fblocks:
    o=orbit(b)
    # keep only members that are F blocks
    o=frozenset(m for m in o if m in Fblocks)
    if o not in seen:
        seen.add(o); orbits.append(sorted(o))
print("num orbits:", len(orbits))
for o in orbits: print(o)
env=base()
base_lvl=env.levels_completed
found=None
for mask in range(1<<len(orbits)):
    clicks=[]
    for i,o in enumerate(orbits):
        if mask&(1<<i):
            clicks+=o
    c=env.clone()
    for (r,cc) in clicks:
        c.step(6,colc[cc],rowc[r])
    if c.levels_completed>base_lvl:
        found=(mask,clicks); break
print("FOUND:", found)
EOF
