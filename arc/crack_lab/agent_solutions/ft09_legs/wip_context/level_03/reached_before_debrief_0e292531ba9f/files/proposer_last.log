$ cd /Users/sasha/gkm/arc/crack_lab/runs/scratch/gkm_legs_ws_ft09_opus && cat > /tmp/orient.py << 'EOF'
import sys; sys.path.insert(0,'/Users/sasha/gkm/arc/crack_lab'); sys.path.insert(0,'.')
import gkm_arena as A
import numpy as np, json, itertools
ck = json.load(open('checkpoint.json'))
env = A.Arena('ft09')
for act in ck['final_path']:
    env.step(act)
rowc={0:6,1:14,2:22,3:30,4:38,5:46,6:54}; colc={0:14,1:22,2:30,3:38,4:46}
Fset=set([(0,1),(0,2),(0,3),(1,1),(1,3),(2,0),(2,1),(2,2),(2,3),(2,4),
(3,0),(3,2),(3,4),(4,0),(4,1),(4,2),(4,3),(4,4),(5,1),(5,3),(6,1),(6,2),(6,3)])
pats={(1,2):[[0,0,0],[0,12,2],[2,0,2]],
      (3,1):[[2,0,2],[2,8,0],[0,0,2]],
      (3,3):[[2,0,0],[0,8,2],[2,0,2]],
      (5,2):[[2,0,2],[0,12,2],[0,0,0]]}
def orient(g,o):
    a=np.array(g)
    r=o%4; a=np.rot90(a,r)
    if o>=4: a=np.fliplr(a)
    return a.tolist()
def selmap(pr,pc,g):
    # returns dict block->bool(sel) for 2-cells and 0-cells (non center)
    d={}
    for i in range(3):
        for j in range(3):
            if i==1 and j==1: continue
            b=(pr-1+i,pc-1+j)
            if b in Fset:
                d[b]= (g[i][j]==2)
    return d
def test(sel):
    c=env.clone()
    for (r,cc) in sel: c.step(6,colc[cc],rowc[r])
    return c.levels_completed>2
plist=list(pats.items())
found_consistent=[]
for combo in itertools.product(range(8),repeat=4):
    maps=[selmap(pos[0],pos[1],orient(g,o)) for (pos,g),o in zip(plist,combo)]
    merged={}
    ok=True
    for m in maps:
        for b,v in m.items():
            if b in merged and merged[b]!=v: ok=False;break
            merged[b]=v
        if not ok: break
    if ok:
        sel=frozenset(b for b,v in merged.items() if v)
        found_consistent.append((combo,sel))
print("consistent orientation combos:",len(found_consistent))
seen=set(); wins=[]
for combo,sel in found_consistent:
    if sel in seen: continue
    seen.add(sel)
    if test(sel):
        print("WIN",combo,sorted(sel)); wins.append(sel)
print("distinct consistent sels:",len(seen),"wins:",len(wins))
# show a few
for s in list(seen)[:6]:
    print(sorted(s))
EOF
