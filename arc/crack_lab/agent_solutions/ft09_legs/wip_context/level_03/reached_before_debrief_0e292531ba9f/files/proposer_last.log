$ cd /Users/sasha/gkm/arc/crack_lab/runs/scratch/gkm_legs_ws_ft09_opus && cat > /tmp/proto.py << 'EOF'
import sys; sys.path.insert(0,'/Users/sasha/gkm/arc/crack_lab'); sys.path.insert(0,'.')
import gkm_arena as A
import numpy as np, json
from collections import Counter
ck = json.load(open('checkpoint.json'))
env = A.Arena('ft09')
for act in ck['final_path']:
    env.step(act)
f=np.asarray(env.frame())

def decode_clicks(f):
    H,W=f.shape
    core=f[:62]  # ignore bottom bar row(s)
    bg=Counter(core.ravel().tolist()).most_common(1)[0][0]
    # find uniform sxs blocks: try s=6
    s=6
    # candidate block color = most common non-bg color among solid blocks
    # scan grid slots: a slot (r,c) is start of block if region rxr non-bg dominantly
    # First find all rows/cols that begin a block: detect by column profile of non-bg
    nonbg=(core!=bg)
    # find block starts by looking for runs; use pitch detection via projecting
    # Simpler: find all top-left corners where a 6x6 area is fully non-bg (a block)
    starts=[]
    for r in range(0,62-s+1):
        for c in range(0,W-s+1):
            if nonbg[r:r+s,c:c+s].all():
                # ensure it's a top-left (cell above/left is bg or edge)
                if (r==0 or not nonbg[r-1,c]) and (c==0 or not nonbg[r,c-1]):
                    starts.append((r,c))
    rows=sorted(set(r for r,c in starts)); cols=sorted(set(c for r,c in starts))
    ri={r:i for i,r in enumerate(rows)}; cimap={c:i for i,c in enumerate(cols)}
    # block color = most common single-color among uniform blocks
    blockcolor=None; cnt=Counter()
    slots={}  # (i,j)->(r,c)
    for (r,c) in starts:
        blk=core[r:r+s,c:c+s]
        slots[(ri[r],cimap[c])]=(r,c)
        u=np.unique(blk)
        if len(u)==1: cnt[int(u[0])]+=1
    blockcolor=cnt.most_common(1)[0][0]
    # identify pattern blocks (non-uniform) and clickable (uniform==blockcolor or selected)
    clickable=set(); patterns={}
    for (ij),(r,c) in slots.items():
        blk=core[r:r+s,c:c+s]; u=np.unique(blk)
        if len(u)==1:
            clickable.add(ij)
        else:
            patterns[ij]=blk
    # red color = the non-zero-ish decoration color: cells are 0 and 2; find them
    # In pattern 3x3, non-center cells take two values; treat one as 'mark'.
    # Determine 'mark' color = the color that appears as a cell value and equals 2? 
    # Generalize: cell values are {v0, vmark}; center is blockcolor or selectedcolor.
    # We define selected = ((center==blockcolor) == (cell==markcolor))
    # markcolor = the decoration color that is NOT the background-of-pattern (0).
    # Collect all cell colors across patterns' non-center cells:
    def cell3(blk):
        return [[int(blk[2*i,2*j]) for j in range(3)] for i in range(3)]
    cellvals=Counter()
    for blk in patterns.values():
        g=cell3(blk)
        for i in range(3):
            for j in range(3):
                if (i,j)!=(1,1): cellvals[g[i][j]]+=1
    # two colors expected; mark = the less frequent? Here 0 freq> 2 freq. mark=2.
    # choose markcolor as the color that is not the pattern's most common cell color
    common_cell=cellvals.most_common()
    markcolor=common_cell[-1][0] if len(common_cell)>1 else common_cell[0][0]
    sel=set()
    for (pi,pj),blk in patterns.items():
        g=cell3(blk); center=g[1][1]
        for i in range(3):
            for j in range(3):
                if (i,j)==(1,1): continue
                nb=(pi+(i-1),pj+(j-1))
                if nb in clickable:
                    if ((center==blockcolor)==(g[i][j]==markcolor)):
                        sel.add(nb)
    # to clicks (x=col center, y=row center)
    clicks=[]
    for (i,j) in sorted(sel):
        r,c=slots[(i,j)]
        clicks.append([6, c+s//2-1, r+s//2-1])
    return clicks, sorted(sel), blockcolor, markcolor

clicks,sel,bc,mc=decode_clicks(f)
print("blockcolor",bc,"markcolor",mc)
print("selected",sel)
print("nclicks",len(clicks))
c=env.clone()
for a in clicks: c.step(*a)
print("win lvl",c.levels_completed)
