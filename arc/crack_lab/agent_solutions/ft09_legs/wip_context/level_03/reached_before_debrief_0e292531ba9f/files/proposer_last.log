import sys; sys.path.insert(0,'/Users/sasha/gkm/arc/crack_lab'); sys.path.insert(0,'.')
import gkm_arena as A
import numpy as np, json
ck = json.load(open('checkpoint.json'))
env = A.Arena('ft09')
for act in ck['final_path']:
    env.step(act)
rowc={0:6,1:14,2:22,3:30,4:38,5:46,6:54}
colc={0:14,1:22,2:30,3:38,4:46}
def test(blocks):
    c=env.clone()
    for (r,cc) in blocks:
        c.step(6,colc[cc],rowc[r])
    return c.levels_completed
# pattern 2-block sets (neighborhood)
P12=[(1,3),(2,1),(2,3)]
P31=[(2,0),(2,2),(3,0),(4,2)]
P33=[(2,2),(3,4),(4,2),(4,4)]
P52=[(4,1),(4,3),(5,3)]
from collections import Counter
cnt=Counter(P12+P31+P33+P52)
xor=[b for b,n in cnt.items() if n%2==1]
inter=[b for b,n in cnt.items() if n>=2]
union=list(cnt.keys())
cands={'xor':xor,'inter_ge2':inter,'union':union}
# 0-blocks neighborhood
def zeromap(pr,pc,grid):
    out=[]
    for i in range(3):
        for j in range(3):
            if grid[i][j]==0:
                out.append((pr-1+i,pc-1+j))
    return out
g12=[[0,0,0],[0,-1,2],[2,0,2]]
g31=[[2,0,2],[2,-1,0],[0,0,2]]
g33=[[2,0,0],[0,-1,2],[2,0,2]]
g52=[[2,0,2],[0,-1,2],[0,0,0]]
Fset=set([(0,1),(0,2),(0,3),(1,1),(1,3),(2,0),(2,1),(2,2),(2,3),(2,4),
(3,0),(3,2),(3,4),(4,0),(4,1),(4,2),(4,3),(4,4),(5,1),(5,3),(6,1),(6,2),(6,3)])
z=zeromap(1,2,g12)+zeromap(3,1,g31)+zeromap(3,3,g33)+zeromap(5,2,g52)
z=[b for b in z if b in Fset]
cands['zero_union']=list(set(z))
for name,blocks in cands.items():
    blocks=[b for b in blocks if b in Fset]
    print(name, len(blocks), "->lvl", test(blocks))
