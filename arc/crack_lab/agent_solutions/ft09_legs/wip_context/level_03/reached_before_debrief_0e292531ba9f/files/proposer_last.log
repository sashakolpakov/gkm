import sys; sys.path.insert(0,'/Users/sasha/gkm/arc/crack_lab'); sys.path.insert(0,'.')
import gkm_arena as A
import numpy as np, json
ck = json.load(open('checkpoint.json'))
env = A.Arena('ft09')
for act in ck['final_path']:
    env.step(act)
rowc={0:6,1:14,2:22,3:30,4:38,5:46,6:54}; colc={0:14,1:22,2:30,3:38,4:46}
Fset=set([(0,1),(0,2),(0,3),(1,1),(1,3),(2,0),(2,1),(2,2),(2,3),(2,4),
(3,0),(3,2),(3,4),(4,0),(4,1),(4,2),(4,3),(4,4),(5,1),(5,3),(6,1),(6,2),(6,3)])
pats={(1,2):[[0,0,0],[0,12,2],[2,0,2]],
      (3,1):[[2,0,2],[2,8,0],[0,0,2]],
      (3,3):[[2,0,0],[0,8,2],[2,0,2]],
      (5,2):[[2,0,2],[0,12,2],[0,0,0]]}
def test(sel):
    sel=[b for b in sel if b in Fset]
    c=env.clone()
    for (r,cc) in sel: c.step(6,colc[cc],rowc[r])
    return c.levels_completed>2, len(sel)
# build coverage: block-> list of (pattern_pos, value)
cover={}
for (pr,pc),g in pats.items():
    for i in range(3):
        for j in range(3):
            if i==1 and j==1: continue
            b=(pr-1+i,pc-1+j)
            if b in Fset:
                cover.setdefault(b,[]).append(((pr,pc),g[i][j]))
def dist(b,p): return (b[0]-p[0])**2+(b[1]-p[1])**2
strategies={}
# nearest pattern, 2=select
def nearest(b):
    return min(cover[b],key=lambda pv: dist(b,pv[0]))
strategies['near_2sel']=[b for b in cover if nearest(b)[1]==2]
strategies['near_0sel']=[b for b in cover if nearest(b)[1]==0]
# farthest
def farthest(b):
    return max(cover[b],key=lambda pv: dist(b,pv[0]))
strategies['far_2sel']=[b for b in cover if farthest(b)[1]==2]
# majority 2
strategies['maj_2sel']=[b for b in cover if sum(1 for _,v in cover[b] if v==2)*2>len(cover[b])]
strategies['maj_2sel_ge']=[b for b in cover if sum(1 for _,v in cover[b] if v==2)*2>=len(cover[b])]
# all covering ==2
strategies['all2']=[b for b in cover if all(v==2 for _,v in cover[b])]
# any 0
strategies['any0']=[b for b in cover if any(v==0 for _,v in cover[b])]
for name,sel in list(strategies.items()):
    w,n=test(sel)
    print(name,n,"win",w)
    cw,cn=test([b for b in Fset if b not in set(sel)])
    print("  complement",cn,"win",cw)
