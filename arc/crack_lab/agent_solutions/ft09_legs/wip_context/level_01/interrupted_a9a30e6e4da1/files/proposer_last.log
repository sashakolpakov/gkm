import sys
sys.path.insert(0, '/Users/sasha/gkm/arc/crack_lab')
from gkm_arena import Arena
import numpy as np

env = Arena('ft09')
frame0 = np.array(env.frame())

# Check what actions actually DO in terms of the full frame
# (not just timer bar)
print('Checking all action impacts on full frame (excluding row 63):')
for a in range(1, 7):
    c = env.clone()
    c.step(a)
    f = np.array(c.frame())
    # Exclude bottom row
    f_body = f[:63]
    f0_body = frame0[:63]
    diff = np.where(f0_body != f_body)
    n_diff = len(diff[0])
    print(f'Action {a}: {n_diff} pixels changed in body')

print()
# Let's try many steps and check for level changes
print('Trying to find what causes level change...')
# BFS with bounded depth
from collections import deque

def key(env):
    return np.array(env.frame()[:63]).tobytes()

env_start = Arena('ft09')
q = deque([(env_start.clone(), [])])
seen = {key(env_start)}
found = None
while q:
    node, path = q.popleft()
    if node.levels_completed > 0:
        found = path
        print(f'Found level completion at depth {len(path)}: {path}')
        break
    if len(path) >= 8:
        continue
    for a in range(1, 7):
        child = node.clone()
        child.step(a)
        k = key(child)
        if k not in seen:
            seen.add(k)
            q.append((child, path + [a]))

if found is None:
    print('No level completion found within depth 8')
    print(f'States explored: {len(seen)}')
"

