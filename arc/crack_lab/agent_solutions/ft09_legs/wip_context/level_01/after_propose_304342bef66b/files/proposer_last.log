import sys; sys.path.insert(0,'/Users/sasha/gkm/arc/crack_lab')
import gkm_arena as A, numpy as np
env = A.Arena('ft09')
base=env.frame().copy()
# cluster clickable tiles by changed-region bbox (rows<62)
from collections import defaultdict
tiles={}
for y in range(0,64,2):
  for x in range(0,64,2):
    c=env.clone(); c.step(6,x,y)
    d=np.argwhere(base!=c.frame())
    d=[(r,cc) for r,cc in d if r<62]
    if not d: continue
    rs=[p[0] for p in d]; cs=[p[1] for p in d]
    key=(min(rs),min(cs),max(rs),max(cs))
    tiles.setdefault(key,(x,y))
print('num tiles',len(tiles))
for k in sorted(tiles): print(k,tiles[k])
