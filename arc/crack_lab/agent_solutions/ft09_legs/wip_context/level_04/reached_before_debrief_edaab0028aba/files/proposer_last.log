import sys, json
sys.path.insert(0,"/Users/sasha/gkm/arc/crack_lab"); sys.path.insert(0,".")
import gkm_arena as A
import numpy as np
from collections import Counter
from legs import _grid_of_blocks

def discover_three_state_key_clicks(env):
    g=_grid_of_blocks(env.frame())
    if not g: return None
    s,bg,slots,uniform,patterns=g
    if not patterns or not uniform: return None
    f=np.asarray(env.frame())
    idx0=next(iter(uniform)); r,c=slots[idx0]; cx,cy=c+s//2-1,r+s//2-1
    cl=env.clone(); cycle=[int(cl.frame()[r+s//2,c+s//2])]
    for _ in range(6):
        cl.step(6,cx,cy); col=int(cl.frame()[r+s//2,c+s//2])
        if col==cycle[0]: break
        cycle.append(col)
    ncy=len(cycle); pos={col:i for i,col in enumerate(cycle)}
    def cell3(blk):
        n=blk.shape[0]; off=[i*n//3+n//6 for i in range(3)]
        return [[int(blk[off[i],off[j]]) for j in range(3)] for i in range(3)]
    cellvals=Counter()
    for blk in patterns.values():
        gg=cell3(blk)
        for i in range(3):
            for j in range(3):
                if (i,j)!=(1,1): cellvals[gg[i][j]]+=1
    mark=cellvals.most_common()[-1][0]
    target={}
    for pidx,blk in patterns.items():
        gg=cell3(blk); cc=gg[1][1]
        for i in range(3):
            for j in range(3):
                if (i,j)==(1,1): continue
                if gg[i][j]==mark:
                    nb=(pidx[0]+i-1,pidx[1]+j-1)
                    if nb in uniform: target[nb]=cc
    def centerof(idx):
        r,c=slots[idx]; return (c+s//2-1,r+s//2-1)
    def build(default):
        clicks=[]
        for idx in sorted(uniform):
            r,c=slots[idx]; cur=int(f[r+s//2,c+s//2])
            tgt=target.get(idx,default)
            n=(pos[tgt]-pos[cur])%ncy
            clicks+=[centerof(idx)]*n
        return clicks
    base=env.levels_completed
    for default in cycle:
        clicks=build(default)
        cl=env.clone()
        for (x,y) in clicks: cl.step(6,x,y)
        if cl.levels_completed>base:
            return clicks
    return None

env=A.Arena('ft09')
ck=json.load(open('checkpoint.json'))
for act in ck['final_path']: env.step(act)
base=env.levels_completed
clicks=discover_three_state_key_clicks(env)
print("num clicks", None if clicks is None else len(clicks))
cl=env.clone()
for (x,y) in clicks: cl.step(6,x,y)
print("levels", cl.levels_completed, "base", base)
EOF
