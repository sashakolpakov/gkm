from probe import env_at_level5, step_count_used
import numpy as np
from collections import deque
UP,DOWN,LEFT,RIGHT,USE=1,2,3,4,5
DIRS={UP:(-1,0),DOWN:(1,0),LEFT:(0,-1),RIGHT:(0,1)}

def cells(c):
    """Return (avatar_cell, facing, grabbed_bool, obstacle_set, boxes_set, courier_cell)."""
    f=np.asarray(c.frame())
    G=16
    # coarse cell color majority (ignore avatar/box internal)
    av=None; head=None
    ys,xs=np.where(f==14)
    if len(ys): av=(int(ys.min())//4,int(xs.min())//4)
    hy,hx=np.where(f==0)
    if len(hy): head=(int(hy.min())//4,int(hx.min())//4)
    boxes=set()
    # boxes: 4-border 4x4. detect by scanning cell blocks whose border is 4 or 3 or 0(grabbed)
    for R in range(G):
        for C in range(G):
            blk=f[R*4:R*4+4,C*4:C*4+4]
            u=set(int(v) for v in np.unique(blk))
            if 9 in u and (4 in u or 3 in u) and len(u)<=3:
                boxes.add((R,C))
    cour=None
    cy,cx=np.where(f==12)
    if len(cy):
        cour=(int(cy.min())//4,int(cx.min())//4)
    # walls: any cell that is majority 5
    walls=set()
    for R in range(G):
        for C in range(G):
            blk=f[R*4:R*4+4,C*4:C*4+4]
            if int((blk==5).sum())>=8:
                walls.add((R,C))
    return av,head,boxes,cour,walls

def avatar_facing(av,head):
    if av is None or head is None: return None
    dr=head[0]-av[0]; dc=head[1]-av[1]
    for a,(r,c) in DIRS.items():
        if (dr,dc)==(r,c): return a
    # head is within same cell region; determine by pixel offset
    return None
