def ferry_one(c, box, drop=(7,10), log=None):
    br,bc=box
    # navigate to two below box then up to grab
    if not move_avatar_to(c,(br+2,bc),log):
        # try one below directly
        move_avatar_to(c,(br+1,bc),log)
    cur=avatar_cell(c)
    if cur is None: return False
    # step up to be adjacent below box (face up)
    if int(cur[0])>br+1:
        c.step(UP);  log and log.append(UP)
    # now at (br+1,bc) facing up, box above
    c.step(USE); log and log.append(USE)  # grab
    # box now attached above avatar. translate avatar to (drop_r+1, drop_c)
    tr,tc=drop  # box target; avatar goes to (tr+1,tc)
    move_avatar_to(c,(tr+1,tc),log)
    c.step(USE); log and log.append(USE)  # release
    return True
EOF
