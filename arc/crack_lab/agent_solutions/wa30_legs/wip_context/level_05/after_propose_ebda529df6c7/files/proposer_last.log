UP,DOWN,LEFT,RIGHT,USE=1,2,3,4,5

def step_count_used(c):
    f=np.asarray(c.frame())
    return 64-int((f[63]==7).sum())

def move_avatar_to(c, target, log=None):
    # greedy move empty avatar to target cell within right region (cols>=10)
    for _ in range(40):
        cur=avatar_cell(c)
        if cur is None: return False
        r,cc=int(cur[0]),int(cur[1])
        tr,tc=target
        if (r,cc)==(tr,tc): return True
        # move col first toward tc but keep cc>=10
        if cc<tc: a=RIGHT
        elif cc>tc: a=LEFT
        elif r<tr: a=DOWN
        elif r>tr: a=UP
        else: return True
        c.step(a)
        if log is not None: log.append(a)
    return avatar_cell(c)==tuple(target)
EOF
