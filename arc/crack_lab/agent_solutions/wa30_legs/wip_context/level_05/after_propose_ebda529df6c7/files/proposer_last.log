$ cd /private/tmp/claude-501/-Users-sasha-gkm/e3e00be1-d1a5-4095-a6ef-4d720f42d84e/scratchpad/gkm_legs_ws_wa30_opus_scaffold_clean && cat >> ctrl.py <<'EOF'

def adj(cell):
    r,c=cell
    return {UP:(r-1,c),DOWN:(r+1,c),LEFT:(r,c-1),RIGHT:(r,c+1)}

def bfs_pair(start_av, offset, goal_av, blocked, G=16):
    """BFS moving avatar; box=avatar+offset; both must stay in-bounds & unblocked."""
    def ok(a):
        b=(a[0]+offset[0],a[1]+offset[1])
        if not(0<=a[0]<G and 0<=a[1]<G and 0<=b[0]<G and 0<=b[1]<G): return False
        if a in blocked or b in blocked: return False
        return True
    if start_av==goal_av: return []
    q=deque([start_av]); prev={start_av:None}
    while q:
        cur=q.popleft()
        for act,(dr,dc) in DIRS.items():
            nb=(cur[0]+dr,cur[1]+dc)
            if nb in prev: continue
            if nb!=goal_av and not ok(nb): continue
            # also goal must be ok
            if nb==goal_av and not ok(nb): continue
            prev[nb]=(cur,act)
            if nb==goal_av:
                path=[]; n=nb
                while prev[n] is not None:
                    p,ac=prev[n]; path.append(ac); n=p
                return path[::-1]
            q.append(nb)
    return None

def carry_pair(c, offset, goal_av, log=None, cap=60):
    for _ in range(cap):
        if c.terminal(): return False
        av,head,boxes,cour,walls=cells(c)
        if av==goal_av: return True
        blocked=set(walls)
        # other boxes block, but our carried box is at av+offset (exclude)
        carried=(av[0]+offset[0],av[1]+offset[1])
        for b in boxes:
            if b!=carried: blocked.add(b)
        if cour: blocked.add(cour)
        blocked.discard(goal_av)
        blocked.discard(av)
        path=bfs_pair(av,offset,goal_av,blocked)
        if not path:
            # maybe courier blocking; wait by stepping in place-safe? try USE would release. skip -> fail
            return False
        a=path[0]; before=av
        c.step(a); (log is not None) and log.append(a)
        if cells(c)[0]==before:
            # blocked by moving courier; try again (courier will move)
            continue
    return cells(c)[0]==goal_av

def ferry(c, box, drop=(7,10), log=None):
    av,head,boxes,cour,walls=cells(c)
    if box not in boxes: return False
    # pick approach side: reachable open adjacent cell
    blocked=set(walls)|(set(boxes)-{box})
    if cour: blocked.add(cour)
    best=None
    for act,ac in adj(box).items():
        if not(0<=ac[0]<16 and 0<=ac[1]<16): continue
        if ac in blocked: continue
        p=bfs_path(av,ac,blocked)
        if p is not None and (best is None or len(p)<best[0]):
            best=(len(p),ac,act)
    if best is None: return False
    _,ac,act=best
    if not nav_to(c,ac,log=log): return False
    # face box: step toward box (opposite of approach dir from box). dir from ac to box:
    dr=box[0]-ac[0]; dc=box[1]-ac[1]
    face={(-1,0):UP,(1,0):DOWN,(0,-1):LEFT,(0,1):RIGHT}[(dr,dc)]
    c.step(face); (log is not None) and log.append(face)  # blocked, sets facing, highlight
    c.step(USE); (log is not None) and log.append(USE)     # grab
    # offset box relative to avatar after grab
    av2,_,_,_,_=cells(c)
    offset=(box[0]-av2[0],box[1]-av2[1])
    goal_av=(drop[0]-offset[0],drop[1]-offset[1])
    if not carry_pair(c,offset,goal_av,log=log): 
        c.step(USE); (log is not None) and log.append(USE)  # release wherever
        return False
    c.step(USE); (log is not None) and log.append(USE)  # release at drop
    return True
