def right_boxes(c):
    av,head,boxes,cour,walls=cells(c)
    return [b for b in boxes if b[1]>=11 and b[0]<15]  # in right region proper (col>=11)

def orchestrate(c, drops=((7,10),(8,10)), verbose=False):
    while not c.terminal() and c.levels_completed<=4:
        av,head,boxes,cour,walls=cells(c)
        rb=[b for b in boxes if b[1]>=11 and b[0]<15]
        at_drop=[d for d in drops if d in boxes]
        if not rb and not at_drop:
            break  # all delivered/seating
        # find an empty drop
        empty=[d for d in drops if d not in boxes and (cour is None or cour!=d)]
        if rb and empty:
            # ferry nearest box to nearest empty drop
            av0=av
            rb.sort(key=lambda b:abs(b[0]-av0[0])+abs(b[1]-av0[1]))
            box=rb[0]
            # choose drop closest to box
            empty.sort(key=lambda d:abs(d[0]-box[0])+abs(d[1]-box[1]))
            ok=ferry(c,box,drop=empty[0])
            if verbose: print('ferried',box,'->',empty[0],'ok',ok,'budget',step_count_used(c))
            if not ok:
                # give courier time
                for _ in range(3):
                    if c.terminal(): break
                    c.step(DOWN)
        else:
            # yield to let courier clear a drop; move avatar harmlessly away from drops
            safe_yield(c,cap=1)
    # final seating yield
    for a in [RIGHT,RIGHT,DOWN,DOWN]:
        if not c.terminal(): c.step(a)
    for i in range(120):
        if c.terminal() or c.levels_completed>4: break
        c.step(UP if i%2 else DOWN)
