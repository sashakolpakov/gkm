def safe_yield(c, cap=200):
    """Yield turns without grabbing: move avatar in an empty area, bouncing."""
    # move avatar to a parking cell away from boxes/corridor
    for i in range(cap):
        if c.terminal() or c.levels_completed>4: return
        av,head,boxes,cour,walls=cells(c)
        # pick a harmless move: one that doesn't face a box adjacent (avoid grab on subsequent USE-not used) 
        # we only move, never USE, so grabbing won't happen. But bumping a box highlights (harmless) and could accidentally... 
        # Actually moving INTO a box just highlights; fine. But we must not leave avatar attached. Moving never attaches.
        # choose a direction that changes position (prefer away from any box)
        best=None
        for a,(dr,dc) in DIRS.items():
            nb=(av[0]+dr,av[1]+dc)
            if not(0<=nb[0]<16 and 0<=nb[1]<16): continue
            if nb in walls or nb in boxes: continue
            if cour and nb==cour: continue
            # distance from nearest box
            d=min([abs(nb[0]-b[0])+abs(nb[1]-b[1]) for b in boxes], default=99)
            if best is None or d>best[0]: best=(d,a)
        if best is None:
            c.step(UP)
        else:
            c.step(best[1])
