import numpy as np

def avatar_cell(c):
    f=np.asarray(c.frame())
    ys,xs=np.where(f==14)
    if len(ys)==0: return None
    # include head (0) nearest? just use 14 body center rounded
    r=(ys.min()+ys.max())//2; cc=(xs.min()+xs.max())//2
    return (ys.min()//4, xs.min()//4)  # top-left cell

def boxes_cells(c):
    f=np.asarray(c.frame())
    # boxes are 4-border components with 9 core, size 4x4, located right region
    out=[]
    import perception as P
    for o in P.object_candidates(f, min_area=8):
        if o['color']==4 and o['area']==12:
            r0,c0,r1,c1=o['bbox']
            out.append((r0//4,c0//4))
    return out
