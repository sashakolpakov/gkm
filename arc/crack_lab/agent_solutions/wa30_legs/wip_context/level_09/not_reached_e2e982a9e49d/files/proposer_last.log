SOCK=set(LEFT+RIGHT)
def cellset(env):
    f=np.asarray(env.frame()); box=set(); empty=set()
    for R in range(16):
        for C in range(16):
            blk=f[R*4:R*4+4,C*4:C*4+4]; u=set(int(v) for v in np.unique(blk))
            if 9 in u and 2 in u and 4 not in u: empty.add((R,C))
            elif 9 in u and 4 in u and 2 not in u: box.add((R,C))
