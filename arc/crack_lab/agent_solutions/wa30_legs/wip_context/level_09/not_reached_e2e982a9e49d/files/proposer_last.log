$ cd /private/tmp/claude-501/-Users-sasha-gkm/e3e00be1-d1a5-4095-a6ef-4d720f42d84e/scratchpad/gkm_legs_ws_wa30_opus_l9_resume_budget && cat >> legs.py << 'PYEOF'


def _container_state(env, cells, G=16):
    """(open_cells, loose_boxes) for a single goal container.

    A container cell is *open* while its 4x4 block still shows the empty-core
    colour 2; a *loose box* is any 4x4 block with a 9 core wrapped in colour 4
    (or the in-transit colour 3) that is NOT one of ``cells``.
    """
    f = np.asarray(env.frame())
    cellset = set(cells)
    opens, boxes = [], []
    for R in range(G):
        for C in range(G):
            blk = f[R * 4:R * 4 + 4, C * 4:C * 4 + 4]
            u = set(int(v) for v in np.unique(blk))
            if (R, C) in cellset:
                if 2 in u:
                    opens.append((R, C))
            elif 9 in u and (4 in u or 3 in u) and 2 not in u:
                boxes.append((R, C))
    return opens, boxes


def fill_goal_container(env, cells, guard_c7=2, cap=80, mover=None):
    """Fill a single goal container's ``cells`` with the arena's loose boxes.

    The recurring wa30 end-game shape: a helper courier auto-seats boxes into
    the same container while the avatar rigid-carries the boxes the courier is
    slow to reach.  Each round the avatar delivers the loose box nearest an
    open cell (shortest avatar+carry Manhattan), trying the next candidate on a
    failed/unroutable carry and ceding a turn to the courier only when nothing
    is deliverable.  If ``mover`` (a self-mover colour) is given, a stationary
    adjacent one is USE-cleared for free (neutralise-then-fill).  Bounded by the
    colour-7 step bar (``guard_c7``) and terminal; returns filled-cell count.
    """
    base = env.levels_completed
    prev_m = None
    for _ in range(cap):
        if env.terminal() or env.levels_completed > base:
            break
        if _color_count(env, 7) <= guard_c7:
            break
        # opportunistic free neutralise of a parked adjacent intruder
        if mover is not None:
            ms = _movers(env, mover)
            m = ms[0] if ms else None
            if m is not None and m == prev_m:
                av = _grid_scan(env)[0]
                if abs(av[0] - m[0]) + abs(av[1] - m[1]) == 1:
                    env.step(_DIRS_INV[(m[0] - av[0], m[1] - av[1])])
                    env.step(USE)
            prev_m = _movers(env, mover)[0] if _movers(env, mover) else None
        opens, boxes = _container_state(env, cells)
        if not opens:
            break
        if not boxes:
            env.step(USE)
            continue
        av = _grid_scan(env)[0]
        cands = sorted(
            (abs(av[0] - b[0]) + abs(av[1] - b[1])
             + abs(b[0] - s[0]) + abs(b[1] - s[1]), b, s)
            for s in opens for b in boxes)
        did = False
        for _, b, s in cands:
            if env.terminal():
                break
            try:
                if carry_box_to(env, b, s):
                    did = True
                    break
            except Exception:
                break
        if not did:
            env.step(USE)
    opens, _ = _container_state(env, cells)
    return len(cells) - len(opens)


_DIRS_INV = {(-1, 0): UP, (1, 0): DOWN, (0, -1): LEFT, (0, 1): RIGHT}


def _color_count(env, color):
    return int((np.asarray(env.frame()) == color).sum())
