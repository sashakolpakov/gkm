import numpy as np
from l9lib import fresh, _baselen
import legs
from legs import deliver_pairs, yield_until_level_up, _avatar_nav, _mover_cell, _DIRS, USE, DOWN

def ambush_mover(env, cell, face_action, mover=15, idle_action=USE, cap=45):
    if not _avatar_nav(env, cell, cap=cap):
        return False
    dr, dc = _DIRS[face_action]
    tgt = (cell[0] + dr, cell[1] + dc)
    for _ in range(cap):
        if env.terminal():
            return False
        mc = _mover_cell(env, mover)
        if mc is None:
            return True
        if mc == tgt:
            env.step(face_action)
            env.step(USE)
            if _mover_cell(env, mover) is None:
                return True
        else:
            env.step(idle_action)
    return _mover_cell(env, mover) is None

def play(env):
    deliver_pairs(env, [((8,14),(6,14)), ((7,12),(6,13)), ((5,11),(3,11))])
    print('after right phase: steps', len(env.path)-_baselen, 'lv', env.levels_completed)
    ok = ambush_mover(env, (9,3), DOWN)
    print('ambush ok', ok, 'steps', len(env.path)-_baselen)
    deliver_pairs(env, [((8,1),(5,7))])
    print('after left carry: steps', len(env.path)-_baselen)
    yield_until_level_up(env, USE)
    print('final steps', len(env.path)-_baselen, 'lv', env.levels_completed, 'terminal', env.terminal())

e = fresh()
play(e)
EOF
