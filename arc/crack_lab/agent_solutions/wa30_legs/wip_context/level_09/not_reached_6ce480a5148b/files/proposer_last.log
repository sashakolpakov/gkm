def play_level_9(env):
    # Split-world socket level: a wall splits the arena; each half has a
    # courier (colour 12) seating boxes onto its sockets, and a colour-15
    # mover laps the bottom maze, exiting at (9,3) to steal seated boxes.
    # Seat the two avatar-reachable right sockets, hand the third right box
    # to the right courier on its shelf row, ambush the mover at its exit,
    # help the left courier with the farthest box, then yield.
    deliver_pairs(env, [((8, 14), (6, 14)),   # seat right socket
                        ((7, 12), (6, 13)),   # seat right socket
                        ((5, 11), (3, 11))])  # handoff to right courier
    ambush_mover(env, (9, 3), DOWN)           # clear the stealer at its exit
    deliver_pairs(env, [((8, 1), (5, 7))])    # help the left courier
    yield_until_level_up(env, USE)            # courier seats the last box
