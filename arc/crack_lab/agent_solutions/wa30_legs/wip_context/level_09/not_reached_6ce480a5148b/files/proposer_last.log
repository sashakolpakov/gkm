# --- Track-exit ambush for a patrolling self-mover (wa30 L9) -----------------
# Some self-movers circulate a fixed one-wide track (a maze lap) and only
# threaten the goal once they exit it.  Chasing them on the track is hopeless
# (same speed), but the exit cell is a chokepoint: an avatar parked ON the
# exit blocks the lap, so the mover queues in the adjacent track cell where a
# facing USE removes it for good.

def ambush_mover(env, cell, face_action, mover=15, idle_action=USE, cap=45):
    """Park on the track-exit ``cell`` and USE the self-mover when it queues.

    Navigates to ``cell``, idles (harmless ``idle_action``) until the mover
    occupies the cell in the ``face_action`` direction (it stalls there while
    we block its exit), then turns to face it and clears it with USE.
    Returns True once the mover colour is gone."""
    if not _avatar_nav(env, cell, cap=cap):
        return False
    dr, dc = _DIRS[face_action]
    tgt = (cell[0] + dr, cell[1] + dc)
    for _ in range(cap):
        if env.terminal():
            return False
        mc = _mover_cell(env, mover)
        if mc is None:
            return True
        if mc == tgt:
            env.step(face_action)
            env.step(USE)
            if _mover_cell(env, mover) is None:
                return True
        else:
            env.step(idle_action)
    return _mover_cell(env, mover) is None
EOF
