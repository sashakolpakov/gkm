        elif keys=={9} and 2 not in u: s=' 9emp'
        elif 9 in keys and 2 in keys: s=' 9f2 '  # socket filled with 2
        else: s=str(sorted(keys))
        row.append(s)
    print(f'{R:2d} '+''.join(row))
