def cl(blk):
    u=set(int(v) for v in np.unique(blk)); u.discard(1)
    if not u: return '..'
    if u=={5}: return '##'
    if u=={7}: return '=='
    if u<= {4,5,7}: return '4~'
    if u=={14} or u=={0,14}: return 'AV'
    if u=={12}: return 'CC'
    if u=={5,9} or u=={5,4,9}: return 'Cb'
    if u=={15}: return 'MM'
    if u=={9,15}: return 'Mb'
    if u=={2}: return '22'
    if u=={4,9}: return '4b'
    if 9 in u and 2 in u: return 's2'
    if 9 in u and (0 in u or 3 in u): return 'bx'
    return '?'+''.join(map(str,sorted(u)))
