import numpy as np, sys
from l9lib import fresh, ck
import legs as L
from legs import UP,DOWN,LEFT,RIGHT,USE

def pin_maze_mover(env, seal_cell, mover=15, cap=60):
    # Phase 1: walk to seal cell (mover treated as obstacle)
    def read(e):
        av, boxes, walls = L._grid_scan(e)
        blk = set(walls)|set(boxes)
        m = L._mover_cell(e, mover)
        if m: blk.add(m)
        return av, blk
    if not L._walk_avatar_to(env, seal_cell, read, cap):
        L.chase_and_clear(env, mover, lambda m: True)
        return L._mover_cell(env, mover) is None
    # Phase 2: mover frozen (its exit is sealed); walk down the corridor to it and USE
    for _ in range(cap):
        if env.terminal(): return False
        m = L._mover_cell(env, mover)
        if m is None: return True
        av, boxes, walls = L._grid_scan(env)
        d = abs(av[0]-m[0])+abs(av[1]-m[1])
        if d == 1:
            # bump to face, then USE
            if m[0]>av[0]: env.step(DOWN)
            elif m[0]<av[0]: env.step(UP)
            elif m[1]>av[1]: env.step(RIGHT)
            else: env.step(LEFT)
            env.step(USE)
            continue
        p = L._bfs_path(av, m, set(walls)|set(boxes))
        if not p: return False
        env.step(p[0])
    return L._mover_cell(env, mover) is None

e=fresh(); base=len(ck['final_path'])
L.deliver_pairs(e, [((8,14),(6,14)), ((7,12),(6,13)), ((5,11),(3,11))])
print('ABC done t=', len(e.path)-base)
ok=pin_maze_mover(e,(9,3))
print('pin', ok, 't=', len(e.path)-base)
L.deliver_pairs(e, [((8,1),(5,6)), ((7,1),(4,6))])
print('E done t=', len(e.path)-base, 'lvl', e.levels_completed)
L.yield_until_level_up(e, USE, cap=40)
print('end t=', len(e.path)-base, 'lvl', e.levels_completed, 'terminal', e.terminal())
