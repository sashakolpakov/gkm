# --- Chokepoint mover: seal its only exit, then corner it (wa30 L9) ---------
# A self-mover that path-plans to its target FREEZES the moment no route
# exists.  When the mover's region drains through a single chokepoint cell,
# occupying that cell freezes it wherever it stands -- and walking INTO the
# one-cell-wide corridor keeps the route sealed, so the frozen mover can be
# approached at leisure and removed with a facing USE (the standard clear
# mechanic).  This is timing-robust: no chase, no stall-waiting.

def pin_maze_mover(env, seal_cell, mover=15, cap=60):
    """Seal ``seal_cell`` (the mover's only exit), walk down the corridor to
    the now-frozen mover, and USE it away.

    Falls back to :func:`chase_and_clear` if the mover escapes into the open
    before the seal lands.  Returns True once the mover colour is gone.
    """
    def read(e):
        av, boxes, walls = _grid_scan(e)
        blk = set(walls) | set(boxes)
        m = _mover_cell(e, mover)
        if m:
            blk.add(m)
        return av, blk

    if L_mover_gone(env, mover):
        return True
    if not _walk_avatar_to(env, seal_cell, read, cap):
        chase_and_clear(env, mover, lambda m: True)
        return _mover_cell(env, mover) is None
    for _ in range(cap):
        if env.terminal():
            return False
        m = _mover_cell(env, mover)
        if m is None:
            return True
        av, boxes, walls = _grid_scan(env)
        if abs(av[0] - m[0]) + abs(av[1] - m[1]) == 1:
            # bump toward the mover to face it, then USE clears it
            if m[0] > av[0]:
                env.step(DOWN)
            elif m[0] < av[0]:
                env.step(UP)
            elif m[1] > av[1]:
                env.step(RIGHT)
            else:
                env.step(LEFT)
            env.step(USE)
            continue
        p = _bfs_path(av, m, set(walls) | set(boxes))
        if not p:
            return False
        env.step(p[0])
    return _mover_cell(env, mover) is None


def L_mover_gone(env, mover):
    return _mover_cell(env, mover) is None
EOF
