def play_level_9(env):
    # Two socket clusters (left 8-ring, right quad) with two couriers doing
    # most of the seating, a maze-bound stealer (colour 15), and a tight
    # colour-7 step budget (~70).  Hand the couriers the three east boxes,
    # ambush the stealer where it surfaces at the maze mouth, seat one more
    # west box, then yield so the couriers finish inside the budget.
    deliver_pairs(env, [((8, 14), (6, 14)),
                        ((7, 12), (6, 13)),
                        ((5, 11), (3, 11))])
    ambush_and_clear(env, (9, 3), DOWN)
    deliver_pairs(env, [((8, 1), (5, 7))])
    yield_until_level_up(env, UP)
