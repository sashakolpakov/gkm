import l9lib, numpy as np
e=l9lib.fresh()
f=np.asarray(e.frame())
# 16x16 grid of 4x4 tiles; print majority color per tile
g=np.zeros((16,16),dtype=int)
for r in range(16):
    for c in range(16):
        t=f[4*r:4*r+4,4*c:4*c+4]
        vals,cnts=np.unique(t,return_counts=True)
        g[r,c]=vals[np.argmax(cnts)]
for r in range(16):
    print(' '.join('%2d'%v for v in g[r]))
