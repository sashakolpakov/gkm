import l9lib, numpy as np
def cells(f,color,th=8):
    out=[]
    for r in range(16):
        for c in range(16):
            t=f[4*r:4*r+4,4*c:4*c+4]
            if (t==color).sum()>=th: out.append((r,c))
    return out
e=l9lib.fresh()
prev2=None
for i in range(120):
    f=np.asarray(e.frame())
    n2=(f==2).sum()
    if i%10==0 or (prev2 is not None and n2!=prev2):
        print(i,'c2=',n2,'boxes',len(cells(f,9,4)),'cour',cells(f,12),'steal',cells(f,15))
    prev2=n2
    e.step(5)
print('levels',e.levels_completed)
