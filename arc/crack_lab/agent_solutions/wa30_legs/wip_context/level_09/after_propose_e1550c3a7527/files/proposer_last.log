import legs as L
def cofill(e, seats, cap=200):
    base=e.levels_completed
    stall=0
    while not e.terminal() and e.levels_completed==base and stall<60:
        av,boxes,walls=L._grid_scan(e)
        empty=[s for s in seats if s not in boxes]
        free=[b for b in boxes if b not in seats]
