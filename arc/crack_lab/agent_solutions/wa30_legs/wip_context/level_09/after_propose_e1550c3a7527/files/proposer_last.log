import l5try2 as T
import legs as L
from l5lib import fresh
def run_fixed(assign):
    e=fresh()
    base=e.levels_completed
    log=[]
    for b,d in assign:
        for _ in range(6):
            av,head,boxes,cour,walls=L._cells(e)
            if b in boxes: break
            e.step(1)
        ok=T.seat_any(e,b,d,base)
