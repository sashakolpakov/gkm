from l5lib import fresh
import legs as L
FACES={(-1,0):1,(1,0):2,(0,-1):3,(0,1):4}
def seat(e, box, drop):
    av,head,boxes,cour,walls=L._cells(e)
    if box not in boxes: return False
    blocked=set(walls)|(set(boxes)-{box})
    best=None
    for (dr,dc),face in FACES.items():
        ac=(box[0]+dr,box[1]+dc)
        if not(0<=ac[0]<16 and 0<=ac[1]<16) or ac in blocked: continue
        p=L._bfs_path(av,ac,blocked|({cour} if cour else set()))
        if p is not None and (best is None or len(p)<best[0]):
            best=(len(p),ac,FACES[(box[0]-ac[0],box[1]-ac[1])])
    if best is None: return False
    _,ac,face=best
    if not L._nav_to(e,ac): return False
    e.step(face); e.step(5)
    if not L._grid_grabbed(e):
        return False
    av2=L._cells(e)[0]
    off=(box[0]-av2[0],box[1]-av2[1])
    goal=(drop[0]-off[0],drop[1]-off[1])
    if not L._carry_pair(e,off,goal):
        e.step(5); return False
    e.step(5); return True
def trial(assign, cap=120):
    e=fresh()
    log=[]
    for b,d in assign:
        ok=seat(e,b,d)
        log.append((b,d,ok,len(e.path)-227))
    i=0
    while not e.terminal() and e.levels_completed<5 and i<cap:
        e.step(1 if i%2 else 2); i+=1
    return e.levels_completed, len(e.path)-227, log
