def play_level_9(env):
    # One big goal container (left, courier-fed), two right slot containers,
    # and a pellet-maze self-mover (colour 15) that emerges at (9,3)~move 40
    # to steal seated boxes back to its store.  70-move pellet timer.
    # 1) Avatar seats the two lower-right slots and lifts the third right box
    #    onto the strip for the upper courier.
    deliver_pairs(env, [((8, 14), (6, 14)),
                        ((7, 12), (6, 13)),
                        ((5, 11), (3, 11))])
    # 2) Ambush the stealer at its maze-exit choke cell.
    ambush_mover_at_cell(env, stand=(9, 3), watch=(10, 3), face_action=DOWN)
    # 3) Deliver the one left box the courier cannot seat in time.
    deliver_pairs(env, [((8, 1), (5, 7))])
    # 4) Park clear of the courier lanes; couriers seat the rest.
    park_then_yield(env, (9, 8), DOWN)
