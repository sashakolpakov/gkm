from l5lib import fresh
import legs as L
def seatw(e, box, drop, retries=8):
    # approach from east, face west, carry with box-left offset
    ac=(box[0],box[1]+1)
    if not L._nav_to(e,ac): return False
    e.step(3); e.step(5)
    if not L._grid_grabbed(e): return False
    av2=L._cells(e)[0]
    off=(box[0]-av2[0],box[1]-av2[1])
    goal=(drop[0]-off[0],drop[1]-off[1])
    for _ in range(retries):
        if L._carry_pair(e,off,goal):
            e.step(5); return True
        e.step(5)  # release; try re-grab? just fail
        return False
def trial(assign, cap=120):
    e=fresh()
    log=[]
    for b,d in assign:
        ok=seatw(e,b,d)
        log.append((b,d,ok,len(e.path)-227))
    i=0
    while not e.terminal() and e.levels_completed<5 and i<cap:
        e.step(1 if i%2 else 2); i+=1
    return e.levels_completed, len(e.path)-227, log
