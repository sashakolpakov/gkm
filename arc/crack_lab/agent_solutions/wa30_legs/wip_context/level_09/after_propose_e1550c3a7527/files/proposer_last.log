# --- Timed choke-point ambush (wa30 L9) --------------------------------------
# A pellet-eating self-mover (colour 15) snakes through a bottom maze on a
# fixed schedule and then emerges into the arena to steal seated boxes back to
# its store.  It is uncatchable in the 1-wide maze lanes, but its exit cell is
# known -- so the avatar can arrive early, stand on the exit, and USE the
# instant the mover steps adjacent.  This is the neutralise half of the usual
# neutralise-then-deliver shape, specialised to interception at a choke point.

def ambush_mover_at_cell(env, stand, watch, face_action,
                         mover=15, idle_action=USE, cap=40):
    """Stand on ``stand`` and USE-clear the ``mover`` when it reaches ``watch``.

    Navigates to ``stand`` (box/wall-aware), idles in place with a harmless
    ``idle_action`` until the mover occupies the adjacent ``watch`` cell, then
    steps ``face_action`` (blocked by the mover, so it only turns to face it)
    and fires USE.  Returns True once the mover colour is gone."""
    if not _avatar_nav(env, stand):
        return False
    for _ in range(cap):
        if env.terminal():
            return False
        mc = _mover_cell(env, mover)
        if mc is None:
            return True
        if mc == watch:
            break
        env.step(idle_action)
    env.step(face_action)
    env.step(USE)
    return _mover_cell(env, mover) is None


def park_then_yield(env, cell, idle_action, cap=40):
    """Walk the avatar to a safe out-of-the-way ``cell`` and cede turns.

    Composes :func:`_avatar_nav` with :func:`yield_until_level_up`: park where
    no courier route passes (pick a cell whose ``idle_action`` is blocked, so
    yielding is a true no-op), then idle until the level completes."""
    _avatar_nav(env, cell)
    yield_until_level_up(env, idle_action, cap)
