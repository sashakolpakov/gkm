from probe6 import fresh_at_level6
import numpy as np, time
from collections import deque

def key(f):
    # avatar cell (14), box cells (4&9 or 3&9), grabbed(0&9), courier(15)
    av=None; boxes=[]; gr=[]; cour=None
    # coarse 16x16 via reshape
    for R in range(15):
        base=R*4
        for C in range(16):
            blk=f[base:base+4,C*4:C*4+4]
            u=set(int(v) for v in np.unique(blk))
            if 14 in u: av=(R,C)
            elif 15 in u: cour=(R,C)
            elif 9 in u:
                if 4 in u or 3 in u: boxes.append((R,C))
                elif 0 in u: gr.append((R,C))
    return (av,cour,tuple(sorted(boxes)),tuple(sorted(gr)))

def solve(prefix, max_states=250000, time_cap=250, max_depth=70):
    base=fresh_at_level6(budget=80_000_000)
    b0=base.clone()
    for a in prefix: b0.step(a)
    start_lvl=b0.levels_completed
    t0=time.time()
    k0=key(np.asarray(b0.frame()))
    q=deque([(b0,[])]); seen={k0}
    n=0
    while q and len(seen)<max_states and time.time()-t0<time_cap:
        node,path=q.popleft()
        n+=1
        for a in (1,2,3,4,5):
            ch=node.clone(); ch.step(a)
            if ch.levels_completed>start_lvl:
                return prefix+path+[a], len(seen), time.time()-t0, 'WIN'
            if ch.terminal(): continue
            k=key(np.asarray(ch.frame()))
            if k in seen: continue
            seen.add(k)
            if len(path)+1<max_depth: q.append((ch,path+[a]))
    status='EXHAUSTED' if not q else ('CAP' if len(seen)>=max_states else 'TIME')
    return None, len(seen), time.time()-t0, status

if __name__=='__main__':
    prefix=[1]*7+[4]*6+[5]  # courier removed
    res=solve(prefix, time_cap=250)
    print('courier-removed:',res if res[0] is None else ('WIN len %d'%len(res[0]), res[1:]))
    print(res[0])
