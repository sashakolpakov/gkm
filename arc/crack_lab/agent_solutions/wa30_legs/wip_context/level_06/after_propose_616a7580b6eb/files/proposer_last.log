def grab_and_deliver_robust(env, box, drop, cap=120):
    """Grab a 4x4 box and rigidly carry it onto ``drop``, trying every approach
    side and using clone look-ahead to pick one whose carry path is feasible.

    Generalises :func:`grab_and_deliver` for tightly-fenced goals (e.g. carrying
    a box back through a one-wide wall gap) where only some grab orientations
    leave a routable carry.  Composes _cells / _nav_to / _carry_pair.
    """
    av, head, boxes, cour, walls = _cells(env)
    if box not in boxes:
        return False
    blocked = set(walls) | (set(boxes) - {box})
    if cour:
        blocked.add(cour)
    faces = {(-1, 0): UP, (1, 0): DOWN, (0, -1): LEFT, (0, 1): RIGHT}
    for (dr, dc), face in faces.items():
        ac = (box[0] + dr, box[1] + dc)
        if not (0 <= ac[0] < 16 and 0 <= ac[1] < 16) or ac in blocked:
            continue
        if _bfs_path(av, ac, blocked) is None:
            continue
        # simulate this approach on a clone
        trial = env.clone()
        if not _nav_to(trial, ac, cap):
            continue
        trial.step(face)
        trial.step(USE)
        tav = _cells(trial)[0]
        offset = (box[0] - tav[0], box[1] - tav[1])
        goal_av = (drop[0] - offset[0], drop[1] - offset[1])
        probe = trial.clone()
        if not _carry_pair(probe, offset, goal_av, cap):
            continue
        # feasible -> commit on the real env
        if not _nav_to(env, ac, cap):
            return False
        env.step(face)
        env.step(USE)
        rav = _cells(env)[0]
        off = (box[0] - rav[0], box[1] - rav[1])
        gav = (drop[0] - off[0], drop[1] - off[1])
        if not _carry_pair(env, off, gav, cap):
            env.step(USE)
            return False
        env.step(USE)
        return True
    return False


def clear_mover_then_fill_goal(env, approach, drops, boxes):
    """Level-6 shape: reach a parked self-mover through the wall gap, USE to
    clear it, then ferry every arena box into the goal container.

    ``approach`` is a follow_plan tuple-list that lands the avatar beside the
    mover; the trailing USE removes it.  ``boxes``/``drops`` are the source box
    cells and their goal container cells (paired by index).  Reuses
    :func:`grab_and_deliver_robust` for each box.
    """
    follow_plan(env, *approach)
    use(env)
    for box, drop in zip(boxes, drops):
        grab_and_deliver_robust(env, box, drop)
