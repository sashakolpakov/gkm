def _agent_cells(env, color, band=None):
    f = np.asarray(env.frame())
    cells = set((int(y)//4, int(x)//4) for y, x in zip(*np.where(f == color)))
    if band == 't':
        cells = {c for c in cells if c[0] < 8}
    elif band == 'b':
        cells = {c for c in cells if c[0] > 8}
    return cells


def chase_clear_mover(env, band, color=15, cap=45):
    """Chase a self-mover in ``band`` and USE when adjacent to clear it."""
    for _ in range(cap):
        if env.terminal():
            return False
        f = np.asarray(env.frame())
        mv = _agent_cells(env, color, band)
        if not mv:
            return True
        av, boxes, walls = _grid_scan(env)
        tg = min(mv, key=lambda m: abs(m[0]-av[0])+abs(m[1]-av[1]))
        d = (tg[0]-av[0], tg[1]-av[1])
        if abs(d[0])+abs(d[1]) == 1:
            env.step(_DIRS_INV[d]); env.step(USE); continue
        blk = set(walls) | set(boxes) | (_agent_cells(env, color) - {tg})
        best = None
        for (dr, dc) in _DIRS.values():
            adj = (tg[0]+dr, tg[1]+dc)
            if adj in blk or not (0 <= adj[0] < 16 and 0 <= adj[1] < 16):
                continue
            p = _bfs_path(av, adj, blk)
            if p and (best is None or len(p) < len(best)):
                best = p
        if best:
            env.step(best[0])
        else:
            dr = 1 if tg[0] > av[0] else (-1 if tg[0] < av[0] else 0)
            dc = 1 if tg[1] > av[1] else (-1 if tg[1] < av[1] else 0)
            env.step(DOWN if dr > 0 else (UP if dr < 0 else (RIGHT if dc > 0 else LEFT)))
    return not _agent_cells(env, color, band)


_DIRS_INV = {v: k for k, v in _DIRS.items()}


def clear_movers_then_yield(env, color=15, idle=USE):
    av = _grid_scan(env)[0]
    order = ['t', 'b'] if av[0] < 8 else ['b', 't']
    for band in order:
        chase_clear_mover(env, band, color)
    yield_until_level_up(env, idle, cap=90)
