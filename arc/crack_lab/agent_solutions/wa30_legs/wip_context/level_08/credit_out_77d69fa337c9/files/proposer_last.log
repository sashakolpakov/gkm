from legs import carry_box_to, _grid_scan
import numpy as np

def cellcolors(f,R,C):
    return set(int(v) for v in np.unique(f[R*4:R*4+4,C*4:C*4+4]))

def mu(c):
    f=np.asarray(c.frame()); return 64-int((f[63]==7).sum())

