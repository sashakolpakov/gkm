        if ok: break
    print('it%d box%s ok=%s lvl=%d mu=%d freeleft=%d'%(it,box,ok,c.levels_completed,mu(c),len(free_boxes(c)[1])))
    if not ok:
        # skip: nudge to avoid infinite loop
        c.step(2)
print('FINAL lvl',c.levels_completed,'mu',mu(c),'term',c.terminal())
