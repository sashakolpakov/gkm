from l8env import l8
from perception import connected_components, ACTION_NAME
import numpy as np

def summarize(env):
    f = np.asarray(env.frame())
    blobs = connected_components(f, colors=[4,12,14,15], min_area=1)
    return {(b.color,)+b.bbox for b in blobs}

env = l8()
