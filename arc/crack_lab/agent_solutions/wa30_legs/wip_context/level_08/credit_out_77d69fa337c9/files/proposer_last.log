from l8env import l8
import numpy as np
env=l8()
f=np.asarray(env.frame())
# classify each 4x4 cell
def cls(block):
    vals=set(int(v) for v in np.unique(block))
    if vals=={1}: return '.'
    if vals=={5}: return '#'
    if vals=={7}: return '='
    if vals=={2}: return '2'  # 2-region
    if vals=={12}: return 'C'
    if vals=={0,14}: return 'A'  # avatar
    if vals=={4,9}: return 'b'  # box(4) with 9 hole
    if vals=={15}: return 'M'  # mover
    if vals=={9,2}: return 'g'  # goal container fill (9 frame + 2)
    if vals=={9}: return '9'
    return '?'+str(sorted(vals))
for cr in range(16):
    row=''
    for cc in range(16):
        block=f[cr*4:cr*4+4, cc*4:cc*4+4]
        row+=cls(block).ljust(1)[:1] if not cls(block).startswith('?') else 'x'
    print('{:2d} '.format(cr)+row)
