def empty_cont(f):
    out=[]
    for (R,C) in cont:
        u=cellcolors(f,R,C)
        if 2 in u and not (4 in u or 3 in u or 0 in u):
            out.append((R,C))
    return out

def free_boxes(c):
    av,boxes,walls=_grid_scan(c)
    fb=[]
    for b in boxes:
        if 2<=b[0]<=3 and b[1]>=11: continue
        if 12<=b[0]<=14 and b[1]>=11: continue
        fb.append(b)
    return av,fb

