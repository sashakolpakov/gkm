    if c.terminal() or c.levels_completed>7: break
    f=np.asarray(c.frame())
    av,fb=free_boxes(c)
    empt=empty_cont(f)
    if not fb:
        print('no free boxes at it',it); break
    if not empt:
        print('no empty cont'); break
    fb.sort(key=lambda b:abs(b[0]-av[0])+abs(b[1]-av[1]))
