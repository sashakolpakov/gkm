# --- wa30 L8: two-band courier world (15=ripener mover, 12=courier). --------
# A far-left box cluster is out of the movers' ripening range and never gets
# ripened/seated.  Free such stuck boxes inside the mover's ripening zone so the
# mover ripens them (border 4->5) and the courier seats them into the goal.

def _boxset(env, G=16):
    f = np.asarray(env.frame())
    out = set()
    for R in range(G):
        for C in range(G):
            blk = f[R*4:R*4+4, C*4:C*4+4]
            u = set(int(v) for v in np.unique(blk))
            if 9 in u and ({4, 5, 3, 0} & u) and 2 not in u:
                out.add((R, C))
    return out


def _held(env):
    return _grid_grabbed(env)


def free_box_into_zone(env, box, drop, cap=40):
    """Grab ``box``, rigid-carry it onto ``drop``, USE-release then STEP AWAY so
    the box becomes a free (border-4) box the ripener/courier can process."""
    av, boxes, walls = _grid_scan(env)
    faces = {(-1, 0): UP, (1, 0): DOWN, (0, -1): LEFT, (0, 1): RIGHT}
    best = None
    blk = set(walls) | (boxes - {box})
    for (dr, dc), fa in faces.items():
        ac = (box[0]+dr, box[1]+dc)
        if not (0 <= ac[0] < 16 and 0 <= ac[1] < 16) or ac in blk:
            continue
        p = _bfs_path(av, ac, blk)
        if p is not None and (best is None or len(p) < best[0]):
            best = (len(p), ac, fa)
    if best is None:
        return False
    _, ac, fa = best
    if not _avatar_nav(env, ac, cap) or env.terminal():
        return False
    env.step(fa); env.step(USE)
    if not _held(env):
        return False
    rav = _grid_scan(env)[0]
    hb = sorted(_held(env))[0]
    off = (hb[0]-rav[0], hb[1]-rav[1])
    gav = (drop[0]-off[0], drop[1]-off[1])
    for _ in range(cap):
        if env.terminal():
            return False
        av, boxes, walls = _grid_scan(env)
        if av == gav:
            break
        held = _held(env)
        b2 = set(walls)
        for b in boxes:
            if b not in held:
                b2.add(b)
        b2.discard(gav); b2.discard(av)
        p = _bfs_pair(av, off, gav, b2)
        if not p:
            break
        before = av
        env.step(p[0])
        if _grid_scan(env)[0] == before:
            break
    if env.terminal():
        return False
    env.step(USE)  # release -> border 3
    # step away to free (border 3 -> 4)
    av, boxes, walls = _grid_scan(env)
    held = _held(env)
    for a, (dr, dc) in _DIRS.items():
        nb = (av[0]+dr, av[1]+dc)
        if nb in held or nb in walls or nb in boxes or not (0 <= nb[0] < 16 and 0 <= nb[1] < 16):
            continue
        if not env.terminal():
            env.step(a)
        break
    return True


def feed_stuck_boxes_two_band(env, top_zone, bot_zone,
                              top_pred=lambda b: b[0] < 6 and b[1] < 5,
                              bot_pred=lambda b: b[0] > 9 and b[1] < 6,
                              max_feeds=12, settle=3):
    """Ferry far-left stuck boxes in each band into that band's ripening zone
    and free them, so the band's mover/courier ripen+seat them.  Rotates over a
    small set of zone drop cells (to avoid congesting the handoff, the L5
    lesson), settling a few turns after each free so the helper can process it,
    then yields the rest of the budget for the helpers to finish."""
    base = env.levels_completed
    ti = bi = 0
    for _ in range(max_feeds):
        if env.terminal() or env.levels_completed > base:
            return
        boxes = _boxset(env)
        av = _grid_scan(env)[0]
        ts = [b for b in boxes if top_pred(b)]
        bs = [b for b in boxes if bot_pred(b)]
        if not ts and not bs:
            break
        cand = []
        if ts:
            cand.append(('t', min(ts, key=lambda b: abs(b[0]-av[0])+abs(b[1]-av[1]))))
        if bs:
            cand.append(('b', min(bs, key=lambda b: abs(b[0]-av[0])+abs(b[1]-av[1]))))
        band, box = min(cand, key=lambda kb: abs(kb[1][0]-av[0])+abs(kb[1][1]-av[1]))
        if band == 't':
            drop = top_zone[ti % len(top_zone)]; ti += 1
        else:
            drop = bot_zone[bi % len(bot_zone)]; bi += 1
        ok = free_box_into_zone(env, box, drop)
        if not ok and not env.terminal():
            env.step(USE)
        for _ in range(settle):
            if env.terminal() or env.levels_completed > base:
                return
            env.step(USE)
    yield_until_level_up(env, USE, cap=80)
PYEOF
