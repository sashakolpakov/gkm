$ cd /private/tmp/claude-501/-Users-sasha-gkm/e3e00be1-d1a5-4095-a6ef-4d720f42d84e/scratchpad/gkm_legs_ws_wa30_opus_l8_l9_resume && cat >> legs.py <<'PYEOF'


# --- Pixel-level box->socket sokoban controller (wa30 box family) -----------
# A source-free, frame-only controller for the box-delivery world: the avatar
# (colour 14 body + colour 0 head) grabs a 4x4 box (colour-4 border, 9 core) by
# facing it and USE, carries it rigidly, and pushes it into a 9-bordered socket
# interior (colour-2 fill), releasing with USE.  Works on the 16x16 grid of 4x4
# cells; empty cells are colours {0,1}.  Re-perceives every step so autonomous
# helpers/thieves (colours 12/15) are treated as live obstacles.  This is the
# generic "grab-carry-release into the goal container" skill at pixel fidelity,
# used when the coarse _grid_scan world model is insufficient (solid colour-2
# blocks that are NOT walls in that model, sockets entered from a loading edge).

def _blk(f, R, C):
    return f[R * 4:R * 4 + 4, C * 4:C * 4 + 4]


def _uset(f, R, C):
    return set(int(v) for v in np.unique(_blk(f, R, C)))


def _cell_empty(f, R, C):
    if not (0 <= R < 16 and 0 <= C < 16):
        return False
    return _uset(f, R, C) <= {0, 1}


def _px_avatar(f):
    ys, xs = np.where((f == 14) | (f == 0))
    if not len(ys):
        return None
    return (int(ys.min()) // 4, int(xs.min()) // 4)


def _px_grabbed(f):
    for R in range(16):
        for C in range(16):
            u = _uset(f, R, C)
            if 0 in u and 9 in u and 2 not in u and 14 not in u:
                return (R, C)
    return None


def _px_boxes(f):
    out = set()
    for R in range(16):
        for C in range(16):
            u = _uset(f, R, C)
            if 9 in u and (4 in u or 3 in u) and 2 not in u:
                out.add((R, C))
    return out


def _px_socket_cells(f):
    out = set()
    for R in range(16):
        for C in range(16):
            if _uset(f, R, C) == {2}:
                out.add((R, C))
    return out


def _px_bfs(f, start, goals):
    goals = set(goals)
    if start in goals:
        return []
    q = deque([start])
    prev = {start: None}
    while q:
        cur = q.popleft()
        for a, (dr, dc) in _DIRS.items():
            nb = (cur[0] + dr, cur[1] + dc)
            if nb in prev:
                continue
            if nb in goals or _cell_empty(f, nb[0], nb[1]):
                prev[nb] = (cur, a)
                if nb in goals:
                    path = []
                    n = nb
                    while prev[n]:
                        p, ac = prev[n]
                        path.append(ac)
                        n = p
                    return path[::-1]
                q.append(nb)
    return None


def deliver_boxes_to_sockets(env, prefer='both', budget=140):
    """Greedy pixel controller: repeatedly grab the nearest free box and push it
    into the nearest 9-bordered socket interior, re-perceiving each step.

    ``prefer`` restricts the box pool to the top ('top') / bottom ('bottom')
    arena (row split at cell 8) or uses all boxes ('both').  Bounded by
    ``budget`` real steps.  A general best-effort delivery skill for the wa30
    box family; composes only frame reads + the five actions.
    """
    base = env.levels_completed

    def S(a):
        if env.terminal():
            return False
        env.step(a)
        return True

    for _ in range(budget):
        if env.terminal() or env.levels_completed > base:
            break
        f = np.asarray(env.frame())
        av = _px_avatar(f)
        g = _px_grabbed(f)
        socks = _px_socket_cells(f)
        if g is not None:
            if not socks:
                S(USE)
                continue
            tgt = min(socks, key=lambda s: abs(s[0] - g[0]) + abs(s[1] - g[1]))
            if abs(g[0] - tgt[0]) + abs(g[1] - tgt[1]) == 1:
                dr, dc = tgt[0] - g[0], tgt[1] - g[1]
                face = {(-1, 0): UP, (1, 0): DOWN, (0, -1): LEFT, (0, 1): RIGHT}[(dr, dc)]
                S(face)
                S(USE)
                continue
            order = []
            if tgt[0] != g[0]:
                order.append(DOWN if tgt[0] > g[0] else UP)
            if tgt[1] != g[1]:
                order.append(RIGHT if tgt[1] > g[1] else LEFT)
            moved = False
            for a in order:
                dr, dc = _DIRS[a]
                nav = (av[0] + dr, av[1] + dc)
                ng = (g[0] + dr, g[1] + dc)
                if _cell_empty(f, nav[0], nav[1]) and (_cell_empty(f, ng[0], ng[1]) or ng in socks):
                    S(a)
                    moved = True
                    break
            if not moved:
                S(USE)
            continue
        bs = list(_px_boxes(f))
        if prefer == 'top':
            bs = [b for b in bs if b[0] < 8]
        elif prefer == 'bottom':
            bs = [b for b in bs if b[0] >= 8]
        if not bs:
            S(USE)
            continue
        bs.sort(key=lambda b: abs(b[0] - av[0]) + abs(b[1] - av[1]))
        grabbed = False
        for box in bs[:4]:
            adj = {}
            for a, (dr, dc) in _DIRS.items():
                ac = (box[0] - dr, box[1] - dc)
                if _cell_empty(f, ac[0], ac[1]):
                    adj[ac] = a
            if not adj:
                continue
            path = _px_bfs(f, av, set(adj.keys()))
            if path is None and av not in adj:
                continue
            if path:
                S(path[0])
            av2 = _px_avatar(np.asarray(env.frame()))
            if av2 in adj:
                S(adj[av2])
                S(USE)
            grabbed = True
            break
        if not grabbed:
            S(USE)
    return env.levels_completed > base
