# --- Evasive-agent clearing via bounded lookahead (wa30 L8) -----------------
# Some self-movers (colour 15) evade a reactive chase (they keep a diagonal
# offset from the avatar), yet a mover that steps ORTHOGONALLY adjacent can be
# removed with USE.  A bounded clone beam parks the avatar in a wall-gap
# chokepoint so the wandering mover is forced adjacent, then USEs — driving the
# agent colour's pixel count to zero.  This generalises the L6/L7 "USE-clear a
# blocking agent" to agents that cannot be caught reactively.

def _agent_px(env, color):
    return int((np.asarray(env.frame()) == color).sum())


def _clear_sig(env):
    f = np.asarray(env.frame())
    av = None
    for R in range(16):
        for C in range(16):
            if 14 in set(int(v) for v in np.unique(f[R * 4:R * 4 + 4, C * 4:C * 4 + 4])):
                av = (R, C)

    def cells(c):
        ys, xs = np.where(f == c)
        return frozenset((int(y) // 4, int(x) // 4) for y, x in zip(ys, xs))

    return (av, cells(15), cells(12))


def clear_evasive_agents(env, color=15, budget=90, beam_width=200):
    """Remove every instance of an evasive USE-clearable agent ``color``.

    Runs a bounded clone beam (minimise the agent's pixel count) to find a short
    avatar action sequence, then commits it on the real env.  Returns True once
    the agent colour is gone.  ``budget`` bounds both the search depth and the
    committed move count, keeping clone use small.
    """
    if _agent_px(env, color) == 0:
        return True
    start = env.clone()
    beam = [(_agent_px(start, color), start, [])]
    seen = {_clear_sig(start)}
    found = None
    for _ in range(budget):
        cand = []
        for sc, node, path in beam:
            for a in (UP, DOWN, LEFT, RIGHT, USE):
                ch = node.clone()
                ch.step(a)
                if ch.terminal():
                    continue
                px = _agent_px(ch, color)
                if px == 0:
                    found = path + [a]
                    break
                k = _clear_sig(ch)
                if k in seen:
                    continue
                seen.add(k)
                cand.append((px, ch, path + [a]))
            if found:
                break
        if found:
            break
        if not cand:
            break
        cand.sort(key=lambda x: x[0])
        beam = cand[:beam_width]
    if found is None:
        return False
    for a in found:
        if env.terminal():
            return False
        env.step(a)
    return _agent_px(env, color) == 0


def yield_for_couriers(env, park_goal=(8, 0), idle_actions=(LEFT, RIGHT), cap=90):
    """Park the avatar out of both couriers' regions, then cede turns.

    The couriers (colour 12) are region-locked; parking in the central band lets
    them seat boxes unobstructed.  Yields with a harmless in-place wiggle until
    the level increments or the step budget is spent.
    """
    _avatar_nav(env, park_goal, cap=30)
    start = env.levels_completed
    for i in range(cap):
        if env.terminal() or env.levels_completed > start:
            return
        env.step(idle_actions[i % len(idle_actions)])
EOF
