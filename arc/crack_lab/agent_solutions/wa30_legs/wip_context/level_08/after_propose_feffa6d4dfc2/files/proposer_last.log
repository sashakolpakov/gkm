        open_bot=[t for t in bot if t not in L._grid_scan(c)[1]]
        r=deliver_round(c, lambda b: open_bot)
        if verbose: print(' bot deliver',r,'steps',tot['n'],'cores',cores(c))
        if r is None: break
    # idle rest
    while not c.terminal() and c.levels_completed<=7:
        c.step(1)
def prog(env):
    for a in path:
        if env.terminal(): break
        env.step(a)
    c=env.clone()
    tot={'n':0}; orig=c.step
    c.step=lambda a,_o=orig:(_o(a),tot.__setitem__('n',tot['n']+1))[0]
    run(c,tot)
    print('END lvl',c.levels_completed,'steps',tot['n'],'cores',cores(c),'cnt15',cnt15(c),'term',c.terminal())
A.run_program('wa30', prog)
