bot=[(13,13),(13,12),(12,13),(12,12),(13,14),(12,14),(14,13),(14,12),(14,14)]
tset=set(top)|set(bot)
def deliver_round(c, tgts_for):
    av,boxes,walls=L._grid_scan(c)
    free=[b for b in boxes if b not in tset]
    def tg(b): return tgts_for(b)
    free.sort(key=lambda b: min((abs(b[0]-t[0])+abs(b[1]-t[1]) for t in tg(b)),default=99))
    for b in free[:6]:
        for t in sorted(tg(b),key=lambda t:abs(b[0]-t[0])+abs(b[1]-t[1]))[:2]:
            if L.carry_box_to(c,b,t): return (b,t)
    return None
def run(c,tot,verbose=True):
    # clear top
    L._avatar_nav(c,(5,5),cap=15); chase(c,lambda m:m[0]<7,20)
