import json, sys
sys.path.insert(0, '/Users/sasha/gkm/arc/crack_lab')
import gkm_arena as A
import numpy as np, legs as L
ck=json.load(open('checkpoint.json')); path=ck['final_path']
DIRS={1:(-1,0),2:(1,0),3:(0,-1),4:(0,1)}
def m15(env):
    f=np.asarray(env.frame()); ys,xs=np.where(f==15)
    return sorted(set((int(y)//4,int(x)//4) for y,x in zip(ys,xs)))
def cnt(env,c):return int((np.asarray(env.frame())==c).sum())
def dir_to(a,m):
    for act,(dr,dc) in DIRS.items():
        if (a[0]+dr,a[1]+dc)==m: return act
    return None
def chase_one(c, band_row_filter, cap):
    used=0
    while used<cap and not c.terminal():
        ms=[m for m in m15(c) if band_row_filter(m)]
        if not ms: return used,True
        av=L._grid_scan(c)[0]
        ms.sort(key=lambda m:abs(av[0]-m[0])+abs(av[1]-m[1]))
        m=ms[0]; d=abs(av[0]-m[0])+abs(av[1]-m[1])
        if d==1:
            fa=dir_to(av,m)
            c.step(fa); used+=1  # face (avatar stays if solid)
            c.step(5); used+=1   # USE
        else:
            walls=L._grid_scan(c)[2]
            p=L._bfs_path(av,m,set(walls)-{m})
            c.step(p[0] if p else 1); used+=1
    return used,(not [m for m in m15(c) if band_row_filter(m)])
def prog(env):
    for a in path:
        if env.terminal(): break
        env.step(a)
    c=env.clone()
    tot={'n':0}; orig=c.step
    c.step=lambda a,_o=orig:(_o(a),tot.__setitem__('n',tot['n']+1))[0]
    print('start cnt15',cnt(c,15))
    # top band mover (row<7)
    L._avatar_nav(c,(5,5),cap=30)
    u,ok=chase_one(c, lambda m:m[0]<7, 40)
    print('top chase done ok',ok,'cnt15',cnt(c,15),'steps',tot['n'])
    # bottom band mover (row>9)
    L._avatar_nav(c,(11,9),cap=30)
    u,ok=chase_one(c, lambda m:m[0]>9, 40)
    print('bot chase done ok',ok,'cnt15',cnt(c,15),'steps',tot['n'])
A.run_program('wa30', prog)
