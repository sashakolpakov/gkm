        if r is None: break
    # clear bottom
    L._avatar_nav(c,(11,9),cap=15); chase(c,lambda m:m[0]>9,35)
    if verbose: print('bot clear steps',tot['n'],'cnt15',cnt15(c),'cores',cores(c))
    for _ in range(3):
