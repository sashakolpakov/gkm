        d=abs(av[0]-m[0])+abs(av[1]-m[1])
        if d==1: c.step(5)
        else:
            blocked=(set(walls)|set(boxes))-{m}; p=L._bfs_path(av,m,blocked) or L._bfs_path(av,m,set(walls)-{m})
            c.step(p[0] if p else 1)
