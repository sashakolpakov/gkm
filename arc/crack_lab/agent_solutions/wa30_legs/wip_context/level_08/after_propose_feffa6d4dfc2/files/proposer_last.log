import gkm_arena as A
import numpy as np
import perception as P

ck=json.load(open('checkpoint.json'))
path=ck['final_path']

def centroids_by_color(f):
    d={}
    for col in [0,2,4,7,9,12,14,15]:
        ys,xs=np.where(f==col)
        if len(ys): d[col]=(round(ys.mean(),1),round(xs.mean(),1),len(ys))
    return d

def prog(env):
    for a in path:
        if env.terminal(): break
        env.step(a)
    base=np.asarray(env.frame())
    b=centroids_by_color(base)
    print('BASE',b)
    for act in [1,2,3,4,5]:
        c=env.clone(); c.step(act)
        f=np.asarray(c.frame())
        cc=centroids_by_color(f)
        # show colors whose centroid or count changed
        diffs={col:(b.get(col),cc.get(col)) for col in cc if b.get(col)!=cc.get(col)}
        print(P.ACTION_NAME[act], diffs)

A.run_program('wa30', prog)
