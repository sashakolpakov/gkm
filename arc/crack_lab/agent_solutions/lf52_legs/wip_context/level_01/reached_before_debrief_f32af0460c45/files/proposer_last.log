{"type":"item.completed","item":{"id":"item_12","type":"command_execution","command":"/bin/zsh -lc \"sed -n '1,140p' probe.py\"","aggregated_output":"import sys\n\nsys.path.insert(0, \"/Users/sasha/gkm/arc/crack_lab\")\n\nimport gkm_arena as arena\n\nfrom perception import color_counts, connected_components, frame_delta\n\n\nACTIONS = (1, 2, 3, 4, 6, 7)\n\n\ndef blobs(frame):\n    return [\n        (b.color, b.bbox, b.area)\n        for b in connected_components(frame, min_area=2)\n    ]\n\n\ndef inspect(env):\n    base = env.frame()\n    print(\"level\", env.levels_completed + 1, \"actions\", env.actions)\n    print(\"colors\", color_counts(base))\n    print(\"blobs\", blobs(base))\n    for action in ACTIONS:\n        clone = env.clone()\n        before = clone.frame()\n        clone.step(action)\n        delta = frame_delta(before, clone.frame())\n        print(\n            \"action\",\n            action,\n            \"reward\",\n            clone.levels_completed,\n            \"delta\",\n            (delta[\"count\"], delta[\"bbox\"]),\n            \"blobs\",\n            blobs(clone.frame()),\n        )\n    print(\"coordinate_scan\")\n    for row, y in enumerate(range(13, 50, 6)):\n        line = []\n        for col, x in enumerate(range(12, 49, 6)):\n            clone = env.clone()\n            before = clone.frame()\n            clone.step(6, x, y)\n            delta = frame_delta(before, clone.frame())\n            line.append(\n                (\n                    row,\n                    col,\n                    delta[\"count\"],\n                    delta[\"bbox\"],\n                    color_counts(clone.frame()),\n                    clone.levels_completed,\n                )\n            )\n        print(line)\n\n\narena.run_program(\"lf52\", inspect)\n","exit_code":0,"status":"completed"}}
