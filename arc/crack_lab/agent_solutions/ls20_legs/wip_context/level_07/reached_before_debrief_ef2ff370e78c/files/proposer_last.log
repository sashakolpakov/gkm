import sys
sys.path.insert(0,'/tmp')
from mk7 import make7
from map7 import Mapper
import numpy as np

def run(seq, verbose=False):
    env = make7()
    c = env.clone()
    M = Mapper()
    M.feed(c.frame())
    trace = []
    for a in seq:
        f = c.step(a)
        av = M.feed(f)
        bar = int((np.array(f)[61]==11).sum())
        trace.append((a, av, bar))
        if verbose: print(a, av, bar)
    return c, M, trace
