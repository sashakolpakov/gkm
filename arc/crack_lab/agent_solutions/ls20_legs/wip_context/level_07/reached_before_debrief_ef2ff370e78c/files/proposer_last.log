import sys
sys.path.insert(0,'/tmp')
from mk7 import make7, CH
import numpy as np

class Mapper:
    def __init__(self):
        self.known = np.full((64,64), -1, dtype=int)

    def feed(self, f):
        f = np.asarray(f)
        # avatar
        av = None
        rs, cs = np.where(f == 12)
        for r, c in zip(rs, cs):
            if r < 54 and c+4 < 64 and (f[r, c:c+5] == 12).all() and r+4<64 and (f[r+2,c:c+5]==9).all():
                av = (int(r), int(c)); break
        for r in range(54):
            for c in range(64):
                v = int(f[r,c])
                if v == 5: continue
                if av and av[0]<=r<av[0]+5 and av[1]<=c<av[1]+5: continue
                if v == 4:
                    if av is None: continue
                    d = abs(r-(av[0]+2)) + abs(c-(av[1]+2))
                    if d > 9: continue
                self.known[r,c] = v
        return av

    def show(self):
        for r in range(54):
            print(''.join('?' if self.known[r,c]<0 else CH.get(int(self.known[r,c]),'x') for c in range(64)))
