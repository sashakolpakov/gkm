import sys, json
sys.path.insert(0,'/tmp')
from drv7 import make7, obs
import numpy as np

S0A5 = '110011101'    # after C x3 + A x5: shape S0, color 8
FINAL = '101110011'   # room pattern = R^2(S0)

class Ctl:
    def __init__(self, c):
        self.c = c
        self.acts = []
        self.o = obs(c.frame())
    def step(self, a):
        f = self.c.step(a)
        self.acts.append(a)
        self.o = obs(f)
        assert not (self.o['av'] == (15,19) and len(self.acts) > 3 and self.o['bar'] >= 40), ('DEATH', len(self.acts))
        return self.o
    def run(self, seq):
        for a in seq: self.step(a)
    def st(self):
        return self.o['av'], self.o['bar'], self.o['bl'], self.o['blc']

def main():
    env = make7()
    c = env.clone()
    C = Ctl(c)
    # --- phase 1: C x3 (color 12->8), A x5 (shape -> S0)
    C.run([3,3,2,2,2,2]); assert C.o['av'] == (35,9), C.st()
    C.run([2,1,2,1,2]);   assert C.o['av'] == (40,9) and C.o['blc'] == [8], C.st()
    C.run([4,2]);         assert C.o['bar'] >= 40, C.st()   # box (45,14)
    C.run([1,4]);         assert C.o['av'] == (40,19), C.st()
    C.run([1,2,1,2,1,2,1,2])
    assert C.o['bl'] == S0A5 and C.o['blc'] == [8], C.st()
    # --- phase 2: travel right, refuel (20,29), spring, dial R^2
    C.run([1,3,3,1,1]);   assert C.o['av'] == (25,9), C.st()
    C.run([4,4,4,4,1]);   assert C.o['bar'] >= 40, C.st()   # box (20,29)
    C.run([2,4,4,1]);     assert C.o['av'] == (40,39), C.st()  # spring
    C.run([4,4,4,1,1,1,1]); assert C.o['av'] == (20,54), C.st()
    for attempt in range(8):
        guard = 0
        while C.o['bl'] != FINAL:
            guard += 1; assert guard < 40, C.st()
            if C.o['bar'] <= 12:
                while C.o['av'] != (15,54):
                    C.step(1 if C.o['av'][0] > 15 else 2)
                C.run([1,1,3])          # box (5,49)
                assert C.o['bar'] >= 36, C.st()
                C.run([4,2,2])          # back to (15,54)
                continue
            C.step(1 if C.o['av'] == (20,54) else 2)
        # exit down while intact
        while C.o['av'] != (40,54) and C.o['bl'] == FINAL:
            C.step(2)
        if C.o['av'] == (40,54) and C.o['bl'] == FINAL:
            break
        while C.o['av'][0] < 20:
            C.step(2)
        while C.o['av'][0] > 20:
            C.step(1)
    assert C.o['av'] == (40,54) and C.o['bl'] == FINAL and C.o['blc'] == [8], C.st()
    # --- phase 3: refuel (50,54), spring back, press into room
    C.run([3,2,2,4]);     assert C.o['bar'] >= 40, C.st()   # box (50,54)
    C.run([3,1,1,3,3]);   assert C.o['av'] == (40,39), C.st()
    C.run([1,1]);         assert C.o['av'] == (30,29), C.st()
    C.run([2,2,2]);       assert C.o['av'] == (45,29), C.st()
    assert C.o['bl'] == FINAL and C.o['blc'] == [8], C.st()
    C.step(2)
    print('levels:', c.levels_completed, 'pos', C.o['av'], 'bar', C.o['bar'], 'moves', len(C.acts))
    if c.levels_completed >= 7:
        json.dump(C.acts, open('/tmp/win7.json','w'))
        print('WIN')

main()
