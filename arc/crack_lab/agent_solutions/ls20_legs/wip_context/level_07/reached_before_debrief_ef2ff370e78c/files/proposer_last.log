import sys
sys.path.insert(0,'/tmp')
from mk7 import make7, CH
import numpy as np
from collections import deque

ROWS = list(range(5, 51, 5))
COLS = list(range(9, 60, 5))

def obs(f):
    f = np.asarray(f)
    o = {}
    o['av'] = None
    rs, cs = np.where(f == 12)
    for r, c in zip(rs, cs):
        if r < 50 and c+4 < 64 and (f[r, c:c+5] == 12).all() and (f[r+2, c:c+5] == 9).all():
            o['av'] = (int(r), int(c)); break
    o['bar'] = int((f[61] == 11).sum())
    o['lives'] = int((f[60:63, 57:] == 8).sum())
    # display bottom-left: 3x3 at rows 54,56,58 cols 3,5,7
    o['bl'] = ''.join(str(int(f[r, c] != 5)) for r in (54,56,58) for c in (3,5,7))
    blc = [int(v) for v in np.unique(f[54:60, 3:9]) if v != 5]
    o['blc'] = blc
    return o

class Mapper:
    def __init__(self):
        self.known = np.full((64,64), -1, dtype=int)
    def feed(self, f, av):
        f = np.asarray(f)
        for r in range(54):
            for c in range(64):
                v = int(f[r,c])
                if v == 5: continue
                if av and av[0]<=r<av[0]+5 and av[1]<=c<av[1]+5: continue
                if v == 4:
                    if av is None: continue
                    if abs(r-(av[0]+2)) + abs(c-(av[1]+2)) > 9: continue
                self.known[r,c] = v
    def show(self, r0=0, r1=54):
        print('    ' + ''.join(str(cc%10) for cc in range(64)))
        for r in range(r0, r1):
            print(f'{r:2d}  ' + ''.join('?' if self.known[r,c]<0 else CH.get(int(self.known[r,c]),'x') for c in range(64)))

class D:
    def __init__(self, env, mapper=None):
        self.c = env
        self.M = mapper or Mapper()
        self.o = obs(env.frame())
        self.M.feed(env.frame(), self.o['av'])
        self.trace = []
    def step(self, a):
        f = self.c.step(a)
        self.o = obs(f)
        self.M.feed(f, self.o['av'])
        self.trace.append((a, self.o['av'], self.o['bar'], self.o['lives']))
        return self.o
    def run(self, seq):
        for a in seq:
            self.step(a)
        return self.o
