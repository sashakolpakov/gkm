import sys; sys.path.insert(0,'/tmp')
from drv7 import *
import numpy as np
env = make7()
c = env.clone()
def sprites(f):
    f = np.asarray(f)
    out = {}
    # creature: multicolour incl 14
    rs, cs = np.where(f==14)
    out['cr'] = (int(rs.min()), int(cs.min())) if len(rs) else None
    # digit sprites: colors 0
    rs, cs = np.where(f==0)
    pts = [(int(r),int(c)) for r,c in zip(rs,cs)]
    left = [p for p in pts if p[1] < 30]
    right = [p for p in pts if p[1] >= 44]
    out['sl'] = min(left) if left else None
    out['sr'] = min(right) if right else None
    return out
# bounce in top-left room between (15,9) and (10,9): far from all sprites
c.step(3); c.step(3)
for i in range(14):
