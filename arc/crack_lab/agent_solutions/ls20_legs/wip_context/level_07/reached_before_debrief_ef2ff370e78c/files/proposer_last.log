import sys, json
sys.path.insert(0,'/tmp')
from drv7 import make7, obs
import numpy as np

INTER = '111010010'   # R^2 A^1 S0  (after R-dial, before A-dial)
FINAL = '101110011'   # room pattern R^2 A^0 S0
class Ctl:
    def __init__(self, c):
        self.c = c
        self.acts = []
        self.o = obs(c.frame())
    def step(self, a):
        f = self.c.step(a)
        self.acts.append(a)
        self.o = obs(f)
        return self.o
    def run(self, seq):
        for a in seq:
            self.step(a)
    def st(self):
        return self.o['av'], self.o['bar'], self.o['bl'], self.o['blc']

def main():
    env = make7()
    c = env.clone()
    C = Ctl(c)
    # --- to right region via spring
    C.run([1,1,4,4,2,4,2,2,4])
    assert C.o['av'] == (40,39), C.st()
    C.run([4,4,4])
    assert C.o['av'] == (40,54), C.st()
    # refuel (50,54)
    C.run([3,2,2,4]); assert C.o['bar'] >= 40, C.st()
    C.run([3,1,1,4]); assert C.o['av'] == (40,54), C.st()
    # up to bounce zone
    C.run([1,1,1,1]); assert C.o['av'] == (20,54), C.st()
    # dial R until INTER, then exit cleanly
    for attempt in range(6):
        guard = 0
        while C.o['bl'] != INTER:
            guard += 1; assert guard < 30
            a = 1 if C.o['av'] == (20,54) else 2
            C.step(a)
            if C.o['bar'] <= 10:
                # refuel top-right box (5,49)
                while C.o['av'] != (15,54):
                    C.step(1 if C.o['av'][0] > 15 else 2)
                C.run([1,1,3])   # (5,49) box
                assert C.o['bar'] >= 38, C.st()
                C.run([4,2,2])   # back to (15,54)
        # exit down to (40,54)
        while C.o['av'] != (40,54) and C.o['bl'] == INTER:
            C.step(2)
        if C.o['av'] == (40,54) and C.o['bl'] == INTER:
            break
        # broken by a crossing: go back up and re-dial
        while C.o['av'] != (20,54):
            C.step(1)
    assert C.o['av'] == (40,54) and C.o['bl'] == INTER, C.st()
    # --- return west via spring (30,39)
    C.run([3,3,3]); assert C.o['av'] == (40,39), C.st()
    C.run([1,1]);  assert C.o['av'] == (30,29), C.st()
    C.run([1,3,3,3,3]); assert C.o['av'] == (25,9), C.st()
    C.run([2,2]); assert C.o['av'] == (35,9), C.st()
    # --- C presses x3: color 12->9->14->8
    C.run([2,1,2,1,2])
    assert C.o['blc'] == [8], C.st()
    assert C.o['av'] == (40,9), C.st()
    # refuel (45,14)
    C.run([4,2]); assert C.o['bar'] >= 40, C.st()
    C.run([1])
    # --- A presses x5
    C.run([4]); assert C.o['av'] == (40,19), C.st()
    C.run([1,2,1,2,1,2,1,2])
    assert C.o['bl'] == FINAL and C.o['blc'] == [8], C.st()
    # --- to the room
    C.run([1,3,3,1,1]); assert C.o['av'] == (25,9), C.st()
    C.run([4,4,4,4]); assert C.o['av'] == (25,29), C.st()
    C.run([1,2])  # box (20,29) and back
    assert C.o['bar'] >= 38, C.st()
    C.run([2,2,2,2]); assert C.o['av'] == (45,29), C.st()
    C.step(2)
    print('levels:', c.levels_completed, 'pos', C.o['av'], 'bar', C.o['bar'])
    if c.levels_completed >= 7:
        json.dump(C.acts, open('/tmp/win7.json','w'))
        print('WIN, moves', len(C.acts))
    else:
        print('no win yet', C.st())

main()
