# Faster BFS: reuse a clone across blocked (no-change) actions.
import json, sys, time
sys.path.insert(0, '/Users/sasha/gkm/arc/crack_lab')
import gkm_arena as A
import numpy as np
from collections import deque
from legs import detect_noise_mask, _masked_bytes

ck = json.load(open("checkpoint.json"))
env = A.Arena('ls20')
for a in ck["final_path"]:
    env.step(a)
assert env.levels_completed == 5
mask = detect_noise_mask(env)
t0 = time.time()

start = env.clone()
key0 = _masked_bytes(start.frame(), mask)
seen = {key0}
q = deque([(start, [], key0)])
base = env.levels_completed
path = None
nclones = 0
while q and path is None:
    node, p, nkey = q.popleft()
    c = node.clone(); nclones += 1
    for a in (1, 2, 3, 4):
        f = c.step(a)
        if c.levels_completed > base:
            path = p + [a]
            break
        key = _masked_bytes(f, mask)
        if key == nkey:
            continue  # blocked/no-op: state unchanged, reuse clone
        if key not in seen:
            seen.add(key)
            q.append((c, p + [a], key))
        # need a fresh copy of node for remaining actions
        if a != 4:
            c = node.clone(); nclones += 1
    if len(seen) >= 200000:
        break
    if len(seen) % 10000 < 3:
        print("seen", len(seen), "depth", len(p), "clones", nclones,
              "t=%.0fs" % (time.time()-t0), flush=True)
print("PATH:", path)
print("states:", len(seen), "clones:", nclones, "time %.1fs" % (time.time()-t0))
if path:
    json.dump(path, open('/tmp/win6.json', 'w'))
EOF
