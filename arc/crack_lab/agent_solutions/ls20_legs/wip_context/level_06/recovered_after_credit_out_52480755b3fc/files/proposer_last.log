import numpy as np
from collections import deque

def obs(f):
    f = np.asarray(f)
    o = {}
    rs, cs = np.where(f == 12)
    o['av'] = None
    for r, c in zip(rs, cs):
        if c+4 < 64 and (f[r, c:c+5] == 12).all():
            o['av'] = (int(r), int(c)); break
    sa = [(int(r),int(c)) for r,c in zip(*np.where((f==0)|(f==1))) if 10<=r<=14 and 9<=c<=47]
    sb = [(int(r),int(c)) for r,c in zip(*np.where((f==0)|(f==1))) if 40<=r<=44 and 9<=c<=47]
    cr = [(int(r),int(c)) for r,c in zip(*np.where(f==14)) if r<55 and 5<=c<=50]
    o['sa'] = min(sa) if sa else None
    o['sb'] = min(sb) if sb else None
    o['cr'] = min(cr) if cr else None
    o['bl'] = ''.join(str(int(v!=5)) for v in f[55:61:2, 3:9:2].flatten())
    o['blc'] = [int(v) for v in np.unique(f[55:61, 3:9]) if v != 5]
    o['bar'] = int((f[60:63] == 11).sum())
    o['boxes'] = set()
    for name, (r, c) in {'b45': (46,10), 'b5l': (6,10), 'b5r': (6,40)}.items():
        if f[r, c] == 11:
            o['boxes'].add(name)
    return o

# static tile graph (no springs during ops)
ROWS = list(range(5, 51, 5)); COLS = list(range(9, 55, 5))
GRID = {
 5:  "XXXXXXX.XX",
 10: "XXXXXXX.XX",
 15: "X.....XXX.",
 20: "X.XXX.XXX.",
 25: "XXXXXXX.XX",
 30: "X.XXX.X..X",
 35: "X.....X...",
 40: "XXXXXXX..X",
 45: ".XXXXXX..X",
 50: ".XXXXX....",
}
OK = {(r, COLS[i]): ch == 'X' for r in ROWS for i, ch in enumerate(GRID[r])}
SPRINGS = {(5,49), (20,49)}
RING = [(31,26),(31,21),(26,21),(21,21),(21,26),(21,31),(26,31),(31,31)]

def cr_next(cur):
    return RING[(RING.index(cur)+1) % 8] if cur in RING else None

def overlaps(av, obj3):
    if av is None or obj3 is None:
        return False
    r, c = av; orr, oc = obj3
    return r <= orr and orr+2 <= r+4 and c <= oc and oc+2 <= c+4

SA_ROW, SB_ROW = 11, 41
def spr_next(pos, prev):
    # horizontal patrol; TLs cols 15..35 (A) or 16..36 (B); direction from prev
    if pos is None: return None
    lo, hi = (15, 35) if pos[0] == SA_ROW else (16, 36)
    if prev is None or prev == pos:
        d = 5
    else:
        d = pos[1] - prev[1]
    nc = pos[1] + d
    if nc > hi or nc < lo:
        d = -d; nc = pos[1] + d
    return (pos[0], nc)

class Driver:
    def __init__(self, env):
        self.c = env
        self.o = obs(env.frame())
        self.prev = {'sa': None, 'sb': None}
        self.base = env.levels_completed

    def step(self, a):
        self.prev['sa'] = self.o['sa'] or self.prev['sa']
        self.prev['sb'] = self.o['sb'] or self.prev['sb']
        f = self.c.step(a)
        self.o = obs(f)
        return self.o

    def won(self):
        return self.c.levels_completed > self.base

    def predicted(self):
        # predict next positions of sa, sb, cr if a tick happens
        sa_n = spr_next(self.o['sa'], self.prev['sa'])
        sb_n = spr_next(self.o['sb'], self.prev['sb'])
        cr_n = cr_next(self.o['cr']) if self.o['cr'] else None
        return sa_n, sb_n, cr_n

    def safe_move(self, a, allow=()):
        """attempt move a; only if destination tile won't overlap any predicted
        critter (except those in allow). Returns True if moved."""
        r, c = self.o['av']
        dr, dc = {1:(-5,0),2:(5,0),3:(0,-5),4:(0,5)}[a]
        dest = (r+dr, c+dc)
        sa_n, sb_n, cr_n = self.predicted()
        for name, pos in (('sa',sa_n),('sb',sb_n),('cr',cr_n)):
            if name in allow: continue
            if overlaps(dest, pos):
                return False
        self.step(a)
        return True

    def goto(self, target, avoid_crit=True):
        # BFS path on tiles; execute with per-step critter dodging
        while self.o['av'] != target:
            path = self._plan(self.o['av'], target)
            assert path, (self.o['av'], target)
            a = path[0]
            if not avoid_crit:
                self.step(a); continue
            if not self.safe_move(a):
                # dodge: try a harmless side-step or reverse, else wait via bounce
                for alt in (1,2,3,4):
                    if alt == a: continue
                    r, c = self.o['av']
                    dr, dc = {1:(-5,0),2:(5,0),3:(0,-5),4:(0,5)}[alt]
                    dest = (r+dr, c+dc)
                    if OK.get(dest) and dest not in SPRINGS and self.safe_move(alt):
                        break
                else:
                    # nothing safe?? just take original move
                    self.step(a)

    def _plan(self, a, b):
        q = deque([(a, [])]); seen = {a}
        while q:
            u, p = q.popleft()
            if u == b: return p
            r, c = u
            for act,(dr,dc) in {1:(-5,0),2:(5,0),3:(0,-5),4:(0,5)}.items():
                v = (r+dr, c+dc)
                if OK.get(v) and v not in SPRINGS and v not in seen:
                    seen.add(v); q.append((v, p+[act]))
        return None

    def refuel_if_needed(self, floor=30):
        if self.o['bar'] > floor:
            return
        for name, tile in (('b45',(45,9)), ('b5l',(5,9)), ('b5r',(5,39))):
            if name in self.o['boxes']:
                self.goto(tile)
                return

    def op_B(self):
        self.refuel_if_needed()
        self.goto((40,39))
        guard = 0
        while guard < 40:
            guard += 1
            if self.o['av'] == (40,39):
                # try to move to (40,34) exactly when sprite lands at TL 36
                sb_n = self.predicted()[1]
                if sb_n and overlaps((40,34), sb_n):
                    self.step(3)  # overlap!
                    self.goto((40,39))
                    return True
                self.safe_move(3, allow=())  or self.step(1) and None
            elif self.o['av'] == (40,34):
                self.safe_move(4) or self.step(4)
            else:
                self.goto((40,39))
        return False

    def op_A(self):
        self.refuel_if_needed()
        self.goto((10,9))
        guard = 0
        while guard < 40:
            guard += 1
            if self.o['av'] == (10,9):
                sa_n = self.predicted()[0]
                if sa_n and overlaps((10,14), sa_n):
                    self.step(4)
                    self.goto((10,9))
                    return True
                self.safe_move(4) or self.step(3)
            elif self.o['av'] == (10,14):
                self.safe_move(3) or self.step(3)
            else:
                self.goto((10,9))
        return False

    def op_C(self):
        self.refuel_if_needed()
        self.goto((25,9))
        guard = 0
        while guard < 40:
            guard += 1
            if self.o['av'] == (25,14):
                cr_n = self.predicted()[2]
                if cr_n == (26,21):
                    self.step(4)  # overlap at (25,19)
                    # leave west immediately
                    self.step(3)
                    return True
                self.safe_move(3) or self.step(3)
            elif self.o['av'] == (25,9):
                self.safe_move(4) or self.step(4)
            else:
                self.goto((25,14))
        return False
