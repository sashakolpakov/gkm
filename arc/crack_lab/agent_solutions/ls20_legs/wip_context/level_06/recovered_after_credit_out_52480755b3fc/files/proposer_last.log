import json, sys, time
sys.path.insert(0, '/Users/sasha/gkm/arc/crack_lab')
import gkm_arena as A
import numpy as np
from legs import detect_noise_mask, find_winning_path

ck = json.load(open("checkpoint.json"))
env = A.Arena('ls20')
for a in ck["final_path"]:
    env.step(a)
assert env.levels_completed == 5

t0 = time.time()
mask = detect_noise_mask(env)
print("mask cells:", int(mask.sum()), "t=%.1fs" % (time.time()-t0))

# instrumented BFS to count states explored
from collections import deque
from legs import _masked_bytes
start = env.clone()
key0 = _masked_bytes(start.frame(), mask)
seen = {key0}
q = deque([(start, [])])
base = env.levels_completed
path = None
while q:
    node, p = q.popleft()
    for a in (1,2,3,4):
        c = node.clone()
        c.step(a)
        if c.levels_completed > base:
            path = p + [a]
            break
        key = _masked_bytes(c.frame(), mask)
        if key not in seen:
            seen.add(key)
            q.append((c, p + [a]))
    if path: break
    if len(seen) >= 120000:
        break
    if len(seen) % 5000 < 4:
        print("seen", len(seen), "depth", len(p), "t=%.0fs" % (time.time()-t0), flush=True)
print("PATH:", path)
print("states:", len(seen), "time %.1fs" % (time.time()-t0))
if path:
    json.dump(path, open('/tmp/win6.json','w'))
EOF
