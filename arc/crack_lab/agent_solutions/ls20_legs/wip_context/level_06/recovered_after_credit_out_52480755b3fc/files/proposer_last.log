sys.path.insert(0, '/Users/sasha/gkm/arc/crack_lab')
import multiprocessing as mp
mp.set_start_method('fork', force=True)
import gkm_arena as A
import numpy as np
from legs import detect_noise_mask

ck = json.load(open("checkpoint.json"))
ROOT = A.Arena('ls20')
for a in ck["final_path"]:
    ROOT.step(a)
BASE_LEVEL = ROOT.levels_completed
MASK = detect_noise_mask(ROOT)
MASKB = MASK.tobytes()

def digest(frame):
    g = np.asarray(frame).copy()
    g[MASK] = 255
    return hashlib.md5(g.tobytes()).digest()

ACTIONS = (1, 2, 3, 4)

def worker(conn, wid):
    store = {}
    if wid == 0:
        store[digest(ROOT.frame())] = ROOT
    while True:
        msg = conn.recv()
        cmd = msg[0]
        if cmd == 'expand':
            keys = msg[1]
            out = []
            for k in keys:
                node = store.get(k)
                if node is None:
                    out.append(('missing', k)); continue
                nkey = k
                c = node.clone()
                for a in ACTIONS:
                    f = c.step(a)
                    if c.levels_completed > BASE_LEVEL:
                        out.append(('win', k, a))
                        conn.send(out)
                        break
                    d = digest(f)
                    if d == nkey:
                        continue
                    store[d] = c
                    out.append(('child', k, a, d))
                    if a != ACTIONS[-1]:
                        c = node.clone()
                else:
                    continue
                break
            else:
                conn.send(out)
        elif cmd == 'keep':
            keep = set(msg[1])
            for d in list(store.keys()):
                if d not in keep:
                    del store[d]
            conn.send(('kept', len(store)))
        elif cmd == 'quit':
            conn.send('bye'); return

NW = 8
conns = []
for wid in range(NW):
    pc, cc = mp.Pipe()
    p = mp.Process(target=worker, args=(cc, wid), daemon=True)
    p.start()
    conns.append(pc)

root_key = digest(ROOT.frame())
seen = {root_key}
owner = {root_key: 0}
parent = {}
frontier = [root_key]
t0 = time.time()
win = None
MAXSTATES = 400000
rounds = 0
while frontier and win is None and len(seen) < MAXSTATES:
    rounds += 1
    # assign frontier keys to their owners
    per = {w: [] for w in range(NW)}
    for k in frontier:
        per[owner[k]].append(k)
    for w in range(NW):
        conns[w].send(('expand', per[w]))
    results = []
    for w in range(NW):
        results.append((w, conns[w].recv()))
    newf = []
    keep_by_w = {w: set() for w in range(NW)}
    for w, out in results:
        for rec in out:
            if rec[0] == 'win':
                k, a = rec[1], rec[2]
                win = (k, a)
                break
            if rec[0] == 'child':
                k, a, d = rec[1], rec[2], rec[3]
                if d not in seen:
                    seen.add(d)
                    parent[d] = (k, a)
                    owner[d] = w
                    newf.append(d)
                    keep_by_w[w].add(d)
        if win: break
    if win: break
    # tell workers to prune stores to new frontier only
    for w in range(NW):
        conns[w].send(('keep', keep_by_w[w]))
    for w in range(NW):
        conns[w].recv()
    frontier = newf
    print(f"round {rounds} seen {len(seen)} frontier {len(frontier)} t={time.time()-t0:.0f}s", flush=True)

if win:
    k, a = win
    path = [a]
    while k != root_key:
        pk, pa = parent[k]
        path.append(pa)
        k = pk
    path.reverse()
    print("WIN PATH:", path)
    json.dump(path, open('/tmp/win6.json', 'w'))
else:
    print("no win", len(seen))
for w in range(NW):
    conns[w].send(('quit',))
