import json, sys
sys.path.insert(0, '/Users/sasha/gkm/arc/crack_lab')
import gkm_arena as A
import numpy as np

ck = json.load(open("checkpoint.json"))
env = A.Arena('ls20')
for a in ck["final_path"]:
    env.step(a)
f0 = np.array(env.frame())

def find_objs(f):
    # avatar: 12 over 9 5x5; creature: 3x3 with 14s; digits: colors 0/1 glyphs
    out = {}
    rs, cs = np.where(f == 12)
    if len(rs): out['avatar'] = (rs.min(), cs.min())
    # creature: cell with value 14 not in bottom-left room (col>13? track area cols 9-47)
    rs, cs = np.where((f == 14))
    pts = [(r, c) for r, c in zip(rs, cs) if 5 <= r <= 53 and 9 <= c <= 47]
    if pts: out['creature'] = min(pts)
    rs, cs = np.where((f == 0) | (f == 1))
    pts = [(r,c) for r,c in zip(rs,cs) if 5 <= r <= 53 and 9 <= c <= 47]
    # cluster digit glyphs by row band
    bands = {}
    for r,c in pts:
        bands.setdefault(r//5, []).append((r,c))
    for k,v in bands.items():
        out[f'digit_band{k}'] = min(v)
    return out

c = env.clone()
print(0, find_objs(f0))
seq = []
for i in range(30):
    a = 1 if i % 2 == 0 else 2
    f = np.array(c.step(a))
    print(i+1, 'act', a, find_objs(f))
EOF
