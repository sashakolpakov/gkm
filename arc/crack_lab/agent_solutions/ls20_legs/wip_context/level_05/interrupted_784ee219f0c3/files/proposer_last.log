import sys; sys.path.insert(0,'/tmp')
from lib5 import *
from collections import deque
env=get_env5()
BOXES=[(6,45),(11,10),(46,15)]
def block(f):
    ys,xs=np.where(f==12); s=set(zip(ys.tolist(),xs.tolist()))
    for (y,x) in sorted(s):
        if all((y+dy,x+dx) in s for dy in range(2) for dx in range(5)) and all(f[y+2+dy,x+dx]==9 for dy in range(3) for dx in range(5)):
            return (y,x)
    return None
def boxsig(f): return tuple(int((f[y:y+3,x:x+3]==11).sum()) for (y,x) in BOXES)
def gaugecells(f): 
    # nonbackground cells in gauge box
    reg=f[53:61,1:11]
    from collections import Counter
    return dict(Counter(reg.flatten().tolist()))
# BFS to first box collection
start=env.clone()
seen={block(start.frame())}
q=deque([(start,[])]); 
res=None
while q and not res:
    node,path=q.popleft()
    for a in (1,2,3,4):
        c=node.clone()
        if c.terminal(): continue
        c.step(a)
        if boxsig(c.frame())!=(8,8,8):
            res=(path+[a],c); break
        p=block(c.frame())
        if p and p not in seen: seen.add(p); q.append((c,path+[a]))
path,c=res
print("path to first box collect:",path)
print("boxsig now",boxsig(c.frame()))
print("gauge before:",gaugecells(start.frame()))
print("gauge after :",gaugecells(c.frame()))
# continue: collect all boxes, watch gauge
cur=c
for target in range(2):
    seen={block(cur.frame())}; q=deque([(cur,[])]); r=None; bs0=boxsig(cur.frame())
    while q and not r:
        node,path=q.popleft()
        for a in (1,2,3,4):
            cc=node.clone()
            if cc.terminal(): continue
            cc.step(a)
            if boxsig(cc.frame())!=bs0: r=(path+[a],cc); break
            p=block(cc.frame())
            if p and p not in seen: seen.add(p); q.append((cc,path+[a]))
    if not r: print("cannot collect more"); break
    path,cur=r
    print("collected another, boxsig",boxsig(cur.frame()),"gauge",gaugecells(cur.frame()),"lvl",cur.levels_completed,"term",cur.terminal())
