import legs
from collections import deque
import json
env=get_env5()
mask=legs.detect_noise_mask(env)
base=env.levels_completed
start=env.clone()
def key(f): 
    g=f.copy(); g[mask]=-1; return g.tobytes()
seen={key(start.frame())}
q=deque([(start,[])])
t0=time.time(); expanded=0; win=None
while q:
    node,path=q.popleft(); expanded+=1
    for a in (1,2,3,4):
        c=node.clone()
        try: c.step(a)
        except Exception: continue
        if c.terminal():
            # dead state, don't expand
            if c.levels_completed>base:
                win=path+[a]; break
            continue
        if c.levels_completed>base:
            win=path+[a]; break
        k=key(c.frame())
        if k not in seen:
            seen.add(k); q.append((c,path+[a]))
    if win: break
    if expanded%500==0:
        print(f"expanded={expanded} seen={len(seen)} depth={len(path)} t={time.time()-t0:.0f}s",flush=True)
    if len(seen)>40000 or time.time()-t0>1400: 
        print("cap hit"); break
if win:
    print("WIN len",len(win),win)
    json.dump(win,open('/tmp/win5.json','w'))
else:
    print("no win, seen",len(seen))
