import sys, time; sys.path.insert(0,'/tmp')
from lib5 import *
env=get_env5()
def blockpos(f):
    # find 2x5 horizontal 12-bar with 9s below => moving block top-left
    ys,xs=np.where(f==12)
    from collections import defaultdict
    s=set(zip(ys.tolist(),xs.tolist()))
    for (y,x) in sorted(s):
        # candidate top-left of 2x5 of 12
        if all((y+dy,x+dx) in s for dy in range(2) for dx in range(5)):
            # check 9s below
            below9=all(f[y+2+dy,x+dx]==9 for dy in range(3) for dx in range(5))
            if below9:
                return (y,x)
    return None
f0=env.frame()
print("start blockpos",blockpos(f0))
# BFS on block position
from collections import deque
start=env.clone()
p0=blockpos(start.frame())
seen={p0}
q=deque([(start,[])])
base=env.levels_completed
t=time.time()
steps=0
win=None
while q:
    node,path=q.popleft()
    for a in (1,2,3,4):
        c=node.clone(); c.step(a); steps+=1
        if c.levels_completed>base:
            win=path+[a]; break
        p=blockpos(c.frame())
        if p is None:  # block vanished? treat as terminal-ish, skip
            continue
        if p not in seen:
            seen.add(p); q.append((c,path+[a]))
    if win: break
    if len(seen)>=4000: break
print("win",win,"positions",len(seen),"steps",steps,"time",round(time.time()-t,1))
# print reachable positions extent
ys=[p[0] for p in seen]; xs=[p[1] for p in seen]
print("y range",min(ys),max(ys),"x range",min(xs),max(xs))
EOF
