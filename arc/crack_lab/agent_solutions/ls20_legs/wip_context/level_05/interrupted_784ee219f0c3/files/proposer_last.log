import sys,time,json,heapq; sys.path.insert(0,'/tmp')
sys.path.insert(0,'/private/tmp/claude-501/-Users-sasha-gkm/e3e00be1-d1a5-4095-a6ef-4d720f42d84e/scratchpad/gkm_legs_ws_ls20_sonnetfresh')
from lib5 import *
import legs
env=get_env5()
mask=legs.detect_noise_mask(env)
BOXES=[(6,45),(11,10),(46,15)]
def boxes_left(f): return sum(1 for (y,x) in BOXES if (f[y:y+3,x:x+3]==11).sum()>=6)
def gauge12(f): return int((f[53:61,1:11]==12).sum())
def gauge14(f): return int((f[53:61,1:11]==14).sum())
def gauge9(f): return int((f[53:61,1:11]==9).sum())
def prog(f):
    return (3-boxes_left(f))*1000 + gauge14(f)*10 + gauge12(f) + gauge9(f)*5
def mkey(f): g=f.copy(); g[mask]=-1; return g.tobytes()
start=env.clone()
seen={mkey(start.frame())}
h0=-prog(start.frame())
cnt=0
pq=[(h0,cnt,start,[])]
t=time.time(); win=None; exp=0; bestprog=prog(start.frame())
while pq:
    hh,_,node,path=heapq.heappop(pq); exp+=1
    for a in (1,2,3,4):
        c=node.clone()
        if c.terminal(): continue
        c.step(a)
        if c.levels_completed>4: win=path+[a]; break
        if c.terminal(): continue
        f=c.frame(); k=mkey(f)
        if k not in seen:
            seen.add(k); cnt+=1
            p=prog(f)
            if p>bestprog: bestprog=p; print("newbest prog",p,"depth",len(path)+1,"boxesleft",boxes_left(f),"g12",gauge12(f),"g9",gauge9(f),"g14",gauge14(f),"exp",exp,flush=True)
            heapq.heappush(pq,(-p*1000 + (len(path)+1), cnt, c, path+[a]))
    if win: break
    if exp%2000==0: print("exp",exp,"seen",len(seen),"bestprog",bestprog,"t",round(time.time()-t),flush=True)
    if len(seen)>50000 or time.time()-t>1200: print("cap"); break
print("WIN",win)
if win: json.dump(win,open('/tmp/win5.json','w')); print("saved len",len(win))
