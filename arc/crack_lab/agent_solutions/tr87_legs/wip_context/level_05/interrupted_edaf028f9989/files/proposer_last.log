import sys, numpy as np
sys.path.insert(0,'/Users/sasha/gkm/arc/crack_lab'); sys.path.insert(0,'.')
import gkm_arena as A, players
env=A.Arena('tr87')
for k in range(1,5): getattr(players,f'play_level_{k}')(env)
def curs(c):
    f=c.frame(); ys,xs=np.where(f==0)
    if len(ys)==0: return None
    return (int(ys.min()),int(xs.min()),int(ys.max()),int(xs.max()))
c=env.clone()
seen=[]
for i in range(20):
    p=curs(c); seen.append(p)
    print(i,p)
    c.step(4)
    if curs(c)==seen[0] and i>0:
        print("wrap at",i+1); break
