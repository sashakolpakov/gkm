import sys, numpy as np
sys.path.insert(0,'/Users/sasha/gkm/arc/crack_lab'); sys.path.insert(0,'.')
import gkm_arena as A, players, perception as P
env=A.Arena('tr87')
for k in range(1,5): getattr(players,f'play_level_{k}')(env)
f=env.frame()
FG=5
def show_box(bbox):
    r0,c0,r1,c1=bbox
    n=(c1-c0+1)//7  # glyphs
    for g in range(n):
        gr0,gc0=r0+1,c0+1+7*g
        print(f"  glyph@({gr0},{gc0}):")
        for i in range(5):
            print("    "+''.join('#' if f[gr0+i,gc0+j]==FG else '.' for j in range(5)))
boxes=[b for b in P.connected_components(f,min_area=15) if b.color in (7,10) and (b.bbox[2]-b.bbox[0]+1)==7]
for b in sorted(boxes,key=lambda b:(b.bbox[0],b.bbox[1])):
    print(f"BOX color={b.color} bbox={b.bbox} width={b.bbox[3]-b.bbox[1]+1}")
    show_box(b.bbox)
EOF
