import sys, numpy as np
sys.path.insert(0,'/Users/sasha/gkm/arc/crack_lab'); sys.path.insert(0,'.')
import gkm_arena as A, players, legs
def fresh():
    env=A.Arena('tr87')
    for k in range(1,5): getattr(players,f'play_level_{k}')(env)
    return env
for name in ['discover_glyph_cipher_puzzle','discover_glyph_legend_puzzle','discover_glyph_compose_puzzle','discover_tile_cycle_puzzle','discover_glyph_tiles']:
    env=fresh()
    fn=getattr(legs,name)
    try:
        spec=fn(env)
        print(name, "->", type(spec).__name__ if spec is not None else None)
        if isinstance(spec,dict):
            for k,v in spec.items():
                if k=='f': continue
                print("   ",k,"=",v if not hasattr(v,'shape') else v.shape)
    except Exception as e:
        print(name,"ERR",repr(e))
EOF
