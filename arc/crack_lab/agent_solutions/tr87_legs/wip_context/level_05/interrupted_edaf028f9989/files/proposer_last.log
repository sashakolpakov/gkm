$ cd /Users/sasha/gkm/arc/crack_lab/runs/scratch/gkm_legs_ws_tr87_opus_complete && cat > /tmp/cycle.py <<'EOF'
import sys, numpy as np
sys.path.insert(0,'/Users/sasha/gkm/arc/crack_lab'); sys.path.insert(0,'.')
import gkm_arena as A, players
env=A.Arena('tr87')
for k in range(1,5): getattr(players,f'play_level_{k}')(env)
FG=5
def gly(c,gr0,gc0):
    f=c.frame()
    return tuple(tuple(1 if f[gr0+i,gc0+j]==FG else 0 for j in range(5)) for i in range(5))
def draw(g):
    return '\n'.join(''.join('#' if v else '.' for v in row) for row in g)
# tile0 A-box glyph @(11,9)
c=env.clone()
seen=[]
for i in range(12):
    g=gly(c,11,9)
    if g in seen:
        print("repeat at",i); break
    seen.append(g)
    c.step(1)
print("distinct glyphs in cycle:",len(seen))
for i,g in enumerate(seen):
    print("state",i); print(draw(g))
EOF
