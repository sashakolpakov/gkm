import sys, json
sys.path.insert(0, '/Users/sasha/gkm/arc/crack_lab')
import gkm_arena as A
import numpy as np
import perception as P
from collections import Counter
import legs
from legs import action_bbox

with open("checkpoint.json") as f:
    ck = json.load(f)
env = A.Arena('tr87')
for a in ck["final_path"]:
    env.step(a)
f = np.asarray(env.frame())

spec0 = legs.discover_tile_cycle_puzzle(env)
edit, move = spec0["edit"], spec0["move"]
ebb = action_bbox(env, edit)
print("ebb", ebb)
r0,c0,r1,c1 = ebb
gh,gw = r1-r0+1, c1-c0+1
pitch = gw+2
print("gh,gw,pitch", gh,gw,pitch)

# ring color -> VAL (editable border)
ring=[]
for c in range(c0-1,c1+2):
    ring.append(int(f[r0-1,c])); ring.append(int(f[r1+1,c]))
for r in range(r0-1,r1+2):
    ring.append(int(f[r,c0-1])); ring.append(int(f[r,c1+1]))
VAL = Counter(ring).most_common(1)[0][0]
inside = f[r0:r1+1,c0:c1+1]
FG = [int(v) for v in np.unique(inside) if int(v)!=VAL][0]
print("VAL(editable border)=",VAL,"FG=",FG)

# bordered boxes height gh+2
blobs = P.connected_components(f, min_area=15)
tall = [b for b in blobs if (b.bbox[2]-b.bbox[0]+1)==gh+2]
colors = Counter(b.color for b in tall)
print("tall box colors:", colors)
KEYCOLOR = [c for c in colors if c!=VAL][0]
print("KEYCOLOR", KEYCOLOR, "VALCOLOR", VAL)

def contains(b, bb):
    R0,C0,R1,C1 = b.bbox
    return R0<=bb[0] and R1>=bb[2] and C0<=bb[1] and C1>=bb[3]
editbox = [b for b in tall if b.color==VAL and contains(b, ebb)][0]
print("editbox bbox", editbox.bbox)

keyboxes = [b for b in tall if b.color==KEYCOLOR]
valboxes = [b for b in tall if b.color==VAL and b is not editbox]
# pair
pairs=[]
unpaired=[]
for kb in keyboxes:
    R0,C0,R1,C1 = kb.bbox
    cands = [v for v in valboxes if v.bbox[0]==R0 and v.bbox[1]>C1]
    cands.sort(key=lambda v: v.bbox[1]-C1)
    if cands: pairs.append((kb,cands[0]))
    else: unpaired.append(kb)
print("num pairs", len(pairs), "unpaired keys", [u.bbox for u in unpaired])
