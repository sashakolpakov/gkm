import pickle
d = pickle.load(open("l3.pkl","rb"))
keys=d["keys"]; vals=d["vals"]; target=d["target"]; tiles=d["tiles"]

# unique canonical glyph inventory
allg = set()
for k in keys: allg|=set(k)
for v in vals: allg|=set(v)
allg|=set(target); allg|=set(tiles)
print("distinct canonical glyphs:", len(allg))

# label glyphs
labels = {g:i for i,g in enumerate(sorted(allg))}
def lab(seq): return [labels[g] for g in seq]
print("keys:", [lab(k) for k in keys])
print("vals:", [lab(v) for v in vals])
print("target:", lab(target))
print("tiles :", lab(tiles))

# DP parse target into keys
import functools
keyseq = [tuple(k) for k in keys]
tgt = tuple(target)
n=len(tgt)
# find segmentation
from functools import lru_cache
sols=[]
def rec(i, acc):
    if i==n:
        sols.append(list(acc)); return
    for ki,k in enumerate(keyseq):
        L=len(k)
        if tgt[i:i+L]==k:
            rec(i+L, acc+[ki])
rec(0,[])
print("num segmentations:", len(sols))
for s in sols:
    out=[]
    for ki in s: out+= vals[ki]
    print("seg keys", s, "-> val len", len(out), "labels", [labels[g] for g in out])
