import sys, json
sys.path.insert(0, '/Users/sasha/gkm/arc/crack_lab')
import gkm_arena as A
import numpy as np
import perception as P
from legs import _glyph, _glyph_canon

with open("checkpoint.json") as f:
    ck = json.load(f)
env = A.Arena('tr87')
for a in ck["final_path"]:
    env.step(a)
f = np.asarray(env.frame())
FG=5

def box_glyphs(bbox):
    r0,c0,r1,c1 = bbox
    k = (c1-c0+1)//7
    return [_glyph(f, r0+1, c0+1+7*g, 5,5,FG) for g in range(k)]

# Legend entries: (key_bbox, val_bbox)
legend = [
    ((4,5,10,11),(4,15,10,21)),
    ((4,28,10,41),(4,45,10,58)),
    ((13,5,19,11),(13,15,19,28)),
    ((13,35,19,48),(13,52,19,58)),
    ((22,5,28,25),(22,29,28,35)),
    ((22,42,28,48),(22,52,28,58)),
]
keys=[]
vals=[]
for kb,vb in legend:
    kg = box_glyphs(kb); vg = box_glyphs(vb)
    keys.append([_glyph_canon(g) for g in kg])
    vals.append([_glyph_canon(g) for g in vg])
    print("KEY len",len(kg),"-> VAL len",len(vg))

target = box_glyphs((40,4,46,59))
target_c = [_glyph_canon(g) for g in target]
print("target len", len(target_c))

tiles = box_glyphs((51,7,57,55))
tiles_c = [_glyph_canon(g) for g in tiles]
print("tiles (current) len", len(tiles_c))

# save for parsing
import pickle
pickle.dump(dict(keys=keys,vals=vals,target=target_c,tiles=tiles_c), open("l3.pkl","wb"))
