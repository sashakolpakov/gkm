import sys, json
sys.path.insert(0, '/Users/sasha/gkm/arc/crack_lab')
import gkm_arena as A
import numpy as np
import legs
from legs import _glyph, _glyph_canon, plan_glyph_cipher, replay_for_reward

def make_env():
    with open("checkpoint.json") as f:
        ck = json.load(f)
    env = A.Arena('tr87')
    for a in ck["final_path"]:
        env.step(a)
    return env

env = make_env()
f = np.asarray(env.frame())
FG=5
def box_glyphs(bbox):
    r0,c0,r1,c1 = bbox
    k = (c1-c0+1)//7
    return [_glyph_canon(_glyph(f, r0+1, c0+1+7*g, 5,5,FG)) for g in range(k)]

legend = [
    ((4,5,10,11),(4,15,10,21)),
    ((4,28,10,41),(4,45,10,58)),
    ((13,5,19,11),(13,15,19,28)),
    ((13,35,19,48),(13,52,19,58)),
    ((22,5,28,25),(22,29,28,35)),
    ((22,42,28,48),(22,52,28,58)),
]
keys=[tuple(box_glyphs(kb)) for kb,vb in legend]
vals=[box_glyphs(vb) for kb,vb in legend]
target=tuple(box_glyphs((40,4,46,59)))

# DP segment
sols=[]
def rec(i,acc):
    if i==len(target): sols.append(acc[:]); return
    for ki,k in enumerate(keys):
        if target[i:i+len(k)]==k: rec(i+len(k), acc+[ki])
rec(0,[])
assert len(sols)==1, len(sols)
seq_canon=[]
for ki in sols[0]:
    seq_canon += vals[ki]
print("seq_canon len", len(seq_canon))

spec = dict(edit=1, move=4, n_tiles=7, cycle=7, gh=5, gw=5, pitch=7, fg=5,
            editreg=(51,7,57,55), seq_canon=seq_canon)
path = plan_glyph_cipher(env, spec)
print("plan path:", path, "len", len(path))
ok = replay_for_reward(env, path)
print("replay_for_reward ->", ok, "levels_completed", env.levels_completed)
