import sys, time
sys.path.insert(0, '/Users/sasha/gkm/arc/crack_lab')
sys.path.insert(0, '.')
import gkm_arena as A
import perception as P
import numpy as np

def discover(env):
    acts=list(env.actions)
    base=np.asarray(env.frame())
    dwidth={}; dbbox={}
    for a in acts:
        c=env.clone(); c.step(a); d=P.frame_delta(base,c.frame())
        bb=d['bbox']
        dwidth[a]= (bb[3]-bb[1]+1) if bb else 0
        dbbox[a]=bb
    # edit actions: nonzero change, small width (<=8) & bbox present
    edits=[a for a in acts if dbbox[a] and dwidth[a]<=8 and (dbbox[a][2]-dbbox[a][0]+1)<=8]
    moves=[a for a in acts if a not in edits and dbbox[a]]
    # forward move = smallest width among moves
    move=min(moves,key=lambda a:dwidth[a])
    edit=edits[0]
    # discover n_tiles: cycle move, track edit-delta left col
    def editbbox(c):
        b=np.asarray(c.frame()); cc=c.clone(); cc.step(edit)
        return P.frame_delta(b, cc.frame())['bbox']
    cols=[]; c=env.clone()
    for k in range(12):
        bb=editbbox(c)
        cols.append(bb[1] if bb else None)
        c.step(move)
    # find period
    first=cols[0]; n=None
    for k in range(1,len(cols)):
        if cols[k]==first: n=k; break
    if n is None: n=len(cols)
    # cycle_len: apply edit repeatedly, detect frame period on edit region
    c=env.clone()
    seen=[]; 
    def key(c): 
        b=np.asarray(c.frame()); r0,c0,r1,c1=dbbox[edit]; return b[r0:r1+1,c0:c1+1].tobytes()
    k0=key(c); seen=[k0]; cyc=None
    for k in range(1,15):
        c.step(edit); kk=key(c)
        if kk==k0: cyc=k; break
        seen.append(kk)
    if cyc is None: cyc=len(seen)
    return edit, move, n, cyc

def search(env, edit, move, n, cyc, budget=240):
    t0=time.time(); found=[None]
    def rec(clone, ti, path):
        if found[0] is not None or time.time()-t0>budget: return
        if clone.levels_completed>0:
            found[0]=path; return
        if ti==n: return
        for s in range(cyc):
            c=clone.clone(); p=path+[edit]*s
            for _ in range(s): c.step(edit)
            if c.levels_completed>0: found[0]=p; return
            if ti<n-1:
                c.step(move); rec(c, ti+1, p+[move])
            if found[0] is not None: return
    rec(env.clone(), 0, [])
    return found[0]

def prog(env):
    e,m,n,cyc=discover(env)
    print("discovered edit",e,"move",m,"n_tiles",n,"cycle",cyc)
    path=search(env,e,m,n,cyc)
    print("path found len", None if path is None else len(path))
    if path:
        c=env.clone()
        for a in path: c.step(a)
        print("replay lc",c.levels_completed)
    raise SystemExit
try:
    A.run_program('tr87', prog)
except SystemExit:
    pass
