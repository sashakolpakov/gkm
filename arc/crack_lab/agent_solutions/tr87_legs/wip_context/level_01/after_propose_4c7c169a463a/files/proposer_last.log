import sys
sys.path.insert(0, '/Users/sasha/gkm/arc/crack_lab')
sys.path.insert(0, '.')
import gkm_arena as A
import numpy as np
TCOLS=[15,22,29,36,43]
def tp(f,rb,c0): return "".join('1' if f[rb+i,c0+j]==5 else '0' for i in range(5) for j in range(5))
def curp(f,ti): return tp(f,52,TCOLS[ti])
def tgtp(f,ti): return tp(f,41,TCOLS[ti])

def prog(env):
    f0=np.asarray(env.frame())
    targets=[tgtp(f0,i) for i in range(5)]
    # get each tile's cycle (list) starting from current state
    cycles=[]
    for ti in range(5):
        c=env.clone()
        for _ in range(ti): c.step(4)
        seq=[curp(np.asarray(c.frame()),ti)]
        for _ in range(6):
            c.step(1); seq.append(curp(np.asarray(c.frame()),ti))
        cycles.append(seq)
    # for each tile pick pattern with max overlap to target
    def overlap(a,b): return sum(x==y for x,y in zip(a,b))
    best=[]
    for ti in range(5):
        ovs=[overlap(p,targets[ti]) for p in cycles[ti]]
        bi=int(np.argmax(ovs))
        best.append((bi,ovs[bi]))
    print("best per tile (upcount, overlap/25):",best)
    # drive env: cursor starts at tile0. Move right to tile i, press up bi times.
    # Need cursor management. cursor pos tracking:
    pos=0
    def goto(ti):
        nonlocal pos
        while pos!=ti:
            env.step(4); pos=(pos+1)%5
    for ti in range(5):
        goto(ti)
        for _ in range(best[ti][0]): env.step(1)
    f=np.asarray(env.frame())
    print("levels_completed:",env.levels_completed)
    # show resulting overlaps
    for ti in range(5):
        print("tile",ti,"cur=",curp(f,ti),"tgt=",tgtp(f,ti),"match",sum(x==y for x,y in zip(curp(f,ti),tgtp(f,ti))))
    raise SystemExit
try:
    A.run_program('tr87', prog)
except SystemExit:
    pass
