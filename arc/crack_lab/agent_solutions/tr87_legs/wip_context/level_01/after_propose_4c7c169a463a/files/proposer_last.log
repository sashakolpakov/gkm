import sys
sys.path.insert(0, '/Users/sasha/gkm/arc/crack_lab')
sys.path.insert(0, '.')
import gkm_arena as A
import numpy as np
import itertools
TCOLS=[15,22,29,36,43]
def tp(f,rb,c0): return "".join('1' if f[rb+i,c0+j]==5 else '0' for i in range(5) for j in range(5))
def curp(f,ti): return tp(f,52,TCOLS[ti])

boxes7=["1111010011100011100101111","1111010010100111001011110","1111110010100101111010000","0011100101111111010011100","1111110001101111010111111","0010011111101011111100100"]

def prog(env):
    # precompute per-tile cycle lists (pattern->upcount from initial)
    cycles=[]
    for ti in range(5):
        c=env.clone()
        for _ in range(ti): c.step(4)
        seq=[curp(np.asarray(c.frame()),ti)]
        for _ in range(6):
            c.step(1); seq.append(curp(np.asarray(c.frame()),ti))
        cycles.append(seq)
    def upcount(ti,pat):
        return cycles[ti].index(pat) if pat in cycles[ti] else None
    # reachable box options per tile
    opts=[]
    for ti in range(5):
        opts.append([bi for bi in range(6) if boxes7[bi] in cycles[ti]])
    print("opts per tile:",opts)
    def test(config):
        # config: list of box index per tile
        c=env.clone(); pos=0
        for ti in range(5):
            while pos!=ti: c.step(4); pos=(pos+1)%5
            uc=upcount(ti,boxes7[config[ti]])
            for _ in range(uc): c.step(1)
        return c.levels_completed, c.terminal()
