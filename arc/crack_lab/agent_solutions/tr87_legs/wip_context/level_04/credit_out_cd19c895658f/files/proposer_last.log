import sys, json
sys.path.insert(0, "/Users/sasha/gkm/arc/crack_lab"); sys.path.insert(0, ".")
import gkm_arena as A
import numpy as np
env = A.Arena('tr87')
ck = json.load(open('checkpoint.json'))
for a in ck['final_path']:
    env.step(a)
chars = {0:'.',1:'#',2:' ',3:'o',5:'*',7:'+',10:'x',11:'K'}
def show(f, r0,r1,c0,c1):
    for r in range(r0,r1):
        print(''.join(chars.get(int(v),'?') for v in f[r,c0:c1]))
base = np.asarray(env.frame())
for act in env.actions:
    c = env.clone(); c.step(act)
    f2 = np.asarray(c.frame())
    ys,xs = np.where(base!=f2)
    print(f"=== action {act}: changed {len(ys)} cells, rows {ys.min()}-{ys.max()} cols {xs.min()}-{xs.max()} ===")
    show(f2, ys.min(), ys.max()+1, xs.min(), xs.max()+1)
    print("--- was ---")
    show(base, ys.min(), ys.max()+1, xs.min(), xs.max()+1)
EOF
