import sys, json
sys.path.insert(0, "/Users/sasha/gkm/arc/crack_lab"); sys.path.insert(0, ".")
import gkm_arena as A
import numpy as np
import perception as P
import legs
env = A.Arena('tr87')
ck = json.load(open('checkpoint.json'))
for a in ck['final_path']:
    env.step(a)
f = np.asarray(env.frame())
blobs = P.connected_components(f, min_area=10)
boxes = [b for b in blobs if b.color in (7,10,11) and (b.bbox[2]-b.bbox[0]+1)==7 and (b.bbox[3]-b.bbox[1]+1)==7]
def gkey(b):
    r0,c0=b.bbox[0],b.bbox[1]
    g=legs._glyph(f, r0+1, c0+1, 5,5,5)
    return legs._glyph_canon(g)
# group by row
from collections import defaultdict
rows=defaultdict(list)
for b in boxes:
    rows[b.bbox[0]].append(b)
gid={}
def gname(cg):
    if cg not in gid: gid[cg]=len(gid)
    return gid[cg]
for r in sorted(rows):
    bs=sorted(rows[r], key=lambda b:b.bbox[1])
    print("row",r, [(b.bbox[1], b.color, gname(gkey(b))) for b in bs])
# word box (x-box color10 wide) and edit box (K color11 wide)
wide=[b for b in blobs if (b.bbox[3]-b.bbox[1]+1)>40]
for b in wide:
    r0,c0,r1,c1=b.bbox
    n=(c1-c0+1)//7
    gs=[gname(legs._glyph_canon(legs._glyph(f,r0+1,c0+1+7*i,5,5,5))) for i in range(n)]
    print("wide color",b.color,"bbox",b.bbox,"glyphs",gs)
EOF
