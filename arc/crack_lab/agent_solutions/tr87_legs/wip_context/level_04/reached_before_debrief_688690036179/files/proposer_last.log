import legs as L
import numpy as np
f = np.load('/tmp/lvl4.npy')

# A-word: border10 rows40-46 cols7-55, 7 glyphs pitch7 starting c0+1=8
Aword = L._box_glyphs(f,(40,7,46,55),5,5,7,5)
Bword = L._box_glyphs(f,(51,7,57,55),5,5,7,5)
Acanon = [L._glyph_canon(g) for g in Aword]
Bcanon = [L._glyph_canon(g) for g in Bword]
print("A canon:", [hash(x)%100000 for x in Acanon])
print("B canon:", [hash(x)%100000 for x in Bcanon])

# Legends
legY = {}  # 10->7  key canon -> val canon
legX = {}  # 7->11  key canon -> val canon
pairs = [
 ((3,12),(3,22),7,11),
 ((3,35),(3,45),10,7),
 ((11,12),(11,22),10,7),
 ((11,35),(11,45),7,11),
 ((19,12),(19,22),7,11),
 ((19,35),(19,45),10,7),
 ((27,12),(27,22),10,7),
 ((27,35),(27,45),7,11),
]
for (kr,kc),(vr,vc),kb,vb in pairs:
    kg = L._glyph_canon(L._glyph(f,kr+1,kc+1,5,5,5))
    vg = L._glyph_canon(L._glyph(f,vr+1,vc+1,5,5,5))
    if kb==10 and vb==7:
        legY[kg]=vg
    elif kb==7 and vb==11:
        legX[kg]=vg
print("legY size",len(legY),"legX size",len(legX))

# translate A-word via Y then X
ok=True
target=[]
for i,a in enumerate(Acanon):
