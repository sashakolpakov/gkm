# verify a general chain-based discovery reproduces the target
import sys, os, json
sys.path.insert(0, os.getcwd())
sys.path.insert(0, '/Users/sasha/gkm/arc/crack_lab')
import legs as L, perception as P
import numpy as np
f = np.load('/tmp/lvl4.npy')
gh=gw=5; pitch=7; FG=5; VAL=11
blobs=P.connected_components(f,min_area=15)
tall=[b for b in blobs if (b.bbox[2]-b.bbox[0]+1)==gh+2]
wide=[b for b in tall if (b.bbox[3]-b.bbox[1]+1)>pitch]
small=[b for b in tall if (b.bbox[3]-b.bbox[1]+1)==pitch]
editbox=[b for b in wide if b.color==VAL][0]
srcbox=[b for b in wide if b is not editbox][0]
SRC=srcbox.color
print("SRC",SRC,"VAL",VAL, "wide", [(b.color,b.bbox) for b in wide])
# group small boxes by row, pair consecutively
from collections import defaultdict
rows=defaultdict(list)
for b in small: rows[b.bbox[0]].append(b)
maps={}
for r in sorted(rows):
    bs=sorted(rows[r], key=lambda b:b.bbox[1])
    for i in range(0,len(bs)-1,2):
        kb,vb=bs[i],bs[i+1]
        kc=L._glyph_canon(L._glyph(f,kb.bbox[0]+1,kb.bbox[1]+1,gh,gw,FG))
        vc=L._glyph_canon(L._glyph(f,vb.bbox[0]+1,vb.bbox[1]+1,gh,gw,FG))
        key=kb.color
        if key not in maps: maps[key]=(vb.color,{})
        maps[key][1][kc]=vc
print("map borders:", {k:v[0] for k,v in maps.items()})
# chain SRC->VAL
srcglyphs=[L._glyph_canon(g) for g in L._box_glyphs(f,srcbox.bbox,gh,gw,pitch,FG)]
target=[]
for g in srcglyphs:
    cur=SRC; cg=g
    while cur!=VAL:
        vb,m=maps[cur]; cg=m[cg]; cur=vb
    target.append(cg)
print("target:", [hash(x)%100000 for x in target])
EOF
