        print("A glyph",i,"not in legY"); ok=False; continue
    mid = legY[a]
    if mid not in legX:
        print("mid",i,"not in legX"); ok=False; continue
    target.append(legX[mid])
print("ok",ok)
print("target canon:", [hash(x)%100000 for x in target])
