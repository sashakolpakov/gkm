sys.path.insert(0,'/Users/sasha/gkm/arc/crack_lab')
import gkm_arena as A
import numpy as np, perception as P, legs

env=A.Arena('tr87')
for a in json.load(open('checkpoint.json'))['final_path']:
    env.step(a)
f=np.asarray(env.frame())
spec=legs.discover_tile_cycle_puzzle(env)
edit,move,n_tiles,cycle=spec['edit'],spec['move'],spec['n_tiles'],spec['cycle']
ebb=legs.action_bbox(env,edit); r0,c0,r1,c1=ebb
gh,gw=r1-r0+1,c1-c0+1
VAL=11; BOX=7; FG=5; PITCH=gw+2  #7

def glyph(fr,r,c,fg):
    return tuple(tuple(1 if fr[r+i,c+j]==fg else 0 for j in range(gw)) for i in range(gh))
def canon(g):
    a=np.array(g); best=None
    cur=a
    for _ in range(4):
        for m in (cur,cur[:,::-1]):
            t=tuple(map(tuple,m.tolist()))
            if best is None or t<best: best=t
        cur=np.rot90(cur)
    return best

blobs=P.connected_components(f,min_area=15)
boxes=[b for b in blobs if b.color==BOX and (b.bbox[2]-b.bbox[0]+1)==gh+2]
valregs=[b for b in blobs if b.color==VAL and (b.bbox[2]-b.bbox[0]+1)==gh+2]
# editable region = valreg containing ebb
def contains(b,bb):
    R0,C0,R1,C1=b.bbox; return R0<=bb[0] and R1>=bb[2] and C0<=bb[1] and C1>=bb[3]
editreg=[b for b in valregs if contains(b,ebb)][0]
legvals=[b for b in valregs if b is not editreg]
# key boxes = width 7 (single glyph); target box = wider
keyboxes=[b for b in boxes if (b.bbox[3]-b.bbox[1]+1)==PITCH]
targetboxes=[b for b in boxes if (b.bbox[3]-b.bbox[1]+1)>PITCH]
tb=targetboxes[0]
def box_glyphs(b):
    R0,C0,R1,C1=b.bbox; w=C1-C0+1; k=w//PITCH
    return [glyph(f,R0+1,C0+1+PITCH*g,FG) for g in range(k)]
keys=[box_glyphs(b)[0] for b in keyboxes]
# pair each key box with the val region on same rows, to its right, nearest
def pairval(kb):
    R0,C0,R1,C1=kb.bbox
    cands=[v for v in legvals if v.bbox[0]==R0 and v.bbox[1]>C1]
    cands.sort(key=lambda v:v.bbox[1]-C1)
    return cands[0]
keyvals=[box_glyphs(pairval(kb)) for kb in keyboxes]
keycanon=[canon(k) for k in keys]
targets=box_glyphs(tb)
seq=[]
for t in targets:
    ct=canon(t)
    ki=[i for i,kc in enumerate(keycanon) if kc==ct]
    assert len(ki)==1, (ki)
    seq.extend(keyvals[ki[0]])
print('seq len',len(seq),'n_tiles',n_tiles)
seqcanon=[canon(g) for g in seq]
# editable tiles positions from editreg
R0,C0,R1,C1=editreg.bbox
plan=[]
for ti in range(n_tiles):
    c=env.clone()
    for _ in range(ti): c.step(move)
    found=None
    for s in range(cycle):
        tg=glyph(np.asarray(c.frame()),R0+1,C0+1+PITCH*ti,FG)
        if canon(tg)==seqcanon[ti]:
            found=s;break
        c.step(edit)
    plan.append(found)
print('plan',plan)
