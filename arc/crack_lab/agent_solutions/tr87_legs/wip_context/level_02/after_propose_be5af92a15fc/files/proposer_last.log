def g(f,r0,c0):
    return tuple(tuple(1 if f[r0+i,c0+j]==5 else 0 for j in range(5)) for i in range(5))
def gn(f,r0,c0):
    return np.array([[1 if f[r0+i,c0+j]==5 else 0 for j in range(5)] for i in range(5)])
def norm(a): return tuple(map(tuple,a.tolist()))

# keys and their value bregs
boxes7=[(4,5),(13,5),(22,5),(4,28),(13,35),(22,42)]
Bregs=[(4,15,1),(13,15,2),(22,15,3),(4,38,3),(13,45,2),(22,52,1)]
