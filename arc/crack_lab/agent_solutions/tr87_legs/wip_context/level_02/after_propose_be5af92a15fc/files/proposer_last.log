def transforms(a):
    outs={}
    cur=a
    for i in range(4):
        outs['r%d'%(i*90)]=cur
        outs['r%df'%(i*90)]=cur[:,::-1]
        cur=np.rot90(cur)
    return outs
for ti,t in enumerate(targets):
    res=[]
    for ki,k in enumerate(keys):
        for tn,tt in transforms(t).items():
            if norm(tt)==norm(k):
                res.append((ki,tn))
