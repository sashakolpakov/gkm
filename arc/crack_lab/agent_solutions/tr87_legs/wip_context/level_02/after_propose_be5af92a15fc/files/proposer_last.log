import sys, json
sys.path.insert(0,'/Users/sasha/gkm/arc/crack_lab')
import gkm_arena as A
import numpy as np, perception as P

def geten():
    env=A.Arena('tr87')
    for a in json.load(open('checkpoint.json'))['final_path']:
        env.step(a)
    return env

env=geten()
f=env.frame()

def glyph(r0,c0):
    # 5x5 fg==5 at rows r0..r0+4, cols c0..c0+4
    return tuple(tuple(1 if f[r0+i,c0+j]==5 else 0 for j in range(5)) for i in range(5))

def region_glyphs(bbox):
    r0,c0,r1,c1=bbox
    w=c1-c0+1
    ng=(w+1)//7  # 7->1,14->2,21->3
    gs=[]
    gr0=r0+1
    for k in range(ng):
        gc0=c0+1+7*k
        gs.append(glyph(gr0,gc0))
    return gs

# 7-boxes = keys
boxes7=[(4,5,10,11),(13,5,19,11),(22,5,28,11),(4,28,10,34),(13,35,19,41),(22,42,28,48)]
Bregs=[(4,15,10,21),(13,15,19,28),(22,15,28,35),(4,38,10,58),(13,45,19,58),(22,52,28,58)]
keys=[region_glyphs(b)[0] for b in boxes7]
vals=[region_glyphs(b) for b in Bregs]
for i,(k,v) in enumerate(zip(keys,vals)):
    print('entry',i,'val_len',len(v))

# target box bottom (40,18)-(46,45), width 28 -> 4 glyphs, sep 2
tgt_bbox=(40,18,46,45)
r0,c0,r1,c1=tgt_bbox
targets=[glyph(r0+1,c0+1+7*k) for k in range(4)]
print('num targets',len(targets))

# match each target to a key
def show(g):
    return '\n'.join(''.join('#' if x else '.' for x in row) for row in g)
for ti,t in enumerate(targets):
    matches=[i for i,k in enumerate(keys) if k==t]
    print('target',ti,'matches key',matches)

# alphabet: cycle editable tile 0
def tileglyph(e,i):
    ff=e.frame(); c0=8+7*i
    return tuple(tuple(1 if ff[52+r,c0+j]==5 else 0 for j in range(5)) for r in range(5))
c=env.clone()
alphabet=[]
for s in range(7):
    alphabet.append(tileglyph(c,0))
    c.step(1)
print('alphabet size',len(alphabet), 'distinct', len(set(alphabet)))

# build target sequence
seq=[]
for t in targets:
    idx=[i for i,k in enumerate(keys) if k==t][0]
    seq.extend(vals[idx])
print('target sequence length',len(seq))
# map each to alphabet index
alpha_idx=[]
for g in seq:
    m=[i for i,a in enumerate(alphabet) if a==g]
    alpha_idx.append(m)
print('alpha indices per tile:',alpha_idx)
