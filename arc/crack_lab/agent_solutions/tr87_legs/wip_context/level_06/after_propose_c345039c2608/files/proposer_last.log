{"type":"item.completed","item":{"id":"item_15","type":"command_execution","command":"/bin/zsh -lc \"sed -n '612,805p' legs.py\"","aggregated_output":"def discover_glyph_legend_synthesis_puzzle(env):\n    \"\"\"Discover a puzzle where the legend itself is cursor-editable.\n\n    The cursor visits bordered key/value words.  Two fixed wide words below\n    them use the key and value border colours respectively.  Each editable\n    word cycles as a unit; the goal is to choose legend entries whose\n    substitution translates the fixed source word into the fixed target.\n    \"\"\"\n    from collections import defaultdict, Counter\n\n    f = np.asarray(env.frame())\n    actions = list(env.actions)\n    deltas = {}\n    for a in actions:\n        c = env.clone(); c.step(a)\n        deltas[a] = P.frame_delta(f, c.frame())\n\n    # Editing changes only the selected glyph interior; cursor moves alter a\n    # larger region around two boxes.  There may be forward/backward versions\n    # of each, so one representative of each affordance is enough.\n    edits = []\n    for a, d in deltas.items():\n        h, w = bbox_size(d[\"bbox\"])\n        if d[\"bbox\"] and h <= 8 and w <= 16:\n            edits.append(a)\n    moves = [a for a in actions if a not in edits and deltas[a][\"bbox\"]]\n    if not edits or not moves:\n        return None\n    edit, move = edits[0], moves[0]\n    gh = max(bbox_size(deltas[a][\"bbox\"])[0] for a in edits)\n    pitch = gh + 2\n\n    tall = [b for b in P.connected_components(f, min_area=15)\n            if bbox_size(b.bbox)[0] == pitch\n            and bbox_size(b.bbox)[1] % pitch == 0]\n    if not tall:\n        return None\n\n    def selected_box(state):\n        before = np.asarray(state.frame())\n        c = state.clone(); c.step(edit)\n        after = np.asarray(c.frame())\n        for b in tall:\n            r0, c0, r1, c1 = b.bbox\n            if np.any(before[r0 + 1:r1, c0 + 1:c1] !=\n                      after[r0 + 1:r1, c0 + 1:c1]):\n                return b.bbox\n        return None\n\n    first = selected_box(env)\n    if first is None:\n        return None\n    first_blob = next(b for b in tall if b.bbox == first)\n    r0, c0, r1, c1 = first\n    inside = f[r0 + 1:r1, c0 + 1:c1]\n    fg_counts = Counter(int(v) for v in inside.flat if int(v) != first_blob.color)\n    if not fg_counts:\n        return None\n    FG = fg_counts.most_common(1)[0][0]\n    gw = gh\n\n    def box_word(frame, bbox):\n        return tuple(_glyph_canon(g) for g in\n                     _box_glyphs(frame, bbox, gh, gw, pitch, FG))\n\n    # Traverse the cursor ring once.  At each box, observe its entire cycle on\n    # a private clone, leaving the traversal clone's configuration untouched.\n    nav = env.clone()\n    order, candidates = [], {}\n    for _ in range(len(tall) + 1):\n        bb = selected_box(nav)\n        if bb is None:\n            return None\n        if bb in candidates:\n            break\n        cyc = nav.clone()\n        start = box_word(np.asarray(cyc.frame()), bb)\n        words = [start]\n        for _ in range(1, 16):\n            cyc.step(edit)\n            word = box_word(np.asarray(cyc.frame()), bb)\n            if word == start:\n                break\n            words.append(word)\n        else:\n            return None\n        order.append(bb)\n        candidates[bb] = words\n        nav.step(move)\n    if selected_box(nav) != first or len(order) < 2:\n        return None\n\n    editable = [b for b in tall if b.bbox in candidates]\n    fixed = [b for b in tall if b.bbox not in candidates]\n\n    # Editable boxes occur as left-key/right-value pairs on each row.\n    rows = defaultdict(list)\n    for b in editable:\n        rows[b.bbox[0]].append(b)\n    pairs = []\n    for row in sorted(rows):\n        boxes = sorted(rows[row], key=lambda b: b.bbox[1])\n        if len(boxes) % 2:\n            return None\n        pairs.extend((boxes[i], boxes[i + 1]) for i in range(0, len(boxes), 2))\n    if not pairs:\n        return None\n\n    key_colors = Counter(k.color for k, _ in pairs)\n    val_colors = Counter(v.color for _, v in pairs)\n    KEY, VAL = key_colors.most_common(1)[0][0], val_colors.most_common(1)[0][0]\n    sources = [b for b in fixed if b.color == KEY]\n    targets = [b for b in fixed if b.color == VAL]\n    if len(sources) != 1 or len(targets) != 1:\n        return None\n    source = box_word(f, sources[0].bbox)\n    target = box_word(f, targets[0].bbox)\n\n    return {\"edit\": edit, \"move\": move, \"order\": order, \"pitch\": pitch,\n            \"candidates\": candidates, \"pairs\": pairs,\n            \"source\": source, \"target\": target}\n\n\ndef plan_glyph_legend_synthesis(env, spec):\n    \"\"\"Solve and clone-verify an editable legend synthesis specification.\n\n    Dense progress is the pair ``(source glyphs consumed, target glyphs\n    produced)`` by a candidate sequence of legend entries.  This reduces the\n    sparse-reward search to short segmentations plus per-box cycle lookups.\n    \"\"\"\n    pairs = spec[\"pairs\"]\n    source, target = spec[\"source\"], spec[\"target\"]\n    candidates = spec[\"candidates\"]\n    pitch = spec[\"pitch\"]\n    keylens = [bbox_size(k.bbox)[1] // pitch for k, _ in pairs]\n    vallens = [bbox_size(v.bbox)[1] // pitch for _, v in pairs]\n\n    sequences = []\n    def extend(si, ti, seq):\n        if si == len(source) and ti == len(target):\n            sequences.append(tuple(seq))\n            return\n        for ei, (nk, nv) in enumerate(zip(keylens, vallens)):\n            if si + nk <= len(source) and ti + nv <= len(target):\n                extend(si + nk, ti + nv, seq + [ei])\n    extend(0, 0, [])\n\n    for seq in sequences:\n        si = ti = 0\n        required = {}\n        consistent = True\n        for ei in seq:\n            kw = source[si:si + keylens[ei]]\n            vw = target[ti:ti + vallens[ei]]\n            if ei in required and required[ei] != (kw, vw):\n                consistent = False\n                break\n            required[ei] = (kw, vw)\n            si += keylens[ei]; ti += vallens[ei]\n        if not consistent:\n            continue\n\n        counts = {bb: 0 for bb in spec[\"order\"]}\n        for ei, (kw, vw) in required.items():\n            kb, vb = pairs[ei]\n            km = [i for i, w in enumerate(candidates[kb.bbox]) if w == kw]\n            vm = [i for i, w in enumerate(candidates[vb.bbox]) if w == vw]\n            if not km or not vm:\n                consistent = False\n                break\n            counts[kb.bbox], counts[vb.bbox] = km[0], vm[0]\n        if not consistent:\n            continue\n\n        path = []\n        for i, bb in enumerate(spec[\"order\"]):\n            path.extend([spec[\"edit\"]] * counts[bb])\n            if i + 1 < len(spec[\"order\"]):\n                path.append(spec[\"move\"])\n\n        # Reward is the final arbiter when more than one symbolic segmentation\n        # is reachable.  Return only the prefix that actually completes it.\n        trial, prefix = env.clone(), []\n        for action in path:\n            trial.step(action); prefix.append(action)\n            if trial.levels_completed > env.levels_completed:\n                return prefix\n    return None\n\n\ndef solve_glyph_legend_synthesis_puzzle(env):\n    \"\"\"Discover, symbolically plan, clone-verify, and replay a mutable legend.\"\"\"\n    return solve_by_clone_search(env, discover_glyph_legend_synthesis_puzzle,\n                                 search=plan_glyph_legend_synthesis)\n","exit_code":0,"status":"completed"}}
