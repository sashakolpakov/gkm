import sys
sys.path.insert(0, '/Users/sasha/gkm/arc/crack_lab')
import gkm_arena as A
import numpy as np
from scipy.ndimage import label

def detect(f):
    res={}
    m=(f==15)
    lab,n=label(m)
    for i in range(1,n+1):
        pts=np.argwhere(lab==i)
        cr=pts[:,0].mean(); cc=pts[:,1].mean()
        area=len(pts)
        # check neighbors
        # sample a border pixel neighbor colors
        # hollow? center pixel value
        ccr,ccc=int(round(cr)),int(round(cc))
        center_val=int(f[ccr,ccc]) if 0<=ccr<64 and 0<=ccc<64 else -1
        # neighbor colors around component
        neigh=set()
        for (r,c) in pts:
            for dr,dc in((1,0),(-1,0),(0,1),(0,-1)):
                rr,cc2=r+dr,c+dc
                if 0<=rr<64 and 0<=cc2<64 and lab[rr,cc2]==0:
                    neigh.add(int(f[rr,cc2]))
        has6 = (f[pts[:,0],pts[:,1]]==15).all() and (6 in [int(f[r,c]) for r,c in pts for dr,dc in((0,0),) ]) 
        # box detection: is there a 6 inside bbox
        r0,r1=pts[:,0].min(),pts[:,0].max(); c0,c1=pts[:,1].min(),pts[:,1].max()
        inside6 = (f[r0:r1+1,c0:c1+1]==6).any()
        res[i]={'area':area,'center':(ccr,ccc),'center_val':center_val,'neigh':neigh,'inside6':inside6,'bbox':(int(r0),int(c0),int(r1),int(c1))}
    return res

def main(env):
    f=np.asarray(env.frame())
    import pprint; pprint.pprint(detect(f))
