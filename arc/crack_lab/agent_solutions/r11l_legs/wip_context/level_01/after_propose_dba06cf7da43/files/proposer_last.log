import sys
sys.path.insert(0, '/Users/sasha/gkm/arc/crack_lab')
import gkm_arena as A
import numpy as np

def neigh_colors(f,r,c):
    s=set()
    for dr,dc in((1,0),(-1,0),(0,1),(0,-1)):
        rr,cc=r+dr,c+dc
        if 0<=rr<64 and 0<=cc<64: s.add(int(f[rr,cc]))
    return s

def detect(f):
    cursor=threeD=None; ringpts=[]
    for (r,c) in np.argwhere(f==15):
        nc=neigh_colors(f,r,c)
        if 0 in nc: cursor=(int(r),int(c))
        elif 3 in nc: threeD=(int(r),int(c))
        elif nc<= {5}: ringpts.append((r,c))
    ring=None
    if ringpts:
        rr=int(round(np.mean([p[0] for p in ringpts])))
        cc=int(round(np.mean([p[1] for p in ringpts])))
        ring=(rr,cc)
    return cursor,threeD,ring

def main(env):
    f=np.asarray(env.frame())
    print("cursor,threeD,ring=",detect(f))
levels, path, err = A.run_program('r11l', main)
