import sys, traceback
sys.path.insert(0, '/Users/sasha/gkm/arc/crack_lab')
import gkm_arena as A
import numpy as np, perception as P
from legs import place_box_on_ring, _arr
from probe24 import boxpos, active, init_eps, drive

def canmove(env,frm,dst):
    c=env.clone(); c.step(6,frm[1],frm[0]); c.step(6,dst[1],dst[0])
    return active(_arr(c))==(dst[0],dst[1])

def offset_patterns(n):
    pats=[]
    if n==2:
        for a in range(3,11):
            pats += [[(-a,0),(a,0)],[(0,-a),(0,a)],[(-a,-a),(a,a)],[(-a,a),(a,-a)],[(-a,-1),(a,1)]]
    elif n==3:
        for k in range(3,9):
            pats += [[(-2*k,0),(k,-k),(k,k)],[(2*k,0),(-k,-k),(-k,k)],
                     [(0,-2*k),(-k,k),(k,k)],[(0,2*k),(-k,-k),(k,-k)],
                     [(-k,-k),(k,k),(0,0)] , [(-k,0),(k,-k),(0,k)]]
    else:
        for a in range(3,9):
            pats += [[(0,0)]*(n-1)+[(0,0)]]
    return pats

def snap(c, eps, color, T):
    if boxpos(_arr(c),color)==T: return True
    n=len(eps[color])
    for pat in offset_patterns(n):
        # verify sum zero -> centroid T
        sr=sum(o[0] for o in pat); sc=sum(o[1] for o in pat)
        # test on clone
        tc=c.clone(); teps=[list(x) for x in eps[color]]; ok=True
        for i,o in enumerate(pat):
            dst=(T[0]+o[0], T[1]+o[1])
            if not(0<=dst[0]<64 and 0<=dst[1]<64): ok=False; break
            frm=tuple(teps[i])
            if frm==dst: continue
            if not canmove(tc,frm,dst): ok=False; break
            tc.step(6,frm[1],frm[0]); tc.step(6,dst[1],dst[0]); teps[i]=list(dst)
        if ok and boxpos(_arr(tc),color)==T:
            # commit on real c
            for i,o in enumerate(pat):
                dst=(T[0]+o[0], T[1]+o[1]); frm=tuple(eps[color][i])
                if frm==dst: continue
                c.step(6,frm[1],frm[0]); c.step(6,dst[1],dst[0]); eps[color][i]=dst
            return True
    return False

def solve_ring(c, eps, color, T):
    drive(c,eps,color,T,iters=120)
    if boxpos(_arr(c),color)==T: return True
    return snap(c,eps,color,T)

def solver(env):
    try:
        place_box_on_ring(env)
        c=env.clone()
        eps=init_eps(_arr(c))
        r1=solve_ring(c,eps,12,(51,40)); print("box12",boxpos(_arr(c),12),"ok",r1,"lvl",c.levels_completed,flush=True)
        r2=solve_ring(c,eps,15,(18,57)); print("box15",boxpos(_arr(c),15),"ok",r2,"lvl",c.levels_completed,"term",c.terminal(),flush=True)
    except Exception: traceback.print_exc()
A.run_program('r11l', solver)
