                nb=set()
                for dr in(-1,0,1):
                    for dc in(-1,0,1):
                        rr,cc=r+dr,c+dc
                        if 0<=rr<64 and 0<=cc<64: nb.add(int(f[rr,cc]))
                if 0 in nb: return (r,c)
    return None
def canmove(env,frm,dst):
