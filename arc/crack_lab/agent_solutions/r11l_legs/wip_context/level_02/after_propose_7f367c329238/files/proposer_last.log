                for dc in(-1,0,1):
                    rr,cc=r+dr,c+dc
                    if 0<=rr<64 and 0<=cc<64: nb.add(int(f[rr,cc]))
            if 0 in nb or 3 in nb: d[color].append((r,c))
    return d

def drive(c, eps, color, T, iters=60):
    def cur(): return boxpos(_arr(c),color)
    best_seen=99
    for it in range(iters):
        b=cur()
        if b==T: return b
        cand=[]
        for i,e in enumerate(eps[color]):
            dsts=set()
            for frac in (1.0,.8,.6,.45,.3,.2,.12,.07):
                dsts.add((int(round(e[0]+(T[0]-e[0])*frac)), int(round(e[1]+(T[1]-e[1])*frac))))
            # ring straddle offsets
            for dr,dc in [(-5,0),(5,0),(0,-5),(0,5),(-4,-4),(4,4),(-4,4),(4,-4),(-7,0),(7,0),(0,-7),(0,7)]:
                dsts.add((T[0]+dr,T[1]+dc))
