import gkm_arena as A
import numpy as np
from legs import place_box_on_ring, _arr
import perception as P
def boxpos(f,color):
    for r,c in np.argwhere(f==6):
        blk=f[max(0,r-2):r+3, max(0,c-2):c+3]
        if color in blk: return (int(r),int(c))
    return None
def active(f):
    for col in (12,15):
        for b in P.connected_components(f,colors=[col],min_area=1):
            if b.area==1:
                r,c=int(b.centroid[0]),int(b.centroid[1])
                nb=set()
                for dr in(-1,0,1):
                    for dc in(-1,0,1):
                        rr,cc=r+dr,c+dc
                        if 0<=rr<64 and 0<=cc<64: nb.add(int(f[rr,cc]))
                if 0 in nb: return (r,c)
    return None
def init_eps(f):
    d={12:[],15:[]}
    for color in (12,15):
        for b in P.connected_components(f,colors=[color],min_area=1):
            if b.area!=1: continue
            r,c=int(b.centroid[0]),int(b.centroid[1])
            nb=set()
            for dr in(-1,0,1):
                for dc in(-1,0,1):
                    rr,cc=r+dr,c+dc
                    if 0<=rr<64 and 0<=cc<64: nb.add(int(f[rr,cc]))
            if 0 in nb or 3 in nb: d[color].append((r,c))
    return d
def drive(c, eps, color, T, iters=80, verbose=False):
    def cur(): return boxpos(_arr(c),color)
    for it in range(iters):
        b=cur()
        if b==T: return b
        cand=[]
        for i,e in enumerate(eps[color]):
            dsts=set()
            for frac in (1.0,.8,.6,.45,.3,.2,.12,.07):
                dsts.add((int(round(e[0]+(T[0]-e[0])*frac)), int(round(e[1]+(T[1]-e[1])*frac))))
            for dr,dc in [(-5,0),(5,0),(0,-5),(0,5),(-4,-4),(4,4),(-4,4),(4,-4),(-7,0),(7,0),(0,-7),(0,7)]:
                dsts.add((T[0]+dr,T[1]+dc))
            for dst in dsts:
                if not(0<=dst[0]<64 and 0<=dst[1]<64): continue
                if dst==e: continue
                if any(abs(dst[0]-o[0])<3 and abs(dst[1]-o[1])<3 for j,o in enumerate(eps[color]) if j!=i): continue
                cc=c.clone(); cc.step(6,e[1],e[0]); cc.step(6,dst[1],dst[0])
                if active(_arr(cc))!=(dst[0],dst[1]): continue
                nb=boxpos(_arr(cc),color)
                d=abs(nb[0]-T[0])+abs(nb[1]-T[1])
                cand.append((d,i,e,dst))
        if not cand: 
            if verbose: print("no cand",it,b); break
        cand.sort()
        _,i,e,dst=cand[0]
        c.step(6,e[1],e[0]); c.step(6,dst[1],dst[0]); eps[color][i]=dst
        if verbose: print(f"it{it} ep{i}{e}->{dst} box={cur()} dist={cand[0][0]}")
    return cur()
def solver(env):
    place_box_on_ring(env)
    c=env.clone()
    eps=init_eps(_arr(c))
    b=drive(c,eps,15,(18,57),verbose=True)
    print("=> box15",b,"lvl",c.levels_completed)
A.run_program('r11l', solver)
