import sys, os
sys.path.insert(0, '/Users/sasha/gkm/arc/crack_lab')
import gkm_arena as A
import numpy as np
import perception as P
from legs import place_box_on_ring, detect_rope, _arr

# We want to get to level 2. Use run_program with a solver that solves L1 then stops for probing.
# But run_program probably runs a whole program. Let's inspect what env we get.
def solver(env):
    # solve level 1
    place_box_on_ring(env)
    # now at level 2 - dump info
    f = _arr(env)
    print("level completed:", env.levels_completed)
    print("shape", f.shape)
    vals, cnts = np.unique(f, return_counts=True)
    print("colors", dict(zip(vals.tolist(), cnts.tolist())))
    # save frame
    np.save('/tmp/l2frame.npy', f)

levels, path, err = A.run_program('r11l', solver)
print("RESULT", levels, len(path) if path else None, err)
