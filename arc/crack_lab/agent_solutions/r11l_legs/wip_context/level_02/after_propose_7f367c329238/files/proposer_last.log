import sys
sys.path.insert(0, '/Users/sasha/gkm/arc/crack_lab')
import gkm_arena as A
import numpy as np
from legs import place_box_on_ring, _arr
import perception as P

def endpoints(f, color):
    out=[]
    for b in P.connected_components(f,colors=[color],min_area=1):
        if b.area!=1: continue
        r,c=int(b.centroid[0]),int(b.centroid[1])
        nb=set()
        for dr in(-1,0,1):
            for dc in(-1,0,1):
                rr,cc=r+dr,c+dc
                if 0<=rr<64 and 0<=cc<64: nb.add(int(f[rr,cc]))
        if 0 in nb or 3 in nb: out.append((r,c))
    return sorted(out)
def six(f): return sorted((int(r),int(c)) for r,c in np.argwhere(f==6))

def move_ep(env, frm, dst):
    env.step(6, frm[1], frm[0])   # select
    env.step(6, dst[1], dst[0])   # drop

def solver(env):
    place_box_on_ring(env)
