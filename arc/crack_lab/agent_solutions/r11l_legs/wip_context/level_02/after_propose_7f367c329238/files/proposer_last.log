def domove(env,frm,dst):
    env.step(6,frm[1],frm[0]); env.step(6,dst[1],dst[0])
def box(f,color):
    # centroid of endpoints
    eps=endpoints(f,color)
    return (sum(e[0] for e in eps)/len(eps), sum(e[1] for e in eps)/len(eps)), eps

def walk(c,color,T,iters=25):
    for it in range(iters):
        cen,eps=box(_arr(c),color)
        if abs(cen[0]-T[0])+abs(cen[1]-T[1])<0.7: break
        best=None
        for e in eps:
            for frac in (1.0,.85,.7,.55,.4,.3,.2,.12,.08):
                dst=(int(round(e[0]+(T[0]-e[0])*frac)), int(round(e[1]+(T[1]-e[1])*frac)))
                if dst==e: continue
                if canmove(c,e,dst):
                    ne=[dst if x==e else x for x in eps]
                    ncen=(sum(x[0] for x in ne)/len(ne), sum(x[1] for x in ne)/len(ne))
                    d=abs(ncen[0]-T[0])+abs(ncen[1]-T[1])
                    if best is None or d<best[0]: best=(d,e,dst)
                    break
        if best is None: 
            # try lateral straddle: move endpoints around T
            break
        cen0=abs(cen[0]-T[0])+abs(cen[1]-T[1])
        if best[0]>=cen0-1e-6: break
        domove(c,best[1],best[2])
    return c

def solver(env):
    place_box_on_ring(env)
    c=env.clone()
