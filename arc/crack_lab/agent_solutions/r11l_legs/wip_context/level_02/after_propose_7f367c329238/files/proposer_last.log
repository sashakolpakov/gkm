        cand.sort()
        d0=abs(b[0]-T[0])+abs(b[1]-T[1])
        if cand[0][0]>=d0: 
            if verbose: print("no-improve",it,b,"best",cand[0][0]); break
        _,i,e,dst=cand[0]
        c.step(6,e[1],e[0]); c.step(6,dst[1],dst[0])
        eps[color][i]=dst
        if verbose: print(f"it{it} ep{i} {e}->{dst} box={cur()}")
    return cur()

def solver(env):
    place_box_on_ring(env)
    c=env.clone()
    eps=init_eps(_arr(c))
    b12=drive(c,eps,12,(51,40),verbose=True)
    print("=> box12",b12,"lvl",c.levels_completed)
    b15=drive(c,eps,15,(18,57),verbose=True)
    print("=> box15",b15,"lvl",c.levels_completed)
A.run_program('r11l', solver)
