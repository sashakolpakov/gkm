import sys
sys.path.insert(0, '/Users/sasha/gkm/arc/crack_lab')
import gkm_arena as A
import numpy as np
from legs import place_box_on_ring, _arr

def markers(f):
    """return dict of endpoint markers: {(r,c):('active'/'other', centercolor)} and boxes, rings"""
    def neigh(r,c):
        s=set()
        for dr in(-1,0,1):
            for dc in(-1,0,1):
                if dr==0 and dc==0: continue
                rr,cc=r+dr,c+dc
                if 0<=rr<64 and 0<=cc<64: s.add(int(f[rr,cc]))
        return s
    eps=[]
    for r,c in np.argwhere((f!=5)&(f!=0)&(f!=3)&(f!=2)&(f!=10)&(f!=1)):
        n=neigh(int(r),int(c))
        if 0 in n and f[r,c]!=6:
            eps.append(('active',int(f[r,c]),int(r),int(c)))
        elif 3 in n:
            eps.append(('other',int(f[r,c]),int(r),int(c)))
    return eps

def sixes(f):
    return [(int(r),int(c)) for r,c in np.argwhere(f==6)]

def solver(env):
    place_box_on_ring(env)   # L1
    f=_arr(env)
    print("=== L2 initial ===")
    print("eps", markers(f))
    print("sixes", sixes(f))
    # experiment: click on a far cell to see what moves (active endpoint)
    c=env.clone()
    c.step(6, 30, 30)  # x=30,y=30 => col30,row30
    f2=_arr(c)
    print("after click(col30,row30): eps", markers(f2), "sixes", sixes(f2))

A.run_program('r11l', solver)
