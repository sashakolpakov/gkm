from l2env import get_l2_env
import numpy as np
from collections import deque
env=get_l2_env()
f=np.asarray(env.frame())
# walkable = floor(5) or 8 (removable) ; treat 9-chamber-walls and 0 as blocked
# avatar center approx (28,52). flood from there over 5-or-8 cells
walk = (f==5)|(f==8)
H,W=f.shape
seen=np.zeros_like(walk)
# start from a known floor cell near avatar start, e.g. (24,52) just above avatar
# avatar at rows26-30 col49-53; floor above at row24? find a 5 cell near avatar
# pick (14,52)
starts=[(r,c) for r in range(H) for c in range(W) if walk[r,c] and 48<=c<=54 and r==14]
print('starts',starts[:3])
q=deque(starts)
for s in starts: seen[s]=True
while q:
    r,c=q.popleft()
    for dr,dc in((1,0),(-1,0),(0,1),(0,-1)):
        nr,nc=r+dr,c+dc
        if 0<=nr<H and 0<=nc<W and walk[nr,nc] and not seen[nr,nc]:
            seen[nr,nc]=True; q.append((nr,nc))
# is chamber-adjacent floor reached? chamber left opening around (22,24)
print('reached (22,23)?',seen[22,23],'(22,25)?',seen[22,25],'(18,27)?',seen[18,27])
print('reached (20,20)?',seen[20,20],'(22,20)?',seen[22,20])
# count reached
print('reached floor cells',int((seen&walk).sum()),'total walkable',int(walk.sum()))
# show reached map
chars=lambda r,c: ('R' if seen[r,c] else ('8' if f[r,c]==8 else (' ' if f[r,c]==5 else ('9' if f[r,c]==9 else '.'))))
print('    '+''.join(str(c%10) for c in range(7,56)))
for r in range(14,56):
    print(f'{r:3} '+''.join(chars(r,c) for c in range(7,56)))
