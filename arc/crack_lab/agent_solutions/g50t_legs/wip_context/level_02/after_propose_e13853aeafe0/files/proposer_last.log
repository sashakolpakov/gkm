from l2env import get_l2_env
from legs import clone_after, _components
import numpy as np
from collections import deque
import heapq, time

def avpos(f):
    comps=_components(f==9)
    cand=[c for c in comps if 5<len(c[2])<40 and c[0]<60]
    if not cand: return None
    cand.sort(key=lambda c:-len(c[2]))
    return (cand[0][0],cand[0][1])

MOVES=(1,2,3,4)

def fast_reach(start):
    """BFS over avatar positions (dedup on pos). Returns (reward_path or None, {pos:path})."""
    base=int(start.levels_completed)
    f=np.asarray(start.frame()); s=avpos(f)
    if s is None: return None,{}
    paths={s:[]}; seen={s}
    q=deque([(start.clone(),s,[])])
    while q:
        node,pos,path=q.popleft()
        for a in MOVES:
            c=node.clone(); c.step(a)
            if int(c.levels_completed)>base:
                return path+[a],paths
            p=avpos(np.asarray(c.frame()))
            if p is None or p==pos or p in seen: continue
            seen.add(p); paths[p]=path+[a]
            q.append((c,p,path+[a]))
    return None,paths

def macro_search(env, max_expand=400, time_limit=550):
    t=time.time()
    rp0,reach0=fast_reach(env)
    if rp0 is not None: return rp0
    seen={frozenset(reach0)}
    pq=[(-len(reach0),0,env.clone(),[])]; cnt=1; maxr=len(reach0)
    while pq and cnt<max_expand and time.time()-t<time_limit:
        negn,_,node,prefix=heapq.heappop(pq)
        rp,reach=fast_reach(node)
        if rp is not None: return prefix+rp
        for pos,path in sorted(reach.items(), key=lambda kv:len(kv[1])):
            c=clone_after(node, path+[5])
            rp2,reach2=fast_reach(c)
            if rp2 is not None:
                return prefix+path+[5]+rp2
            rk=frozenset(reach2)
            if rk in seen: continue
            seen.add(rk); maxr=max(maxr,len(reach2))
            heapq.heappush(pq,(-len(reach2),cnt,c,prefix+path+[5])); cnt+=1
    print('no sol; expanded',cnt,'maxreach',maxr,'distinct',len(seen),'time',round(time.time()-t,1))
    return None

if __name__=='__main__':
    env=get_l2_env()
    t=time.time()
    rp,reach=fast_reach(env)
    print('fast_reach time',round(time.time()-t,2),'n',len(reach),'reward',rp is not None)
    sol=macro_search(env, max_expand=400)
    print('SOL',sol)
