from l2env import get_l2_env
from legs import clone_after
import numpy as np
from legs import _components
def av(f):
    comps=_components(f==9)
    cand=[c for c in comps if 5<len(c[2])<40 and c[0]<60]
    cand.sort(key=lambda c:-len(c[2]))
    return (cand[0][0],cand[0][1]) if cand else None
env=get_l2_env()
# Try the L1-style: navigate toward the 9-chamber (rows19-25 cols24-31).
# From start (26,50) move LEFT toward chamber. Explore reaching col ~32 row ~19-25.
# Let's brute BFS with 8-config key.
from collections import deque
def key(e):
    f=np.asarray(e.frame())
    a=av(f)
    m8=(f==8).tobytes()
    return (a,hash(m8))
base=env.levels_completed
start=env.clone()
q=deque([(start,[])])
seen={key(start)}
found=None
steps=0
import time; t=time.time()
while q and steps<4000:
    node,path=q.popleft()
    for aa in (1,2,3,4,5):
        c=node.clone(); c.step(aa); steps+=1
        if c.levels_completed>base:
            found=path+[aa]; break
        k=key(c)
        if k in seen: continue
        seen.add(k)
        if len(path)<40:
            q.append((c,path+[aa]))
    if found: break
print('found',found,'steps',steps,'seen',len(seen),'time',round(time.time()-t,1))
