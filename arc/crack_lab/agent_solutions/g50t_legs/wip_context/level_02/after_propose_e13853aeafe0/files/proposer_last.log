from l2env import get_l2_env
from legs import clone_after, _components
import numpy as np
def snake(f):
    m8=np.argwhere(f==8)
    if not len(m8): return 0,None
    return len(m8),(int(m8[:,0].min()),int(m8[:,1].min()),int(m8[:,0].max()),int(m8[:,1].max()))
def av(f):
    comps=_components(f==9); cand=[c for c in comps if 5<len(c[2])<40 and c[0]<60]; cand.sort(key=lambda c:-len(c[2]))
    return (cand[0][0],cand[0][1]) if cand else None
env=get_l2_env()
# greedily push: try each move, keep ones that reduce n8 (advance snake)
c=env.clone(); path=[]
for it in range(20):
    f=np.asarray(c.frame()); n,bb=snake(f); base=c.levels_completed
    best=None
    for a in [1,2,3,4]:
        cc=clone_after(c,a); ff=np.asarray(cc.frame()); n2,_=snake(ff)
        if cc.levels_completed>base: best=('WIN',a,cc); break
        if n2<n: best=(n2,a,cc); break
    if best is None:
        print('it',it,'no snake-advancing move; av',av(f),'n8',n,bb); break
    if best[0]=='WIN': print('it',it,'WIN move',best[1]); path.append(best[1]); break
    n2,a,cc=best; path.append(a); c=cc
