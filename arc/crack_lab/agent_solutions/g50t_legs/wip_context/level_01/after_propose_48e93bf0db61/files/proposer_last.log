    path=P.bounded_bfs(env,goal,actions=(1,2,3,4),key_fn=key,max_states=5000,max_depth=40)
    print("path",path)
    if path:
        r=P.path_result(env,path)
        print("levels",r['levels_completed'],"terminal",r['terminal'])
    raise SystemExit
