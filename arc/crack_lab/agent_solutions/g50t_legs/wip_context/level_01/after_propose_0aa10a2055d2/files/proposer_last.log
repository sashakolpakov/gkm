import gkm_arena as A
import perception as P
import numpy as np

def avatar(env):
    # interior 9 blob (col>10) that's the avatar - biggest 9 blob in maze
    bl=[b for b in P.connected_components(env.frame(),colors=[9]) if b.bbox[1]>10 and b.bbox[0]<40]
