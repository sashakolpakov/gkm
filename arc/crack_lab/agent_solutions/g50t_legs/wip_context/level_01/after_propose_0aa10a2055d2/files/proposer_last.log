from collections import deque

def avatar_tl(env):
    bl=[b for b in P.connected_components(env.frame(),colors=[9]) if b.bbox[1]>10 and b.bbox[0]<40]
    bl.sort(key=lambda b:-b.area)
    return bl[0].bbox[:2] if bl else None

