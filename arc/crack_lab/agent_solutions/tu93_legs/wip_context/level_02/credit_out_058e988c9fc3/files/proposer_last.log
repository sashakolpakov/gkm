$ cd /Users/sasha/gkm/arc/crack_lab/runs/scratch/gkm_legs_ws_tu93_opus && cat > /tmp/graph.py << 'EOF'
import numpy as np
f = np.load('/tmp/lvl2_frame.npy')
bg=5
R0,C0=21,12  # top-left including goal block
cell=3
def center(br,bc):
    r,c=R0+br*cell,C0+bc*cell
    if r+cell>64 or c+cell>64: return bg
    return int(f[r+1,c+1])
# node block indices even
maxbr=(35-R0)//cell  # up to row35
maxbc=(50-C0)//cell
print("maxbr",maxbr,"maxbc",maxbc)
nodes={}
for br in range(0,maxbr+1,2):
    for bc in range(0,maxbc+1,2):
        col=center(br,bc)
        if col!=bg:
            nodes[(br//2,bc//2)]=col
print("nodes:",nodes)
# edges: horizontal at odd bc, vertical at odd br
def present(br,bc):
    return center(br,bc)!=bg
edges=[]
for (i,j),col in nodes.items():
    br,bc=2*i,2*j
    # right
    if (i,j+1) in nodes and present(br,bc+1): edges.append(((i,j),(i,j+1)))
    # down
    if (i+1,j) in nodes and present(br+1,bc): edges.append(((i,j),(i+1,j)))
for e in edges: print(e)
EOF
