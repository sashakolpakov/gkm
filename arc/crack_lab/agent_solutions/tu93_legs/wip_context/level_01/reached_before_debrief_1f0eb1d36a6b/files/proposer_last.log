import sys
sys.path.insert(0, '/Users/sasha/gkm/arc/crack_lab')
import gkm_arena as A
import numpy as np
from collections import deque

env = A.Arena('tu93')
f = env.frame().copy()
R0,C0=15,15
def bm(br,bc):
    r=R0+br*3; c=C0+bc*3
    return int(f[r+1,c+1])
# nodes i,j 0..5 -> block (2i,2j)
# find start (9) and goal (14) nodes
def nodecolor(i,j): return bm(2*i,2*j)
start=goal=None
for i in range(6):
    for j in range(6):
        v=nodecolor(i,j)
        if v==9: start=(i,j)
        if v==14: goal=(i,j)
print("start",start,"goal",goal)
# edges
def edges(i,j):
    out=[]
    # right
    if j<5 and bm(2*i,2*j+1)==2: out.append((i,j+1,4))
    if j>0 and bm(2*i,2*j-1)==2: out.append((i,j-1,3))
    if i<5 and bm(2*i+1,2*j)==2: out.append((i+1,j,2))
    if i>0 and bm(2*i-1,2*j)==2: out.append((i-1,j,1))
    return out
# BFS
q=deque([(start,[])]); seen={start}
path=None
while q:
    (i,j),p=q.popleft()
    if (i,j)==goal: path=p; break
    for ni,nj,a in edges(i,j):
        if (ni,nj) not in seen:
            seen.add((ni,nj)); q.append(((ni,nj),p+[a]))
print("path actions:",path,"len",len(path) if path else None)
EOF
