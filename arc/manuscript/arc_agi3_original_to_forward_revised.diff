+\begin{aligned}
+  \text{probe for compressible novelty}
+   &\longrightarrow \text{propose a cofibrant attachment}\\
+   &\longrightarrow \text{execute and replay}
+    \longrightarrow \text{retain or refactor}.
+\end{aligned}
